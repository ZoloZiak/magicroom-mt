---
interface Props {
  title: string;
}

const { title } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — MagicRoom Admin</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen bg-slate-50">
    <!-- Header -->
    <header class="bg-white border-b border-pink-100 sticky top-0 z-50">
      <div class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/admin/dashboard" class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-pink-500 flex items-center justify-center text-white font-bold text-lg">
              M
            </div>
            <div>
              <h1 class="font-display text-xl font-bold text-gray-900">MagicRoom</h1>
              <p class="text-xs text-pink-600">Admin Panel</p>
            </div>
          </a>
          
          <nav class="hidden md:flex items-center gap-2">
            <a 
              href="/admin/dashboard" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/dashboard' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              📊 Dashboard
            </a>
            <a 
              href="/admin/gallery" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/gallery' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              🖼️ Galéria
            </a>
            <a 
              href="/admin/dresses" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/dresses' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              👗 Šaty
            </a>
            <a 
              href="/admin/blog" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/blog' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              📝 Blog
            </a>
            <a 
              href="/admin/decor" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/decor' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              🎀 Dekorácie
            </a>
            <a 
              href="/admin/faq" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/faq' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              ❓ FAQ
            </a>
            <a 
              href="/admin/partners" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/partners' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              🤝 Partneri
            </a>
            <a 
              href="/admin/content" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/content' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              ⚙️ Nastavenia
            </a>
            <a 
              href="/admin/help" 
              class:list={[
                "px-4 py-2 rounded-full transition-all duration-300",
                currentPath === '/admin/help' ? "bg-pink-100 text-pink-700 font-medium" : "text-gray-600 hover:bg-pink-50 hover:text-pink-600"
              ]}
            >
              📖 Návod
            </a>
          </nav>

          <form method="POST" action="/api/admin/logout">
            <button 
              type="submit"
              class="flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 hover:border-pink-300 hover:bg-pink-50 transition-all duration-300"
            >
              🚪 <span class="hidden sm:inline">Odhlásiť</span>
            </button>
          </form>
        </div>
      </div>
    </header>

    <!-- Mobile Nav -->
    <nav class="md:hidden bg-white/80 backdrop-blur-md border-b border-pink-100 sticky top-[73px] z-40 overflow-x-auto">
      <div class="flex items-center gap-2 px-4 py-3">
        <a href="/admin/dashboard" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/dashboard' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>📊</a>
        <a href="/admin/gallery" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/gallery' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>🖼️</a>
        <a href="/admin/dresses" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/dresses' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>👗</a>
        <a href="/admin/blog" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/blog' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>📝</a>
        <a href="/admin/decor" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/decor' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>🎀</a>
        <a href="/admin/faq" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/faq' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>❓</a>
        <a href="/admin/partners" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/partners' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>🤝</a>
        <a href="/admin/content" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/content' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>⚙️</a>
        <a href="/admin/help" class:list={["px-3 py-2 rounded-full text-sm whitespace-nowrap", currentPath === '/admin/help' ? "bg-pink-100 text-pink-700" : "text-gray-600"]}>📖</a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>
  </body>
</html>

<style is:global>
  @import '../07-styles/global.css';
  
  /* Additional admin styles */
  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  .font-display {
    font-family: var(--font-display, system-ui);
  }
  
  /* Smooth transitions */
  * {
    transition-property: background-color, border-color, color, fill, stroke, opacity, box-shadow, transform;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }
  
  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #fce7f3;
  }
  ::-webkit-scrollbar-thumb {
    background: #f9a8d4;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #f472b6;
  }
</style>

<script>
  // Toast notification system
  window.showToast = function(message: string, type: 'success' | 'error' = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;
    
    const toast = document.createElement('div');
    toast.className = `px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-slide-in-right ${
      type === 'success' 
        ? 'bg-green-500 text-white' 
        : 'bg-red-500 text-white'
    }`;
    toast.innerHTML = `
      <span class="text-xl">${type === 'success' ? '✓' : '✕'}</span>
      <span class="font-medium">${message}</span>
    `;
    
    container.appendChild(toast);
    
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(100%)';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  };
