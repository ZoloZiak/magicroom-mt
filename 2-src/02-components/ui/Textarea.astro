---
interface Props {
  name: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  rows?: number;
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  name,
  placeholder,
  required = false,
  disabled = false,
  rows = 4,
  class: className = '',
  ...rest
} = Astro.props;

const baseClasses = 'flex min-h-[60px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-base shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 md:text-sm';
---

<textarea
  name={name}
  placeholder={placeholder}
  required={required}
  disabled={disabled}
  rows={rows}
  class:list={[baseClasses, className]}
  {...rest}
></textarea>