---
import { Image } from 'astro:assets';
import Footer from '@/02-components/layout/Footer.astro';
import Header from '@/02-components/layout/Header.astro';
import ScrollToTop from '@/02-components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/02-components/layout/WhatsAppFAB.astro';
import Badge from '@/02-components/ui/Badge.astro';
import Button from '@/02-components/ui/Button.astro';
import { getBookingPageHref } from '@/03-data/site';
import { getFormalDresses, IMAGE_URLS } from '@/03-data/content';
import { getTranslations, getRelativeHref, type Language } from '@/05-lib/translations';
import Layout from '@/04-layouts/Layout.astro';
import Icon from '@/02-components/ui/Icon.astro';

interface Props {
  language: Language;
  skSlug: string;
}

const { language, skSlug } = Astro.props;
const t = getTranslations(language);
const isEn = language === 'en';

const dresses = await getFormalDresses(language);
const firstDressImage = dresses[0]?.imageAsset?.src || IMAGE_URLS.hero;

const productSchema = dresses.map((dress) => ({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: dress.name,
  description: dress.description,
  offers: {
    '@type': 'Offer',
    price: dress.price,
    priceCurrency: 'EUR',
    availability: dress.status === 'available' 
      ? 'https://schema.org/InStock' 
      : 'https://schema.org/SoldOut',
  },
}));
---

<Layout
  title={t.formal.pageTitle}
  description={t.formal.pageDescription}
  image={firstDressImage}
  structuredData={productSchema}
  breadcrumbs={[
    { name: t.nav.home, url: isEn ? '/en' : '/' },
    { name: t.nav.formal, url: getRelativeHref(skSlug, language) },
  ]}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="bg-surface py-12 md:py-20">
      <div class="container mx-auto px-4 text-center">
        <Badge variant="secondary" class="mb-4">
          {t.formal.heroBadge}
        </Badge>
        <h1 class="font-display text-4xl md:text-6xl mb-6">
          {t.formal.heroTitle}
        </h1>
        <p class="max-w-2xl mx-auto text-lg text-muted-foreground">
          {t.formal.heroDescription}
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-background">
      <div class="container mx-auto px-4">
        <div id="formal-dresses-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 items-start">
          {dresses.map((dress) => (
            <div class="group flex flex-col overflow-hidden rounded-[24px] border border-border/50 bg-card transition-all hover:shadow-xl h-full">
              <div class="relative aspect-[2/3] overflow-hidden bg-surface">
                <a 
                  href={dress.images[0].src} 
                  data-pswp-width={dress.images[0].width} 
                  data-pswp-height={dress.images[0].height} 
                  target="_blank"
                  class="block h-full w-full cursor-zoom-in"
                  aria-label={`${dress.name} (${isEn ? 'opens in a new tab' : 'otvorí sa v novom okne'})`}
                >
                    <Image
                      src={dress.images[0]}
                      alt={dress.name}
                      width={600}
                      height={900}
                      class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
                    />
                  </a>
                <div class="absolute right-4 top-4 pointer-events-none">
                  <Badge variant={dress.status === 'available' ? 'success' : 'outline'} class="backdrop-blur-md">
                    {dress.status === 'available' ? t.dresses.statusAvailable : t.dresses.statusReserved}
                  </Badge>
                </div>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex-1">
                    <h2 class="font-display text-2xl line-clamp-2 min-h-[4rem] flex items-center">{dress.name}</h2>
                    <div class="description-container relative mt-2">
                      <div class="description-wrapper overflow-hidden transition-all duration-500 ease-in-out max-h-12">
                        <p class="description-text text-sm text-muted-foreground">
                          {dress.description}
                        </p>
                      </div>
                      <button 
                        class="expand-btn group/expand mt-2 inline-flex items-center gap-1 text-[11px] font-bold uppercase tracking-wider text-primary/70 hover:text-primary transition-colors focus:outline-none"
                        aria-expanded="false"
                      >
                        <span class="btn-text">{isEn ? 'Read More' : 'Viac info'}</span>
                        <Icon name="ChevronDown" class="h-3 w-3 transition-transform duration-300 group-[.active]/expand:rotate-180" />
                      </button>
                    </div>
                  </div>
                  <p class="text-xl font-bold text-cta shrink-0 ml-2 mt-1">{dress.price} €</p>
                </div>

                <div class="mt-auto flex items-center justify-between border-t border-border/50 pt-4">
                  <span class="text-sm font-medium uppercase tracking-widest text-muted-foreground">
                    {t.dresses.sizeLabel} {dress.size}
                  </span>
                  <Button variant="ghost" size="sm" class="group/btn text-muted-foreground hover:text-primary" href={isEn ? '/en/contact#booking' : '/kontakt#booking'}>
                    {t.dresses.bookFitting}
                    <Icon name="ArrowRight" class="ml-2 h-4 w-4 transition-transform group-hover/btn:translate-x-1" />
                  </Button>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-20 text-center p-12 rounded-[40px] bg-surface border border-dashed border-primary/30">
           <Icon name="Star" class="h-10 w-10 text-primary mx-auto mb-6" aria-hidden="true" />
           <h3 class="font-display text-3xl mb-4">{isEn ? 'Looking for wedding dresses?' : 'Hľadáte svadobné šaty?'}</h3>
           <p class="mb-8 text-muted-foreground">{isEn ? 'We also have a beautiful collection of wedding dresses.' : 'V našej ponuke nájdete aj krásnu kolekciu svadobných šiat.'}</p>
           <Button variant="outline" href={getRelativeHref('svadobne-saty', language)}>
              {t.nav.dresses}
           </Button>
        </div>
      </div>
    </section>

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>

<script>
  function setupExpandButtons() {
    const buttons = document.querySelectorAll('.expand-btn');
    buttons.forEach(btn => {
      if ((btn as any)._hasListener) return;
      (btn as any)._hasListener = true;

      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const container = target.closest('.description-container');
        const wrapper = container?.querySelector('.description-wrapper') as HTMLElement;
        const text = wrapper?.querySelector('.description-text') as HTMLElement;
        const btnText = target.querySelector('.btn-text');
        const isEn = document.documentElement.lang === 'en';
        
        if (wrapper && text && btnText) {
          const isExpanded = target.classList.contains('active');
          
          if (isExpanded) {
            wrapper.style.maxHeight = '3rem'; 
            btnText.textContent = isEn ? 'Read More' : 'Viac info';
            target.classList.remove('active');
            target.setAttribute('aria-expanded', 'false');
          } else {
            wrapper.style.maxHeight = text.scrollHeight + 'px';
            btnText.textContent = isEn ? 'Show Less' : 'Menej';
            target.classList.add('active');
            target.setAttribute('aria-expanded', 'true');
          }
        }
      });
    });
  }

  setupExpandButtons();
  document.addEventListener('astro:after-swap', setupExpandButtons);
</script>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  let lightbox: any;

  const initLightbox = () => {
    if (lightbox) {
      lightbox.destroy();
    }
    
    lightbox = new PhotoSwipeLightbox({
      gallery: '#formal-dresses-grid',
      children: 'a[data-pswp-width]',
      pswpModule: () => import('photoswipe'),
      padding: { top: 20, bottom: 20, left: 10, right: 10 },
      showHideAnimationType: 'zoom'
    });
    lightbox.init();
  };

  initLightbox();
  document.addEventListener('astro:after-swap', initLightbox);
</script>

<style is:global>
  .pswp {
    --pswp-bg: rgba(42, 26, 36, 0.95);
  }
  .pswp__img {
    border-radius: 8px;
  }
</style>
