---
import { Image } from 'astro:assets';
import Footer from '@/02-components/layout/Footer.astro';
import Header from '@/02-components/layout/Header.astro';
import ScrollToTop from '@/02-components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/02-components/layout/WhatsAppFAB.astro';
import Badge from '@/02-components/ui/Badge.astro';
import Button from '@/02-components/ui/Button.astro';
import Card from '@/02-components/ui/Card.astro'
import CardContent from '@/02-components/ui/CardContent.astro';
import { getBookingPageHref, PHONE_DISPLAY, PHONE_HREF } from '@/03-data/site';
import { getFounderStory, getGalleryItems, getHomeStats, getTrustReasons, IMAGE_ASSETS, IMAGE_URLS } from '@/03-data/content';
import { getTranslations, getRelativeHref, type Language } from '@/05-lib/translations';
import Layout from '@/04-layouts/Layout.astro';
import Icon from '@/02-components/ui/Icon.astro';

interface Props {
  language: Language;
  skSlug: string;
}

const { language, skSlug } = Astro.props;
const t = getTranslations(language);

const isEn = language === 'en';
const TRUST_REASONS = getTrustReasons(language);
const FOUNDER_STORY = getFounderStory(language);
const GALLERY_ITEMS = await getGalleryItems(language);
const HOME_STATS = getHomeStats(language);

const operatingPrinciples = [
  {
    title: isEn ? 'Personal care' : 'Osobná starostlivosť namiesto chaosu',
    description: isEn ? 'Calm and clear contact.' : 'Každý kontakt s MagicRoom má byť pokojný, jasný a ľudský — od prvej správy až po finálne detaily.',
    icon: 'Heart',
  },
  {
    title: isEn ? 'Up to 50 guests' : 'Svadby a oslavy do 50 hostí',
    description: isEn ? 'Quality and personal approach.' : 'Vedome pracujeme v rozsahu, kde vieme udržať kvalitu, dohľad nad detailmi a osobný prístup Natálie.',
    icon: 'Users',
  },
  {
    title: isEn ? 'Practical help' : 'Praktická pomoc s krásnym výsledkom',
    description: isEn ? 'Save time and enjoy.' : 'Šaty, dekorácie aj poradenstvo majú pomôcť ušetriť čas a spraviť deň harmonickejším, nie komplikovanejším.',
    icon: 'Star',
  },
];
---

<Layout
  title={t.about.pageTitle}
  description={t.about.pageDescription}
  image={IMAGE_URLS.founder}
  breadcrumbs={[
    { name: t.nav.home, url: isEn ? '/en' : '/' },
    { name: t.nav.about, url: getRelativeHref(skSlug, language) },
  ]}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="relative overflow-hidden bg-[linear-gradient(180deg,var(--color-gradient-start)_0%,var(--color-gradient-end)_100%)] pt-12 pb-16 md:pt-20 md:pb-24">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" class="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              {t.about.heroBadge}
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-[0.96] text-foreground md:text-6xl lg:text-7xl animate-fade-in-up animate-stagger-2">
              {t.about.heroTitle}
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-8 text-muted-foreground md:text-xl animate-fade-in-up animate-stagger-3">
              {t.about.heroDescription}
            </p>
            
            <div class="mt-8 luxury-panel p-6 md:p-7 animate-fade-in-up animate-stagger-4">
              <p class="text-lg text-cta mb-1">{isEn ? 'Hi, I\'m Natália' : 'Ahoj, volám sa Natália'}</p>
              <p class="section-kicker">{isEn ? 'Founder' : 'Zakladateľka'}</p>
              <blockquote class="mt-3 font-display text-3xl italic leading-tight text-foreground md:text-4xl">
                „{t.about.storyQuote}“
              </blockquote>
            </div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row items-center animate-fade-in-up animate-stagger-5">
              <Button variant="cta" size="lg" class="sm:min-w-[220px]" href={getBookingPageHref(language)}>
                {t.nav.bookAppointment}
                <Icon name="ArrowRight" class="h-5 w-5 ml-2" />
              </Button>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {HOME_STATS.map((stat, i) => (
                <div class={`rounded-2xl border border-border/70 bg-card/80 px-5 py-4 shadow-sm backdrop-blur animate-fade-in-up animate-stagger-${i + 1}`}>
                  <p class="font-display text-3xl text-cta">{stat.value}</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="photo-card animate-fade-in-right">
            <Image
              src={IMAGE_ASSETS.founder}
              alt="Natália Ondrejková"
              class="w-full rounded-[24px] object-cover"
              width={800}
              height={1000}
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:items-center">
          <div class="max-w-2xl">
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.about.storyTitle}</p>
            <div class="mt-8 space-y-4 text-base leading-7 text-muted-foreground md:text-lg">
              <p>{t.about.storyText1}</p>
              <p>{t.about.storyText2}</p>
            </div>
            <div class="mt-10">
              <Button variant="outline" size="lg" href="#booking">
                {t.home.bookingTitle}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="border-t border-border/40"></div>

    <section class="bg-surface py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.about.principlesSubtitle}</p>
          <h2 class="mt-3 font-display text-4xl">{t.about.principlesTitle}</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {operatingPrinciples.map((item, index) => (
            <div class={`rounded-2xl border border-border/70 bg-card p-6 shadow-[var(--shadow-soft)] animate-fade-in-up animate-stagger-${index+1}`}>
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
                <Icon name={item.icon as any} class="h-5 w-5 text-primary" />
              </div>
              {item.title && <h3 class="mt-5 text-xl font-semibold">{item.title}</h3>}
              <p class="mt-3 text-base text-muted-foreground">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-primary-900 py-20 text-white relative overflow-hidden">
      <div class="container relative mx-auto px-4">
        <div class="mx-auto max-w-4xl rounded-[30px] bg-accent/5 px-6 py-8 md:px-10 md:py-12 border border-accent/20">
          <div class="text-center mb-10">
            <p class="text-sm uppercase tracking-[0.24em] text-accent">{t.home.whySubtitle}</p>
            <h2 class="mt-4 font-display text-4xl md:text-5xl">{t.home.whyTitle}</h2>
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            {TRUST_REASONS.map((reason) => (
              <div class="rounded-2xl border border-accent/10 bg-accent/5 p-5 transition-colors hover:bg-accent/10">
                <div class="flex items-start gap-3 text-accent">
                  <Icon name="CheckCircle2" class="h-4 w-4 mt-1" />
                  <div>
                    {reason.title && <h3 class="text-lg font-semibold text-white">{reason.title}</h3>}
                    <p class="mt-2 text-sm text-white/70">{reason.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-12 text-center">
             <Button variant="secondary" size="lg" href={getBookingPageHref(language)}>
                {t.nav.bookAppointment}
             </Button>
          </div>
        </div>
      </div>
    </section>

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>
