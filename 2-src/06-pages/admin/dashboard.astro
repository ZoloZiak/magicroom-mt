---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getAnalytics } from '@/lib/storage';

export const prerender = false;

// Read analytics data using the new storage utility
const analytics = await getAnalytics();

// Calculate stats
const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const weekAgo = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000);
const monthAgo = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);

const todayBookings = (analytics.bookingSubmissions || []).filter((c: any) => new Date(c.timestamp) >= today).length;
const weekBookings = (analytics.bookingSubmissions || []).filter((c: any) => new Date(c.timestamp) >= weekAgo).length;
const monthBookings = (analytics.bookingSubmissions || []).filter((c: any) => new Date(c.timestamp) >= monthAgo).length;

const todayWhatsApp = (analytics.whatsappClicks || []).filter((c: any) => new Date(c.timestamp) >= today).length;
const weekWhatsApp = (analytics.whatsappClicks || []).filter((c: any) => new Date(c.timestamp) >= weekAgo).length;
const monthWhatsApp = (analytics.whatsappClicks || []).filter((c: any) => new Date(c.timestamp) >= monthAgo).length;

const todayContacts = (analytics.contactFormSubmissions || []).filter((c: any) => new Date(c.timestamp) >= today).length;
const weekContacts = (analytics.contactFormSubmissions || []).filter((c: any) => new Date(c.timestamp) >= weekAgo).length;
const monthContacts = (analytics.contactFormSubmissions || []).filter((c: any) => new Date(c.timestamp) >= monthAgo).length;

const recentBookings = (analytics.bookingSubmissions || []).slice(-5).reverse();
---

<AdminLayout title="Dashboard">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">📊 Dashboard</h1>
  
  <!-- Stats cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <p class="text-sm text-gray-500 mb-1">Rezervácie</p>
      <p class="text-3xl font-bold text-pink-600">{weekBookings}</p>
      <div class="flex items-center gap-1 mt-2">
         <span class="text-xs text-gray-400">za posledný týždeň</span>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <p class="text-sm text-gray-500 mb-1">WhatsApp</p>
      <p class="text-3xl font-bold text-green-600">{weekWhatsApp}</p>
      <p class="text-xs text-gray-400 mt-2">za posledný týždeň</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <p class="text-sm text-gray-500 mb-1">Kontakt formulár</p>
      <p class="text-3xl font-bold text-blue-600">{weekContacts}</p>
      <p class="text-xs text-gray-400 mt-2">za posledný týždeň</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <p class="text-sm text-gray-500 mb-1">Celkom konverzií</p>
      <p class="text-3xl font-bold text-purple-600">{weekBookings + weekWhatsApp + weekContacts}</p>
      <p class="text-xs text-gray-400 mt-2">za posledný týždeň</p>
    </div>
  </div>
  
  <!-- Detailed stats -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Podľa obdobia</h2>
      <div class="space-y-4">
        <!-- Visual bar chart -->
        <div class="space-y-2">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">Dnes</span>
            <span class="font-medium">{todayBookings + todayWhatsApp + todayContacts} konverzií</span>
          </div>
          <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-pink-500 rounded-full" style={`width: ${Math.min(100, (todayBookings + todayWhatsApp + todayContacts) * 20)}%`}></div>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">Týždeň</span>
            <span class="font-medium">{weekBookings + weekWhatsApp + weekContacts} konverzií</span>
          </div>
          <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-pink-500 rounded-full" style={`width: ${Math.min(100, (weekBookings + weekWhatsApp + weekContacts) * 10)}%`}></div>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">Mesiac</span>
            <span class="font-medium">{monthBookings + monthWhatsApp + monthContacts} konverzií</span>
          </div>
          <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-pink-500 rounded-full" style={`width: ${Math.min(100, (monthBookings + monthWhatsApp + monthContacts) * 3)}%`}></div>
          </div>
        </div>
      </div>
      
      <!-- Breakdown table -->
      <table class="w-full mt-6">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="text-left py-3 text-sm font-medium text-gray-500">Obdobie</th>
            <th class="text-right py-3 text-sm font-medium text-gray-500">📅</th>
            <th class="text-right py-3 text-sm font-medium text-gray-500">💬</th>
            <th class="text-right py-3 text-sm font-medium text-gray-500">📝</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-100">
            <td class="py-3 text-gray-900">Dnes</td>
            <td class="py-3 text-right font-medium text-pink-600">{todayBookings}</td>
            <td class="py-3 text-right font-medium text-green-600">{todayWhatsApp}</td>
            <td class="py-3 text-right font-medium text-blue-600">{todayContacts}</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-3 text-gray-900">Týždeň</td>
            <td class="py-3 text-right font-medium text-pink-600">{weekBookings}</td>
            <td class="py-3 text-right font-medium text-green-600">{weekWhatsApp}</td>
            <td class="py-3 text-right font-medium text-blue-600">{weekContacts}</td>
          </tr>
          <tr>
            <td class="py-3 text-gray-900">Mesiac</td>
            <td class="py-3 text-right font-medium text-pink-600">{monthBookings}</td>
            <td class="py-3 text-right font-medium text-green-600">{monthWhatsApp}</td>
            <td class="py-3 text-right font-medium text-blue-600">{monthContacts}</td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm p-6 border border-pink-50">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Posledné aktivity</h2>
      <div class="space-y-3">
        {recentBookings.length > 0 ? recentBookings.map((b: any) => (
          <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
            <span class="text-2xl">📅</span>
            <div>
              <p class="text-sm font-medium text-gray-900">{b.name || 'Nová rezervácia'}</p>
              <p class="text-xs text-gray-500">{new Date(b.timestamp).toLocaleString('sk-SK')}</p>
            </div>
          </div>
        )) : (
          <p class="text-gray-400 text-sm">Žiadne aktivity</p>
        )}
      </div>
    </div>
  </div>
</AdminLayout>
