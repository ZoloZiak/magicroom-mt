export const prerender = false;
---
import AdminLayout from '@/04-layouts/AdminLayout.astro';
import { readFile } from 'fs/promises';
import { join } from 'path';

const galleryPath = join(process.cwd(), 'content/json/gallery.json');
let gallery = { gallery: [] };

try {
  const content = await readFile(galleryPath, 'utf-8');
  gallery = JSON.parse(content);
} catch (e) {
  // File doesn't exist
}

const GITHUB_RAW = 'https://raw.githubusercontent.com/ZoloZiak/magicroom-mt/main';

function getGalleryImageUrl(filename: string): string {
  return `${GITHUB_RAW}/content/images/gallery/${filename}`;
}
---

<AdminLayout title="Galéria">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">🖼️ Galéria</h1>
    <a href="/galeria" target="_blank" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200">👁️ Náhľad</a>
  </div>

  <!-- Upload Section -->
  <div class="bg-white rounded-3xl shadow-xl border border-pink-100 p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">📤 Nahrať novú fotku</h2>
    
    <form id="upload-form" enctype="multipart/form-data" class="space-y-4">
      <div id="drop-zone" class="border-2 border-dashed border-pink-200 rounded-2xl p-8 text-center hover:border-pink-400 transition-colors cursor-pointer">
        <input type="file" id="file-input" name="file" accept="image/*" class="hidden" />
        <div class="text-4xl mb-2">📷</div>
        <p class="text-gray-600">Kliknite alebo pretiahnite fotku sem</p>
        <p class="text-sm text-gray-400 mt-2">PNG, JPG, WebP - max 5MB</p>
      </div>
      
      <div id="preview-container" class="hidden">
        <div class="flex items-center gap-4 p-4 bg-pink-50 rounded-2xl">
          <img id="preview-image" class="w-24 h-24 object-cover rounded-xl" />
          <div class="flex-1">
            <p id="preview-name" class="font-medium text-gray-900"></p>
            <p id="preview-size" class="text-sm text-gray-500"></p>
          </div>
          <button type="button" id="clear-preview-btn" class="text-red-500 hover:text-red-700">✕</button>
        </div>
      </div>

      <input type="hidden" name="folder" value="gallery" />
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Názov (SK)</label>
          <input type="text" id="title-sk" name="titleSk" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all" placeholder="Napríklad: Ružová elegancia" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Názov (EN)</label>
          <input type="text" id="title-en" name="titleEn" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all" placeholder="Napríklad: Pink elegance" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-2">Alt text (SK)</label>
          <input type="text" id="alt-sk" name="altSk" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all" placeholder="Popis obrázka pre SEO" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-2">Alt text (EN)</label>
          <input type="text" id="alt-en" name="altEn" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all" placeholder="Image description for SEO" />
        </div>
      </div>

      <button type="submit" class="w-full bg-pink-500 text-white py-3 px-6 rounded-2xl font-medium hover:shadow-lg transition-all">
        🚀 Nahrať a pridať do galérie
      </button>
    </form>
  </div>

  <!-- Gallery Items -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    {gallery.gallery.map((item: any, i: number) => {
      const imgUrl = getGalleryImageUrl(item.filename);
      return (
      <div class="bg-white rounded-2xl shadow-lg border border-pink-100 overflow-hidden group hover:shadow-xl transition-all">
        <div class="aspect-[3/4] bg-gray-100 relative">
          {imgUrl ? (
            <img src={imgUrl} alt={item.alt} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-gray-100 text-gray-400">
              <div class="text-center">
                <div class="text-4xl mb-2">🖼️</div>
                <div class="text-sm">{item.filename}</div>
              </div>
            </div>
          )}
          <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
            <a href="/galeria" target="_blank" class="p-2 bg-white rounded-full hover:bg-pink-50 transition-colors" title="Zobraziť na stránke">👁️</a>
            <button type="button" class="open-edit-btn p-2 bg-white rounded-full hover:bg-pink-50 transition-colors" data-index={i} title="Upraviť">✏️</button>
            <button type="button" class="delete-btn p-2 bg-white rounded-full hover:bg-red-50 transition-colors text-red-500" data-filename={item.filename} title="Vymazať">🗑️</button>
          </div>
        </div>
        <div class="p-4">
          <h3 class="font-medium text-gray-900 truncate">{item.title || item.titleEn || 'Bez názvu'}</h3>
          <p class="text-xs text-gray-500 mt-1 truncate">{item.filename}</p>
        </div>
      </div>
      );
    })}
  </div>

  <!-- Empty state -->
  {gallery.gallery.length === 0 && (
    <div class="text-center py-12">
      <div class="text-6xl mb-4">🖼️</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">Galéria je prázdna</h3>
      <p class="text-gray-500">Nahrajte prvú fotku do galérie</p>
    </div>
  )}
</AdminLayout>

<!-- Edit Modal -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden">
  <div id="modal-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-3xl p-6 w-full max-w-md">
    <h2 class="text-xl font-bold mb-4">Upraviť fotku</h2>
    <form id="edit-form">
      <input type="hidden" id="edit-index" />
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Názov (SK)</label>
          <input type="text" id="edit-title-sk" class="w-full px-3 py-2 border rounded-lg" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Názov (EN)</label>
          <input type="text" id="edit-title-en" class="w-full px-3 py-2 border rounded-lg" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Alt text (SK)</label>
          <input type="text" id="edit-alt-sk" class="w-full px-3 py-2 border rounded-lg" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Alt text (EN)</label>
          <input type="text" id="edit-alt-en" class="w-full px-3 py-2 border rounded-lg" />
        </div>
      </div>
      <div class="flex gap-3 mt-6">
        <button type="button" id="close-modal-btn" class="flex-1 px-4 py-2 border rounded-lg hover:bg-gray-50">Zrušiť</button>
        <button type="submit" class="flex-1 px-4 py-2 bg-pink-500 text-white rounded-lg hover:bg-pink-600">Uložiť</button>
      </div>
    </form>
  </div>
</div>

<script>
  // @ts-ignore
  const galleryItems = JSON.parse('{JSON.stringify(gallery.gallery)}'.replace(/&quot;/g, '"'));
  let selectedFile: File | null = null;

  const fileInput = document.getElementById('file-input') as HTMLInputElement | null;
  const previewImage = document.getElementById('preview-image') as HTMLImageElement | null;
  const previewName = document.getElementById('preview-name') as HTMLElement | null;
  const previewSize = document.getElementById('preview-size') as HTMLElement | null;
  const previewContainer = document.getElementById('preview-container') as HTMLElement | null;
  const titleSkInput = document.getElementById('title-sk') as HTMLInputElement | null;
  const dropZone = document.getElementById('drop-zone') as HTMLElement | null;

  function handleFileSelect(file: File) {
    selectedFile = file;
    
    const reader = new FileReader();
    reader.onload = function(e) {
      if (previewImage && e.target?.result) {
        previewImage.src = e.target.result as string;
      }
      if (previewName) previewName.textContent = file.name;
      if (previewSize) previewSize.textContent = (file.size / 1024 / 1024).toFixed(2) + ' MB';
      if (previewContainer) previewContainer.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
    
    const nameWithoutExt = file.name.replace(/\.[^/.]+$/, '').replace(/[-_]/g, ' ');
    if (titleSkInput) {
      titleSkInput.value = nameWithoutExt.charAt(0).toUpperCase() + nameWithoutExt.slice(1);
    }
  }

  dropZone?.addEventListener('click', () => fileInput?.click());

  fileInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) handleFileSelect(file);
  });

  document.getElementById('clear-preview-btn')?.addEventListener('click', () => {
    selectedFile = null;
    if (fileInput) fileInput.value = '';
    if (previewContainer) previewContainer.classList.add('hidden');
  });

  // Edit Modal logic
  const editModal = document.getElementById('edit-modal');
  const editIndexInput = document.getElementById('edit-index') as HTMLInputElement;
  const editTitleSk = document.getElementById('edit-title-sk') as HTMLInputElement;
  const editTitleEn = document.getElementById('edit-title-en') as HTMLInputElement;
  const editAltSk = document.getElementById('edit-alt-sk') as HTMLInputElement;
  const editAltEn = document.getElementById('edit-alt-en') as HTMLInputElement;

  document.querySelectorAll('.open-edit-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
      const item = galleryItems[index];
      if (editIndexInput) editIndexInput.value = index.toString();
      if (editTitleSk) editTitleSk.value = item.title || '';
      if (editTitleEn) editTitleEn.value = item.titleEn || '';
      if (editAltSk) editAltSk.value = item.alt || '';
      if (editAltEn) editAltEn.value = item.altEn || '';
      editModal?.classList.remove('hidden');
    });
  });

  const closeModal = () => editModal?.classList.add('hidden');
  document.getElementById('close-modal-btn')?.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);

  // Delete logic
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const filename = (e.currentTarget as HTMLElement).dataset.filename;
      if (!confirm('Naozaj chcete vymazať túto fotku?')) return;
      
      const newItems = galleryItems.filter((item: any) => item.filename !== filename);
      
      try {
        const response = await fetch('/api/admin/save-gallery', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: newItems })
        });
        const result = await response.json();
        if (result.success) {
          (window as any).showToast('Fotka vymazaná!');
          setTimeout(() => window.location.reload(), 1500);
        }
      } catch (err) {
        console.error(err);
      }
    });
  });

  // Handle forms
  document.getElementById('edit-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const index = parseInt(editIndexInput.value);
    const updatedItem = {
      ...galleryItems[index],
      title: editTitleSk.value,
      titleEn: editTitleEn.value,
      alt: editAltSk.value,
      altEn: editAltEn.value,
    };
    
    galleryItems[index] = updatedItem;
    
    try {
      const response = await fetch('/api/admin/save-gallery', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: galleryItems })
      });
      const result = await response.json();
      if (result.success) {
        (window as any).showToast('Zmeny uložené!');
        setTimeout(() => window.location.reload(), 1500);
      }
    } catch (err) {
      console.error(err);
    }
  });

  document.getElementById('upload-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!selectedFile) return;

    const formData = new FormData();
    formData.append('file', selectedFile);
    formData.append('folder', 'gallery');
    formData.append('titleSk', (document.getElementById('title-sk') as HTMLInputElement).value);
    formData.append('titleEn', (document.getElementById('title-en') as HTMLInputElement).value);
    formData.append('altSk', (document.getElementById('alt-sk') as HTMLInputElement).value);
    formData.append('altEn', (document.getElementById('alt-en') as HTMLInputElement).value);

    try {
      const response = await fetch('/api/admin/upload-gallery-item', {
        method: 'POST',
        body: formData
      });
      const result = await response.json();
      if (result.success) {
        (window as any).showToast('Fotka bola pridaná do galérie!');
        setTimeout(() => window.location.reload(), 1500);
      }
    } catch (err) {
      console.error(err);
    }
  });

  // Drag and drop
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-pink-400', 'bg-pink-50');
  });
  
  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-pink-400', 'bg-pink-50');
  });
  
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-pink-400', 'bg-pink-50');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) {
      handleFileSelect(file);
    }
  });
</script>
