---
interface Props {
  title: string;
}

const { title } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — MagicRoom Admin</title>
</head>
<body class="min-h-screen bg-gray-100">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white min-h-screen fixed">
      <div class="p-6">
        <h1 class="text-xl font-bold">MagicRoom</h1>
        <p class="text-sm text-gray-400">Admin</p>
      </div>
      
      <nav class="mt-6">
        <a 
          href="/admin/dashboard" 
          class:list={[
            "block px-6 py-3 hover:bg-gray-800 transition-colors",
            currentPath === '/admin/dashboard' ? "bg-gray-800 border-l-4 border-pink-500" : ""
          ]}
        >
          📊 Dashboard
        </a>
        <a 
          href="/admin/content" 
          class:list={[
            "block px-6 py-3 hover:bg-gray-800 transition-colors",
            currentPath.startsWith('/admin/content') ? "bg-gray-800 border-l-4 border-pink-500" : ""
          ]}
        >
          📝 Obsah
        </a>
        <a 
          href="/admin/gallery" 
          class:list={[
            "block px-6 py-3 hover:bg-gray-800 transition-colors",
            currentPath === '/admin/gallery' ? "bg-gray-800 border-l-4 border-pink-500" : ""
          ]}
        >
          🖼️ Galéria
        </a>
        <a 
          href="/admin/dresses" 
          class:list={[
            "block px-6 py-3 hover:bg-gray-800 transition-colors",
            currentPath === '/admin/dresses' ? "bg-gray-800 border-l-4 border-pink-500" : ""
          ]}
        >
          👗 Šaty
        </a>
        <a 
          href="/admin/partners" 
          class:list={[
            "block px-6 py-3 hover:bg-gray-800 transition-colors",
            currentPath === '/admin/partners' ? "bg-gray-800 border-l-4 border-pink-500" : ""
          ]}
        >
          🤝 Partneri
        </a>
      </nav>
      
      <div class="absolute bottom-0 w-64 p-6">
        <form method="POST" action="/api/admin/logout">
          <button 
            type="submit"
            class="w-full bg-gray-800 hover:bg-gray-700 py-2 px-4 rounded transition-colors"
          >
            🚪 Odhlásiť
          </button>
        </form>
      </div>
    </aside>
    
    <!-- Main content -->
    <main class="flex-1 ml-64 p-8">
      <slot />
    </main>
  </div>
</body>
</html>
