---
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_OG_IMAGE,
  SITE_NAME,
  getBaseSchemas,
  toAbsoluteUrl,
} from '@/data/site';
import { getAlternateLanguageUrl, type Language } from '@/lib/i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  language?: Language;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_OG_IMAGE,
  keywords,
  type = 'website',
  noindex = false,
  structuredData = [],
  breadcrumbs = [],
  language = Astro.props.language || 'sk',
} = Astro.props;

const canonicalUrl = toAbsoluteUrl(Astro.url.pathname);
const alternateUrl = toAbsoluteUrl(getAlternateLanguageUrl(Astro.url, language));
const alternateLang = language === 'sk' ? 'en' : 'sk';
const imageUrl = typeof image === 'string' 
  ? (image.startsWith('http') ? image : toAbsoluteUrl(image)) 
  : (image?.src ? toAbsoluteUrl(image.src) : toAbsoluteUrl(DEFAULT_OG_IMAGE));

const extraSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

// Build breadcrumb schema if provided
const breadcrumbSchema = breadcrumbs.length > 0
  ? [{
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: toAbsoluteUrl(item.url),
      })),
    }]
  : [];

const jsonLd = JSON.stringify([
  ...getBaseSchemas(canonicalUrl, imageUrl, language, description),
  ...breadcrumbSchema,
  ...extraSchemas,
]);
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FF69B4" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="author" content={SITE_NAME} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="generator" content={Astro.generator} />
    <!-- Google Analytics 4 - Deferred -->
    <script is:inline>
      const isDev = window.location.hostname === 'localhost' || 
        window.location.hostname.includes('.local') || 
        (window.location.hostname.includes('vercel.app') && window.location.hostname.includes('-preview')) ||
        window.location.search.includes('test=true');
      
      window.trackEvent = function(category, action, label, value) {
        if (typeof gtag === 'function' && !isDev) {
          gtag('event', action, { event_category: category, event_label: label, value: value });
        }
        if (category === 'conversion' || action.includes('booking') || action.includes('form') || action === 'whatsapp_click') {
          fetch('/api/admin/analytics', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: action.includes('booking') ? 'booking' : action === 'whatsapp_click' ? 'whatsapp_click' : 'conversion', data: { source: label, conversionType: action } }) }).catch(() => {});
        }
      };

      function loadGA() {
        if (window.gaLoaded || isDev) return;
        window.gaLoaded = true;
        const s = document.createElement('script'); s.src = 'https://www.googletagmanager.com/gtag/js?id=G-90JKE6RJNC'; s.async = true; document.head.appendChild(s);
        window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date()); gtag('config', 'G-90JKE6RJNC', { 'send_page_view': false });
        gtag('event', 'page_view', { page_path: window.location.pathname, page_title: document.title });
      }

      // Auto-track clicks on tracked elements
      document.addEventListener('DOMContentLoaded', function() {
        document.body.addEventListener('click', function(e) {
          const target = e.target.closest('[data-ga-category]');
          if (target) {
            const category = target.dataset.gaCategory;
            const action = target.dataset.gaAction || 'click';
            const label = target.dataset.gaLabel || '';
            const value = target.dataset.gaValue;
            trackEvent(category, action, label, value);
          }
        });
      });

      // Defer GA on interaction
      ['scroll', 'click', 'touchstart'].forEach(e => document.addEventListener(e, loadGA, { once: true, passive: true }));
      setTimeout(loadGA, 5000);
    </script>
    <!-- Google Business Profile verification -->
    <meta name="google-site-verification" content="MERGE_FROM_GOOGLE" />
    <meta name="DC.title" content={title} />
    <meta name="DC.description" content={description} />
    <meta name="DC.publisher" content={SITE_NAME} />
    <meta name="DC.creator" content="Natália Ondrejková" />
    <meta name="DC.language" content="sk-SK" />
    <meta name="DC.type" content={type} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={language} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={toAbsoluteUrl('/')} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={language === 'sk' ? 'sk_SK' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Favicon & Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.ico" />
    <link rel="search" type="application/opensearchdescription+xml" href="/opensearch.xml" title="MagicRoom hľadanie" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://wa.me" />
    <link rel="dns-prefetch" href="https://maps.app.goo.gl" />

    <!-- Fonts with display=swap for better performance -->

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd}></script>

    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
