---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_OG_IMAGE,
  SITE_NAME,
  getBaseSchemas,
  toAbsoluteUrl,
} from '@/data/site';
import { getAlternateLanguageUrl, type Language } from '@/lib/i18n';

interface Props {
  title: string;
  description?: string;
  image?: any; // Changed from string to any to support ImageMetadata or string
  keywords?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  language?: Language;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_OG_IMAGE,
  keywords,
  type = 'website',
  noindex = false,
  structuredData = [],
  breadcrumbs = [],
  language = Astro.props.language || 'sk',
} = Astro.props;

const canonicalUrl = toAbsoluteUrl(Astro.url.pathname);
const alternateUrl = toAbsoluteUrl(getAlternateLanguageUrl(Astro.url, language));
const alternateLang = language === 'sk' ? 'en' : 'sk';

// Safe image URL derivation
let imageUrl = toAbsoluteUrl(DEFAULT_OG_IMAGE);
if (typeof image === 'string') {
  imageUrl = image.startsWith('http') ? image : toAbsoluteUrl(image);
} else if (image && typeof image === 'object' && 'src' in image) {
  imageUrl = toAbsoluteUrl(image.src);
}

const extraSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const breadcrumbSchema = breadcrumbs.length > 0
  ? [{
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: toAbsoluteUrl(item.url),
      })),
    }]
  : [];

const jsonLd = JSON.stringify([
  ...getBaseSchemas(canonicalUrl, imageUrl, language, description),
  ...breadcrumbSchema,
  ...extraSchemas,
]);
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FF69B4" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="author" content={SITE_NAME} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="DC.title" content={title} />
    <meta name="DC.description" content={description} />
    <meta name="DC.publisher" content={SITE_NAME} />
    <meta name="DC.language" content={language === 'en' ? 'en-US' : 'sk-SK'} />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <script is:inline>
      // Safe mock for trackEvent while GA is disabled (using Vercel Analytics instead)
      window.trackEvent = function() {};
    </script>
    {import.meta.env.GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.GOOGLE_SITE_VERIFICATION} />
    )}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={language} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={toAbsoluteUrl('/')} />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={language === 'sk' ? 'sk_SK' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.ico" />
    <link rel="search" type="application/opensearchdescription+xml" href="/opensearch.xml" title="MagicRoom hľadanie" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="dns-prefetch" href="https://wa.me" />

    <script type="application/ld+json" set:html={jsonLd}></script>

    <title>{title}</title>
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <slot />
  </body>
</html>

<script>
  declare global {
    interface Window {
      trackEvent: (category: string, action: string, label?: string, value?: number) => void;
      dataLayer: any[];
      gtag: (...args: any[]) => void;
    }
  }
</script>

<style is:global>
  @import '../styles/global.css';
</style>
