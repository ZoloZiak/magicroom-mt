---
interface Props {
  images: { src: string; width: number; height: number }[];
  name: string;
}

const { images, name } = Astro.props;
---

{images.length <= 1 ? (
  <img
    src={images[0]?.src}
    alt={name}
    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
  />
) : (
  <div class="relative h-full w-full" data-carousel={`dress-${name}`}>
    <img
      src={images[0].src}
      alt={`${name} 1/${images.length}`}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 carousel-image"
      data-current="0"
    />
    <button
      data-prev
      class="absolute left-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white/80 text-black shadow-md transition-opacity opacity-0 group-hover:opacity-100 hover:bg-white"
      aria-label="Previous image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button
      data-next
      class="absolute right-2 top-1/2 -translate-y-1/2 flex h-8 w-8 items-center justify-center rounded-full bg-white/80 text-black shadow-md transition-opacity opacity-0 group-hover:opacity-100 hover:bg-white"
      aria-label="Next image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1">
      {images.map((_, i) => (
        <span class={`h-1.5 w-1.5 rounded-full transition-colors ${i === 0 ? 'bg-white' : 'bg-white/50'}`} data-dot={i} />
      ))}
    </div>
  </div>
)}

<script define:vars={{ images: images.map(i => i.src), name }}>
  const container = document.querySelector(`[data-carousel="dress-${name}"]`);
  if (!container) return;
  
  const img = container.querySelector('.carousel-image');
  const prev = container.querySelector('[data-prev]');
  const next = container.querySelector('[data-next]');
  const dots = container.querySelectorAll('[data-dot]');
  let current = 0;
  
  function update() {
    img.src = images[current];
    img.alt = `${name} ${current + 1}/${images.length}`;
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === current);
      dot.classList.toggle('bg-white/50', i !== current);
    });
  }
  
  prev.addEventListener('click', (e) => {
    e.stopPropagation();
    current = current === 0 ? images.length - 1 : current - 1;
    update();
  });
  
  next.addEventListener('click', (e) => {
    e.stopPropagation();
    current = current === images.length - 1 ? 0 : current + 1;
    update();
  });
</script>
