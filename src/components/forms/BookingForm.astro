---
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Textarea } from '@/components/ui/textarea';
import { Star } from 'lucide-react';
import {
  EMAIL,
  EMAIL_HREF,
  PHONE_HREF,
  RESPONSE_PROMISE,
  WHATSAPP_BASE_URL,
  WHATSAPP_URL,
} from '@/data/site';
import { BOOKING_FEATURES } from '@/data/content';

interface Props {
  id?: string;
  title?: string;
  description?: string;
}

const {
  id = 'booking',
  title = 'Zarezervujte si skúšku šiat',
  description = 'Vyplňte krátky formulár a pripravíme vám správu do WhatsAppu, ktorú si pred odoslaním ešte môžete upraviť. Ak vám viac vyhovuje telefonát alebo email, nájdete ich nižšie.',
} = Astro.props;
---

<section id={id} class="rounded-[28px] border border-border/70 bg-white p-5 shadow-[var(--shadow-soft)] md:p-8">
  <div class="mb-7 flex flex-col gap-5 lg:mb-8 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-3">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-primary/70">Rezervácia skúšky</p>
      <h2 class="text-3xl font-display font-semibold text-foreground md:text-4xl">{title}</h2>
      <p class="max-w-2xl text-base leading-7 text-muted-foreground">{description}</p>
    </div>
  </div>

  <form class="space-y-6" data-booking-form novalidate>
    <div class="grid gap-5 md:grid-cols-2">
      <div class="space-y-2">
        <Label for={`${id}-name`}>Meno</Label>
        <Input className="form-input" id={`${id}-name`} name="name" autocomplete="name" placeholder="Vaše meno" />
      </div>

      <div class="space-y-2">
        <Label for={`${id}-phone`}>Telefón alebo WhatsApp</Label>
        <Input
          className="form-input"
          id={`${id}-phone`}
          name="phone"
          type="tel"
          autocomplete="tel"
          placeholder="+421 950 490 323"
        />
      </div>

      <div class="space-y-2">
        <Label for={`${id}-email`}>Email</Label>
        <Input
          className="form-input"
          id={`${id}-email`}
          name="email"
          type="email"
          autocomplete="email"
          placeholder="anna@email.sk (nepovinné)"
        />
      </div>

      <div class="space-y-2">
        <Label for={`${id}-service`}>Čo chcete riešiť?</Label>
        <select
          id={`${id}-service`}
          name="service"
          class="form-input flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
        >
          <option value="">Vyberte si...</option>
          <option value="Skúška svadobných alebo spoločenských šiat">Skúška svadobných alebo spoločenských šiat</option>
          <option value="Konzultácia k svadbe alebo harmonogramu">Konzultácia k svadbe alebo harmonogramu</option>
          <option value="Prenájom dekorácií a výzdoby">Prenájom dekorácií a výzdoby</option>
          <option value="Balík organizácie svadby">Balík organizácie svadby</option>
        </select>
      </div>

      <div class="space-y-2">
        <Label for={`${id}-date`}>Preferovaný dátum</Label>
        <Input className="form-input" id={`${id}-date`} name="date" type="date" min={new Date().toISOString().split('T')[0]} />
      </div>

      <div class="space-y-2">
        <Label for={`${id}-time`}>Preferovaný čas</Label>
        <Input className="form-input" id={`${id}-time`} name="time" placeholder="napr. piatok poobede" />
      </div>
    </div>

    <div class="space-y-2">
      <Label for={`${id}-note`}>Poznámka</Label>
      <Textarea
        className="form-input"
        id={`${id}-note`}
        name="note"
        rows={4}
        placeholder="Napíšte nám, aké šaty hľadáte, termín svadby alebo čo chcete pri rezervácii doriešiť ako prvé."
      />
    </div>

    <div class="rounded-2xl bg-primary-900 px-5 py-4 text-sm text-white/80">
      <p class="font-medium text-white">Skúška svadobných šiat: 12 € / 60 min • nápoj v cene • max. 2 blízke osoby.</p>
      <p class="mt-1">{RESPONSE_PROMISE} Po odoslaní dostanete možnosť pokračovať aj cez WhatsApp.</p>
    </div>

    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p class="text-sm leading-6 text-muted-foreground">
        Ak nechcete formulár dokončovať hneď, môžete sa ozvať aj priamo cez
        <a href={PHONE_HREF} class="font-semibold text-primary underline-offset-4 hover:underline"> telefón</a>,
        <a href={WHATSAPP_URL} class="font-semibold text-primary underline-offset-4 hover:underline" target="_blank" rel="noopener noreferrer"> WhatsApp</a>
        alebo
        <a href={EMAIL_HREF} class="font-semibold text-primary underline-offset-4 hover:underline"> email {EMAIL}</a>.
      </p>

      <Button type="submit" variant="cta" size="lg" className="w-full md:w-auto">
        Odoslať rezerváciu
      </Button>
    </div>

    <p class="hidden rounded-2xl border border-success/30 bg-success/10 px-4 py-3 text-sm text-foreground" data-booking-status aria-live="polite"></p>
    <div class="hidden" data-booking-whatsapp>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-2xl bg-[#25D366] px-5 py-3 text-sm font-medium text-white hover:bg-[#20BD5A]">
        Pokračovať cez WhatsApp
      </a>
    </div>
  </form>
</section>

<script>
  const forms = document.querySelectorAll('[data-booking-form]');

  forms.forEach((form) => {
    const status = form.querySelector('[data-booking-status]');
    const button = form.querySelector('button[type="submit"]');
    const whatsappSection = form.querySelector('[data-booking-whatsapp]');
    const whatsappLink = whatsappSection?.querySelector('a');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const entries = Object.fromEntries(formData.entries());

      if (button) {
        button.setAttribute('disabled', 'true');
        button.innerHTML = '<svg class="mr-2 h-4 w-4 animate-spin inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Odosielame…';
      }

      try {
        const response = await fetch('/api/booking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(entries),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          if (status) {
            status.classList.remove('hidden');
            status.classList.remove('border-destructive/30', 'bg-destructive/10');
            status.classList.add('border-success/30', 'bg-success/10');
            status.textContent = 'Rezervácia odoslaná! Ozveme sa vám do 24 hodín.';
          }

          const lines = [
            'Dobrý deň, chcela by som si rezervovať termín v MagicRoom.',
            '',
            `Meno: ${entries.name ?? ''}`,
            `Telefón: ${entries.phone ?? ''}`,
            `Email: ${entries.email ?? ''}`,
            `Záujem: ${entries.service ?? ''}`,
          ];
          if (entries.date) lines.push(`Preferovaný dátum: ${entries.date}`);
          if (entries.time) lines.push(`Preferovaný čas: ${entries.time}`);
          if (entries.note) lines.push(`Poznámka: ${entries.note}`);

          if (whatsappLink) {
            const url = new URL(WHATSAPP_BASE_URL);
            url.searchParams.set('text', lines.join('\n'));
            whatsappLink.href = url.toString();
            whatsappSection?.classList.remove('hidden');
          }

          form.querySelectorAll('input, select, textarea').forEach((el) => {
            if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
              el.value = '';
            }
          });
        } else {
          if (status) {
            status.classList.remove('hidden');
            status.classList.remove('border-success/30', 'bg-success/10');
            status.classList.add('border-destructive/30', 'bg-destructive/10');
            status.textContent = result.error || 'Niečo sa pokazilo. Skúste to znova.';
          }
        }
      } catch {
        if (status) {
          status.classList.remove('hidden');
          status.classList.remove('border-success/30', 'bg-success/10');
          status.classList.add('border-destructive/30', 'bg-destructive/10');
          status.textContent = 'Chyba pripojenia. Skúste to znova alebo nám zavolajte.';
        }
      }

      if (button) {
        button.removeAttribute('disabled');
        button.textContent = 'Odoslať rezerváciu';
      }
    });
  });
</script>