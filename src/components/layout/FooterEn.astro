---
import { Button } from '@/components/ui/button';
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import {
  ADDRESS_LABEL,
  BOOKING_PAGE_HREF_EN,
  COPYRIGHT_YEAR,
  EMAIL,
  EMAIL_HREF,
  MAP_URL,
  NAV_LINKS_EN,
  PHONE_DISPLAY,
  PHONE_HREF,
  SOCIAL_LINKS_EN,
} from '@/data/site';
import { Mail, MapPin, Phone } from 'lucide-react';

const currentPath = Astro.url.pathname;
const bookingHref = currentPath === '/en' ? '#booking' : BOOKING_PAGE_HREF_EN;
---

<footer class="mt-auto bg-primary-900 py-12 text-white">
  <div class="container mx-auto px-4">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4 lg:gap-12">
      <div class="lg:col-span-2">
        <h3 class="mb-4 font-display text-2xl">MagicRoom</h3>
        <p class="mb-6 max-w-md text-white/70">
          Boutique wedding salon in Martin for brides who want dresses, decorations and calm consulting without chaos.
        </p>

        <div class="mb-6 flex flex-wrap gap-3">
          <Button asChild variant="secondary" size="sm">
            <a href={bookingHref} data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label="footer_cta_en">Book a fitting</a>
          </Button>
          <Button asChild variant="outline" size="sm" className="border-white/30 text-white hover:bg-white/10 hover:text-white">
            <a href={PHONE_HREF} data-ga-category="contact" data-ga-action="phone_click" data-ga-label="footer_phone_en">Call</a>
          </Button>
        </div>

        <div class="flex flex-wrap gap-4">
          {SOCIAL_LINKS_EN.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              data-ga-category="external"
              data-ga-action="social_click"
              data-ga-label={`footer_${item.label.toLowerCase().replace(/[^a-z]/g, '_')}_en`}
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80 transition-colors hover:border-white/20 hover:text-accent"
              aria-label={item.label}
            >
              {item.label === 'Facebook' ? (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                </svg>
              ) : (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.378.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
              )}
              <span>{item.label}</span>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 class="mb-4 font-semibold">Contact</h4>
        <div class="flex flex-col gap-3">
          <a
            href={EMAIL_HREF}
            data-ga-category="contact"
            data-ga-action="email_click"
            data-ga-label="footer_email_en"
            class="flex flex-col items-center gap-2 rounded-2xl border border-white/20 bg-white/5 px-5 py-4 text-center transition-colors hover:border-white/40 hover:bg-white/10"
          >
            <Mail className="h-6 w-6" />
            <span class="text-sm">{EMAIL}</span>
          </a>
          <a
            href={PHONE_HREF}
            data-ga-category="contact"
            data-ga-action="phone_click"
            data-ga-label="footer_phone_card_en"
            class="flex flex-col items-center gap-2 rounded-2xl border border-white/20 bg-white/5 px-5 py-4 text-center transition-colors hover:border-white/40 hover:bg-white/10"
          >
            <Phone className="h-6 w-6" weight="regular" />
            <span class="text-sm">{PHONE_DISPLAY}</span>
          </a>
        </div>
        <a
          href={MAP_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-category="external"
          data-ga-action="map_click"
          data-ga-label="footer_map_en"
          class="mt-4 flex items-center gap-2 text-sm text-white/70 transition-colors hover:text-white"
        >
          <MapPin className="h-4 w-4 shrink-0" weight="regular" />
          <span>{ADDRESS_LABEL}</span>
        </a>
      </div>

      <div>
        <h4 class="mb-4 font-semibold">Navigation</h4>
        <ul class="space-y-2 text-white/70">
          {NAV_LINKS_EN.map((link) => (
            <li><a href={link.href} class="transition-colors hover:text-white">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="my-8 h-px bg-white/15"></div>

    <div class="flex flex-col items-center justify-between gap-4 text-sm text-white/50 md:flex-row">
      <p>© {COPYRIGHT_YEAR} MagicRoom. All rights reserved.</p>
      <a href={MAP_URL} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
        How to get here
      </a>
    </div>
  </div>
</footer>