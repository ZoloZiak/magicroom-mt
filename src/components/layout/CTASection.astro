---
import Button from '@/components/ui/Button.astro';
import { BOOKING_PAGE_HREF, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  kicker?: string;
  heading: string;
  description: string;
  ctaLabel?: string;
  card?: boolean;
}

const {
  kicker = 'Ďalší krok',
  heading,
  description,
  ctaLabel = 'Rezervovať termín',
  card = false,
} = Astro.props;
---

<section class="bg-primary-900 py-16 text-white md:py-20">
  <div class="container mx-auto px-4">
    {card ? (
      <div class="mx-auto max-w-4xl rounded-[34px] border border-white/10 bg-white/6 px-6 py-10 text-center shadow-[var(--shadow-dark)] md:px-10 md:py-14">
        <p class="text-[11px] uppercase tracking-[0.28em] text-white/70">{kicker}</p>
        <h2 class="mt-4 font-display text-4xl leading-tight md:text-5xl">{heading}</h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-white/75">{description}</p>
        <div class="mt-8 flex flex-col justify-center items-center gap-4 sm:flex-row">
          <Button 
            variant="outline" 
            size="lg" 
            href={PHONE_HREF}
            className="border-white/30 text-white hover:bg-white/10 hover:text-white"
          >
            <Icon name="Phone" class="h-4 w-4" />
            {PHONE_DISPLAY}
          </Button>
          <Button 
            variant="secondary" 
            size="lg"
            href={BOOKING_PAGE_HREF}
          >
            {ctaLabel}
            <Icon name="ArrowRight" class="h-4 w-4" />
          </Button>
        </div>
      </div>
    ) : (
      <div class="text-center">
        <p class="text-sm uppercase tracking-[0.24em] text-white/70">{kicker}</p>
        <h2 class="mt-3 font-display text-4xl md:text-5xl">{heading}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/75">{description}</p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center items-center">
          <Button 
            variant="outline" 
            size="lg" 
            href={PHONE_HREF}
            className="border-white text-white hover:bg-white/10"
          >
            <Icon name="Phone" class="h-5 w-5" />
            {PHONE_DISPLAY}
          </Button>
          <Button 
            size="lg" 
            href={BOOKING_PAGE_HREF}
            className="bg-white text-primary-900 hover:bg-white/90"
          >
            {ctaLabel}
            <Icon name="ArrowRight" class="h-5 w-5" />
          </Button>
        </div>
      </div>
    )}
  </div>
</section>
