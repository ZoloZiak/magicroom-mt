---
import { Button } from '@/components/ui/button';
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import { BOOKING_PAGE_HREF_EN, NAV_LINKS_EN, PHONE_DISPLAY, PHONE_HREF, RESPONSE_PROMISE_EN } from '@/data/site';

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en');
const bookingHref = currentPath === '/en' ? '#booking' : BOOKING_PAGE_HREF_EN;
---

<header class="sticky top-0 z-50 w-full border-b border-border/70 bg-background/80 shadow-[var(--shadow-sm)] backdrop-blur-xl">
  <div class="hidden border-b border-border/50 bg-white/60 md:block">
    <div class="container mx-auto flex h-10 items-center justify-between px-4 text-[11px] font-medium uppercase tracking-[0.24em] text-muted-foreground">
      <p>Wedding dress fitting 12 € / 60 min</p>
      <div class="flex items-center gap-6">
        <p>Martin • by appointment</p>
        <a href={PHONE_HREF} class="hover:text-foreground" data-ga-category="contact" data-ga-action="phone_click" data-ga-label="header_phone_en">{PHONE_DISPLAY}</a>
        <p>{RESPONSE_PROMISE_EN}</p>
      </div>
    </div>
  </div>

  <nav class="container mx-auto flex h-[4.5rem] items-center justify-between px-4">
    <a href="/" class="group flex items-center gap-3" aria-label="MagicRoom home">
      <img
        src="/images/logo.jpeg"
        alt="MagicRoom logo"
        class="h-11 w-11 rounded-full object-cover shadow-[var(--shadow-xl)]"
        width="44"
        height="44"
      />
      <div class="hidden sm:block">
        <span class="block font-display text-[1.45rem] leading-none transition-colors group-hover:text-primary">MagicRoom</span>
        <span class="mt-1 block text-[10px] uppercase tracking-[0.34em] text-muted-foreground">bridal concierge • Martin</span>
      </div>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {NAV_LINKS_EN.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium tracking-[0.08em] after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:bg-cta after:transition-transform after:duration-300',
              currentPath === link.href
                ? 'text-foreground after:scale-x-100'
                : 'text-foreground/70 after:scale-x-0 hover:text-foreground hover:after:scale-x-100',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-4 md:flex">
      <LanguageSwitcher currentLanguage="en" />
      <Button asChild variant="cta" size="sm">
        <a href={bookingHref} data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label="header_cta_en">Book a fitting</a>
      </Button>
    </div>

    <div class="md:hidden">
      <button
        id="mobile-menu-toggle"
        style="cursor:pointer;border-radius:8px;padding:8px;background:none;border:none;"
        aria-label="Open navigation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </nav>
</header>

<div id="mobile-menu-root" data-phone-href={PHONE_HREF} data-phone-display={PHONE_DISPLAY} data-response={RESPONSE_PROMISE_EN} data-booking-href={bookingHref} data-nav={JSON.stringify(NAV_LINKS_EN)}></div>

<script>
  const root = document.getElementById('mobile-menu-root');
  const PHONE_HREF = root?.dataset.phoneHref || 'tel:+421950490323';
  const PHONE_DISPLAY = root?.dataset.phoneDisplay || '+421 950 490 323';
  const RESPONSE_PROMISE = root?.dataset.response || '';
  const bookingHref = root?.dataset.bookingHref || '/en/kontakt#booking';
  const NAV_LINKS = JSON.parse(root?.dataset.nav || '[]');
  const currentPath = window.location.pathname;

  const toggleBtn = document.getElementById('mobile-menu-toggle');
  let menuEl = null;

  function createMenu() {
    const el = document.createElement('div');
    el.id = 'mobile-drawer';
    el.setAttribute('role', 'dialog');
    el.setAttribute('aria-modal', 'true');
    el.innerHTML = `
      <div id="mobile-backdrop" style="position:fixed;inset:0;z-index:var(--z-overlay);background:rgba(0,0,0,0.5);display:none;"></div>
      <div id="mobile-panel" style="position:fixed;top:0;right:0;z-index:var(--z-modal);height:100vh;width:300px;background:var(--color-background);box-shadow:-4px 0 30px rgba(0,0,0,0.15);transform:translateX(100%);transition:transform 0.3s ease;overflow-y:auto;">
        <div style="padding:20px;border-bottom:1px solid #E8D0D8;display:flex;align-items:center;justify-content:space-between;">
          <div style="display:flex;align-items:center;gap:12px;">
            <img src="/images/logo.jpeg" alt="MagicRoom" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />
            <div>
              <span style="display:block;font-family:Satoshi,system-ui;font-size:1.5rem;font-weight:600;">MagicRoom</span>
              <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.28em;color:var(--color-muted-foreground);">bridal concierge &bull; Martin</span>
            </div>
          </div>
          <button id="mobile-close-btn" style="cursor:pointer;padding:8px;background:none;border:none;border-radius:8px;" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;" fill="none" viewBox="0 0 24 24" stroke="#2D2421" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <div style="padding:12px 20px;">
          <div style="border-radius:16px;border:1px solid #E8D0D8;background:var(--color-card);padding:12px 16px;font-size:14px;color:var(--color-muted-foreground);">
            <p style="font-weight:500;color:#2D2421;margin:0;">${RESPONSE_PROMISE}</p>
            <a href="${PHONE_HREF}" data-ga-category="contact" data-ga-action="phone_click" data-ga-label="mobile_menu_phone_en" style="display:block;margin-top:4px;color:#B87A8E;text-decoration:none;">${PHONE_DISPLAY}</a>
          </div>
        </div>
        <div style="padding:12px 20px 0;">
          <p style="font-size:11px;text-transform:uppercase;letter-spacing:0.28em;color:var(--color-primary);margin:0;">Navigation</p>
        </div>
        <ul style="list-style:none;margin:0;padding:0 20px;">
          ${NAV_LINKS.map(link => `
            <li style="border-bottom:1px solid rgba(232,208,216,0.5);padding:12px 0;">
              <a href="${link.href}" style="display:block;padding:8px 0;font-size:18px;font-weight:500;color:${currentPath === link.href ? '#B85C4A' : '#2D2421'};text-decoration:none;"
                 onmouseover="this.style.color='#B85C4A'" onmouseout="this.style.color='${currentPath === link.href ? '#B85C4A' : '#2D2421'}'">
                ${link.label}
              </a>
            </li>
          `).join('')}
        </ul>
        <div style="padding:20px;border-top:1px solid #E8D0D8;">
          <a href="${bookingHref}" data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label="mobile_menu_cta_en" style="display:block;text-align:center;padding:12px 24px;background:#B85C4A;color:#fff;border-radius:12px;font-weight:500;text-decoration:none;font-size:15px;">
            Book a fitting
          </a>
          <a href="${PHONE_HREF}" data-ga-category="contact" data-ga-action="phone_click" data-ga-label="mobile_menu_call_en" style="display:block;margin-top:16px;text-align:center;font-size:14px;font-weight:500;color:var(--color-muted-foreground);text-decoration:none;">
            Or call directly
          </a>
        </div>
      </div>
    `;
    document.body.appendChild(el);
    menuEl = el;

    document.getElementById('mobile-backdrop')?.addEventListener('click', closeMenu);
    document.getElementById('mobile-close-btn')?.addEventListener('click', closeMenu);
    el.querySelectorAll('a[href]').forEach(a => {
      a.addEventListener('click', closeMenu);
    });
  }

  function openMenu() {
    if (!menuEl) createMenu();
    const backdrop = document.getElementById('mobile-backdrop');
    const panel = document.getElementById('mobile-panel');
    if (backdrop) backdrop.style.display = 'block';
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      if (panel) panel.style.transform = 'translateX(0)';
    });
  }

  function closeMenu() {
    const backdrop = document.getElementById('mobile-backdrop');
    const panel = document.getElementById('mobile-panel');
    if (panel) panel.style.transform = 'translateX(100%)';
    document.body.style.overflow = '';
    setTimeout(() => {
      if (backdrop) backdrop.style.display = 'none';
    }, 300);
  }

  toggleBtn?.addEventListener('click', openMenu);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>