---
import { Button } from '@/components/ui/button';
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import { getNavLinks, getBookingPageHref, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { getTranslations, type Language } from '@/lib/translations';

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);

const currentPath = Astro.url.pathname;
const isEn = language === 'en';

const navLinks = getNavLinks(language);
const bookingPageHref = getBookingPageHref(language);
const bookingHref = currentPath === (isEn ? '/en' : '/') ? '#booking' : bookingPageHref;
const gaLabelSuffix = isEn ? '_en' : '';
---

<header class="sticky top-0 z-50 w-full border-b border-border/70 bg-background/80 shadow-[var(--shadow-sm)] backdrop-blur-xl">
  <div class="hidden border-b border-border/50 bg-white/60 md:block">
    <div class="container mx-auto flex h-10 items-center justify-between px-4 text-[11px] font-medium uppercase tracking-[0.24em] text-muted-foreground">
      <p>{t.common.fittingNote} {t.common.fittingPrice}</p>
      <div class="flex items-center gap-6">
        <p>{t.common.visitNote}</p>
        <a href={PHONE_HREF} class="hover:text-foreground" data-ga-category="contact" data-ga-action="phone_click" data-ga-label={`header_phone${gaLabelSuffix}`}>{PHONE_DISPLAY}</a>
        <p>{t.common.replyNote}</p>
      </div>
    </div>
  </div>

  <nav class="container mx-auto flex h-[4.5rem] items-center justify-between px-4">
    <a href={isEn ? '/en' : '/'} class="group flex items-center gap-3" aria-label={`MagicRoom ${isEn ? 'home' : 'domov'}`}>
      <div class="h-11 w-11 overflow-hidden rounded-full shadow-[var(--shadow-xl)]">
        <img
          src="/images/logo.jpeg"
          alt="Logo MagicRoom - Svadobný salón Martin"
          class="h-full w-full object-cover"
          width="44"
          height="44"
        />
      </div>
      <div class="hidden sm:block">
        <span class="block font-display text-[1.45rem] leading-none transition-colors group-hover:text-primary">MagicRoom</span>
        <span class="mt-1 block text-[10px] uppercase tracking-[0.34em] text-muted-foreground">{t.common.logoSubtext}</span>
      </div>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium tracking-[0.08em] after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:bg-cta after:transition-transform after:duration-300',
              currentPath === link.href
                ? 'text-foreground after:scale-x-100'
                : 'text-foreground/70 after:scale-x-0 hover:text-foreground hover:after:scale-x-100',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-4 md:flex">
      <LanguageSwitcher currentLanguage={language} />
      <Button asChild variant="cta" size="sm">
        <a href={bookingHref} data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label={`header_cta${gaLabelSuffix}`}>{t.nav.bookAppointment}</a>
      </Button>
    </div>

    <button id="mobile-menu-toggle" type="button" class="md:hidden p-2 rounded-lg hover:bg-muted" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>
</header>

<div id="mobile-menu" style="display: none; position: fixed; inset: 0; z-index: 9999;">
  <div id="mobile-menu-backdrop" style="position: absolute; inset: 0; background-color: rgba(0,0,0,0.5);"></div>
  <div id="mobile-menu-panel" style="position: absolute; top: 0; right: 0; height: 100%; width: 300px; max-width: 85vw; background-color: white; box-shadow: 0 10px 40px rgba(0,0,0,0.2); transform: translateX(100%); transition: transform 0.3s ease-out; overflow-y: auto;">
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 20px; border-bottom: 1px solid #e5e7eb;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <img src="/images/logo.jpeg" alt="MagicRoom" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
        <div>
          <span style="display: block; font-size: 1.25rem; font-weight: 600;">MagicRoom</span>
          <span style="display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.28em; color: #71717a;">bridal concierge &bull; Martin</span>
        </div>
      </div>
      <button id="mobile-menu-close" type="button" style="padding: 8px; border-radius: 8px; border: none; background: transparent; cursor: pointer;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width: 24px; height: 24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div style="padding: 16px 20px;">
      <div style="border: 1px solid #e5e7eb; border-radius: 16px; padding: 16px; font-size: 14px; color: #71717a;">
        <p style="font-weight: 500; color: #18181b;">{t.common.replyNote}</p>
        <a href={PHONE_HREF} style="display: block; margin-top: 4px; font-weight: 600; color: #ec4899; text-decoration: underline;">{PHONE_DISPLAY}</a>
      </div>
    </div>
    <div style="padding: 0 20px;">
      <p style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.28em; color: rgba(236,72,153,0.7);">{t.header.mobileNavigation}</p>
    </div>
    <ul style="padding: 8px 20px;">
      {navLinks.map((link, index) => (
        <li style={`border-bottom: ${link.href === navLinks[navLinks.length - 1].href ? 'none' : '1px solid #e5e7eb'}; padding: 12px 0;`}>
          <a
            href={link.href}
            style={`display: block; padding: 8px 0; font-size: 1.125rem; font-weight: 500; transition: color 0.2s; ${currentPath === link.href ? 'color: #ec4899;' : 'color: #18181a;'}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div style="border-top: 1px solid #e5e7eb; padding: 20px; margin-top: 16px;">
      <a href={bookingHref} style="display: block; border-radius: 12px; background-color: #ec4899; padding: 12px 24px; text-align: center; font-size: 15px; font-weight: 500; color: white; box-shadow: 0 4px 6px rgba(236,72,153,0.3);">
        {t.nav.bookAppointment}
      </a>
      <a href={PHONE_HREF} style="display: block; margin-top: 16px; text-align: center; font-size: 14px; font-weight: 500; color: #71717a; transition: color 0.2s;">
        {t.header.mobileCallDirectly}
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var menu = document.getElementById('mobile-menu');
    var toggle = document.getElementById('mobile-menu-toggle');
    var closeBtn = document.getElementById('mobile-menu-close');
    var backdrop = document.getElementById('mobile-menu-backdrop');
    var panel = document.getElementById('mobile-menu-panel');
    var isOpen = false;

    function openMenu() {
      if (!menu || !panel) return;
      menu.style.display = 'block';
      panel.style.transform = 'translateX(0)';
      isOpen = true;
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      if (!menu || !panel) return;
      panel.style.transform = 'translateX(100%)';
      isOpen = false;
      document.body.style.overflow = '';
      setTimeout(function() {
        if (!isOpen) menu.style.display = 'none';
      }, 300);
    }

    if (toggle) toggle.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    if (backdrop) backdrop.addEventListener('click', closeMenu);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });

    if (panel) {
      var links = panel.querySelectorAll('a');
      for (var i = 0; i < links.length; i++) {
        links[i].addEventListener('click', closeMenu);
      }
    }
  })();
</script>