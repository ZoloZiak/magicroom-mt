---
import { Button } from '@/components/ui/button';
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import { getNavLinks, getBookingPageHref, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { getTranslations, type Language } from '@/lib/translations';

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);

const currentPath = Astro.url.pathname;
const isEn = language === 'en';

const navLinks = getNavLinks(language);
const bookingPageHref = getBookingPageHref(language);
const bookingHref = currentPath === (isEn ? '/en' : '/') ? '#booking' : bookingPageHref;
const gaLabelSuffix = isEn ? '_en' : '';
---

<header class="sticky top-0 z-50 w-full border-b border-border/70 bg-background/80 shadow-[var(--shadow-sm)] backdrop-blur-xl">
  <div class="hidden border-b border-border/50 bg-white/60 md:block">
    <div class="container mx-auto flex h-10 items-center justify-between px-4 text-[11px] font-medium uppercase tracking-[0.24em] text-muted-foreground">
      <p>{t.common.fittingNote} {t.common.fittingPrice}</p>
      <div class="flex items-center gap-6">
        <p>{t.common.visitNote}</p>
        <a href={PHONE_HREF} class="hover:text-foreground" data-ga-category="contact" data-ga-action="phone_click" data-ga-label={`header_phone${gaLabelSuffix}`}>{PHONE_DISPLAY}</a>
        <p>{t.common.replyNote}</p>
      </div>
    </div>
  </div>

  <nav class="container mx-auto flex h-[4.5rem] items-center justify-between px-4">
    <a href={isEn ? '/en' : '/'} class="group flex items-center gap-3" aria-label={`MagicRoom ${isEn ? 'home' : 'domov'}`}>
      <div class="h-11 w-11 overflow-hidden rounded-full shadow-[var(--shadow-xl)]">
        <img
          src="/images/logo.jpeg"
          alt="Logo MagicRoom - Svadobný salón Martin"
          class="h-full w-full object-cover"
          width="44"
          height="44"
        />
      </div>
      <div class="hidden sm:block">
        <span class="block font-display text-[1.45rem] leading-none transition-colors group-hover:text-primary">MagicRoom</span>
        <span class="mt-1 block text-[10px] uppercase tracking-[0.34em] text-muted-foreground">{t.common.logoSubtext}</span>
      </div>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium tracking-[0.08em] after:absolute after:-bottom-2 after:left-0 after:h-px after:w-full after:origin-left after:bg-cta after:transition-transform after:duration-300',
              currentPath === link.href
                ? 'text-foreground after:scale-x-100'
                : 'text-foreground/70 after:scale-x-0 hover:text-foreground hover:after:scale-x-100',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-4 md:flex">
      <LanguageSwitcher currentLanguage={language} />
      <Button asChild variant="cta" size="sm">
        <a href={bookingHref} data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label={`header_cta${gaLabelSuffix}`}>{t.nav.bookAppointment}</a>
      </Button>
    </div>

    <button id="mobile-menu-toggle" type="button" class="md:hidden p-2 rounded-lg hover:bg-muted" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>
</header>

<div id="mobile-menu" class="fixed inset-0 z-50 hidden">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
  <div id="mobile-menu-panel" class="absolute top-0 right-0 h-full w-[300px] max-w-[85vw] bg-background shadow-2xl translate-x-full transition-transform duration-300 ease-out">
    <div class="flex items-center justify-between border-b border-border p-5">
      <div class="flex items-center gap-3">
        <img src="/images/logo.jpeg" alt="MagicRoom" class="h-10 w-10 rounded-full object-cover" />
        <div>
          <span class="block font-display text-xl font-semibold">MagicRoom</span>
          <span class="block text-[10px] uppercase tracking-[0.28em] text-muted-foreground">bridal concierge &bull; Martin</span>
        </div>
      </div>
      <button id="mobile-menu-close" type="button" class="rounded-lg p-2 hover:bg-muted" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div class="p-5 pt-3">
      <div class="rounded-2xl border border-border bg-card p-4 text-sm text-muted-foreground">
        <p class="font-medium text-foreground">{t.common.replyNote}</p>
        <a href={PHONE_HREF} class="mt-1 block font-semibold text-primary hover:underline">{PHONE_DISPLAY}</a>
      </div>
    </div>
    <div class="px-5">
      <p class="text-[11px] uppercase tracking-[0.28em] text-primary/70">{t.header.mobileNavigation}</p>
    </div>
    <ul class="px-5 mt-2">
      {navLinks.map((link) => (
        <li class:list={['border-b border-border/50 py-3', { 'border-0': link.href === navLinks[navLinks.length - 1].href }]}>
          <a
            href={link.href}
            class:list={['block py-2 text-lg font-medium transition-colors', currentPath === link.href ? 'text-primary' : 'text-foreground hover:text-primary']}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="border-t border-border p-5 mt-4">
      <a href={bookingHref} class="block rounded-xl bg-cta px-6 py-3 text-center text-[15px] font-medium text-white shadow-md hover:bg-cta/90 transition-colors">
        {t.nav.bookAppointment}
      </a>
      <a href={PHONE_HREF} class="mt-4 block text-center text-sm font-medium text-muted-foreground hover:text-primary transition-colors">
        {t.header.mobileCallDirectly}
      </a>
    </div>
  </div>
</div>

<style>
  #mobile-menu.open {
    display: block;
  }
  #mobile-menu.open #mobile-menu-backdrop {
    opacity: 1;
  }
  #mobile-menu.open #mobile-menu-panel {
    transform: translateX(0);
  }
</style>

<script>
  const menu = document.getElementById('mobile-menu');
  const toggle = document.getElementById('mobile-menu-toggle');
  const closeBtn = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const panel = document.getElementById('mobile-menu-panel');

  function openMenu() {
    menu?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('open');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      closeMenu();
    }
  });

  panel?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>