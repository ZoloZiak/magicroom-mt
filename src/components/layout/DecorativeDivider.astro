---
interface Props {
  variant?: 'floral' | 'dots' | 'line';
}

const { variant = 'floral' } = Astro.props;
---

{variant === 'floral' && (
  <div class="flex items-center justify-center gap-4 py-8">
    <svg class="h-px w-16 text-primary/30" viewBox="0 0 64 1" preserveAspectRatio="none"><line x1="0" y1="0.5" x2="64" y2="0.5" stroke="currentColor" stroke-width="1"/></svg>
    <svg class="h-6 w-6 text-primary/40" viewBox="0 0 24 24" fill="none">
      <path d="M12 3C12 3 9 6 9 9C9 10.5 10 12 12 12C14 12 15 10.5 15 9C15 6 12 3 12 3Z" fill="currentColor" opacity="0.3"/>
      <path d="M12 12C12 12 8 14 7 17C6.5 18.5 7.5 20 9 20C10.5 20 12 18 12 18" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
      <path d="M12 12C12 12 16 14 17 17C17.5 18.5 16.5 20 15 20C13.5 20 12 18 12 18" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor" opacity="0.5"/>
    </svg>
    <svg class="h-px w-16 text-primary/30" viewBox="0 0 64 1" preserveAspectRatio="none"><line x1="0" y1="0.5" x2="64" y2="0.5" stroke="currentColor" stroke-width="1"/></svg>
  </div>
)}

{variant === 'dots' && (
  <div class="flex items-center justify-center gap-2 py-6">
    <span class="h-1.5 w-1.5 rounded-full bg-primary/30"></span>
    <span class="h-1.5 w-1.5 rounded-full bg-primary/50"></span>
    <span class="h-1.5 w-1.5 rounded-full bg-primary/30"></span>
  </div>
)}

{variant === 'line' && (
  <div class="flex items-center justify-center py-6">
    <svg class="h-px w-24 text-primary/20" viewBox="0 0 96 1" preserveAspectRatio="none"><line x1="0" y1="0.5" x2="96" y2="0.5" stroke="currentColor" stroke-width="1"/></svg>
  </div>
)}
