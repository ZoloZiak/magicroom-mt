---
import { Image } from 'astro:assets';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro'
import CardContent from '@/components/ui/CardContent.astro'
import CardDescription from '@/components/ui/CardDescription.astro'
import CardHeader from '@/components/ui/CardHeader.astro'
import CardTitle from '@/components/ui/CardTitle.astro';
import { getBookingPageHref, PHONE_DISPLAY, PHONE_HREF, WHATSAPP_URL } from '@/data/site';
import { getExtraServices, getServicePackages, IMAGE_URLS, DRESS_CATALOG } from '@/data/content';
import { getTranslations, getRelativeHref, type Language } from '@/lib/translations';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  language: Language;
  skSlug: string;
}

const { language, skSlug } = Astro.props;
const t = getTranslations(language);
const isEn = language === 'en';

const SERVICE_PACKAGES = getServicePackages(language);
const EXTRA_SERVICES = getExtraServices(language);

const servicePillars = [
  {
    title: isEn ? 'Formal Dress Fitting' : 'Skúška svadobných šiat',
    price: '15 € / 60 min',
    description: isEn ? 'Calm fitting with drink, up to 2 close people.' : 'Pokojná skúška s nápojom v cene, priestorom pre dve blízke osoby a časom porovnať si viac modelov bez stresu.',
    cta: isEn ? 'Book a fitting' : 'Rezervovať skúšku',
    href: getBookingPageHref(language),
    icon: 'Shirt',
  },
  {
    title: isEn ? 'Prom & Gala Dresses' : 'Predaj a výber šiat',
    price: isEn ? 'from 15 €' : 'od 100 €',
    description: isEn ? 'High quality dresses at student prices.' : 'Nové modely, dostupné kúsky aj komisný výber pre ženy, ktoré chcú dobrý pocit aj z rozpočtu.',
    cta: isEn ? 'Ask' : 'Napísať o výber',
    href: getBookingPageHref(language),
    icon: 'Star',
  },
  {
    title: isEn ? 'Event Decorations' : 'Prenájom dekorácií',
    price: isEn ? 'from 0.50 €' : 'od 0,50 € / ks',
    description: isEn ? 'Mirrors, vases, candlesticks.' : 'Zrkadlá, vázy, svietniky, kulisy aj candy bar doplnky tak, aby ste vedeli zladiť hostinu bez chaosu.',
    cta: isEn ? 'View' : 'Pozrieť dekorácie',
    href: getRelativeHref('prenajom-dekoracii', language),
    icon: 'LayoutGrid',
  },
  {
    title: isEn ? 'Styling Advice' : 'Svadobné poradenstvo',
    price: isEn ? 'from 40 €' : 'od 40 €',
    description: isEn ? 'Consultations, moodboards.' : 'Konzultácie, moodboard, harmonogram aj odporúčania dodávateľov podľa toho, koľko pomoci naozaj potrebujete.',
    cta: isEn ? 'View' : 'Pozrieť balíky',
    href: '#baliky',
    icon: 'ClipboardList',
  },
];

const servicesSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: SERVICE_PACKAGES.map((pkg, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        name: pkg.name,
        description: pkg.description,
        offers: {
          '@type': 'Offer',
          price: pkg.price.replace(/[^0-9]/g, ''),
          priceCurrency: 'EUR',
        },
      },
    })),
  },
];

const servicesOgImage = DRESS_CATALOG[0]?.imageAsset ? String(DRESS_CATALOG[0].imageAsset) : IMAGE_URLS.hero;
---

<Layout
  title={t.services.pageTitle}
  description={t.services.pageDescription}
  image={servicesOgImage}
  structuredData={servicesSchema}
  breadcrumbs={[
    { name: t.nav.home, url: isEn ? '/en' : '/' },
    { name: t.nav.services, url: getRelativeHref(skSlug, language) },
  ]}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" class="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              {t.services.heroBadge}
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl animate-fade-in-up animate-stagger-2">
              {t.services.heroTitle}
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground animate-fade-in-up animate-stagger-3">
              {t.services.heroDescription}
            </p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row items-center animate-fade-in-up animate-stagger-4">
              <Button variant="cta" size="lg" class="sm:min-w-[220px]" href={getBookingPageHref(language)}>
                {t.nav.bookAppointment}
                <Icon name="ArrowRight" class="h-5 w-5 ml-2" />
              </Button>
              <Button variant="outline" size="lg" class="sm:min-w-[220px]" href={isEn ? WHATSAPP_URL : PHONE_HREF}>
                {isEn ? 'WhatsApp' : `${t.common.callNow} ${PHONE_DISPLAY}`}
              </Button>
            </div>
          </div>
          <div class="photo-card animate-fade-in-right">
            <Image 
              src={DRESS_CATALOG[0].imageAsset} 
              alt="Služby MagicRoom" 
              class="max-h-[520px] w-full rounded-[24px] object-cover shadow-2xl"
              width={800}
              height={1000}
            />
          </div>
        </div>
      </div>
    </section>

    <div class="border-t border-border/40"></div>

    <section class="py-16 md:py-24 bg-background">
      <div class="container mx-auto px-4">
        <div class="mb-12">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.servicesSubtitle.split('—')[0]}</p>
          <h2 class="mt-3 font-display text-4xl">{t.home.servicesTitle}</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {servicePillars.map((item, index) => (
            <Card class={`border-0 bg-surface shadow-[var(--shadow-soft)] hover:shadow-xl transition-shadow animate-fade-in-up animate-stagger-${index+1}`}>
              <CardHeader>
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-card shadow-sm text-primary">
                  <Icon name={item.icon as any} class="h-6 w-6" />
                </div>
                {item.title && (
                  <CardTitle class="font-display text-2xl">
                    {item.title}
                  </CardTitle>
                )}
                <p class="pt-2 text-sm font-semibold uppercase text-cta">{item.price}</p>
                <CardDescription class="pt-2">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button variant="ghost" class="px-0 text-primary group" href={item.href}>
                  {item.cta}
                  <Icon name="ArrowRight" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-1" />
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section id="baliky" class="bg-surface py-20 md:py-28">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.contact.fittingNote}</p>
          <h2 class="mt-3 font-display text-4xl md:text-5xl">{t.home.bookingTitle}</h2>
        </div>
        <div class="grid gap-8 lg:grid-cols-3">
          {SERVICE_PACKAGES.map((pkg, index) => (
            <Card class={`bg-card shadow-lg border-0 flex flex-col ${pkg.recommended ? 'ring-2 ring-cta relative' : ''} animate-fade-in-up animate-stagger-${index+1}`}>
              {pkg.recommended && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-cta px-4 py-1 text-[11px] font-bold uppercase tracking-widest text-white">
                  {isEn ? 'Most popular' : 'Najobľúbenejší'}
                </div>
              )}
              <CardHeader class="text-center">
                <CardTitle class="font-display text-3xl">{pkg.name}</CardTitle>
                <p class="text-2xl font-semibold text-cta mt-2">{pkg.price}</p>
                <CardDescription class="mt-2">{pkg.description}</CardDescription>
              </CardHeader>
              <CardContent class="flex-1">
                <ul class="space-y-4 mb-8">
                  {pkg.features.map((f) => (
                    <li class="flex items-start gap-3 text-sm">
                      <div class="mt-1 shrink-0 rounded-full bg-success/10 p-1 text-success">
                        <Icon name="CheckCircle2" class="h-3 w-3" />
                      </div>
                      <span class="text-muted-foreground">{f}</span>
                    </li>
                  ))}
                </ul>
                <Button 
                  class="mt-auto w-full" 
                  variant={pkg.recommended ? 'cta' : 'outline'}
                  href={getBookingPageHref(language)}
                >
                  {t.common.learnMore}
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-background py-16 md:py-20">
      <div class="container mx-auto px-4">
        <h3 class="mb-10 font-display text-3xl">{isEn ? 'Extra services' : 'Doplnkové služby'}</h3>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {EXTRA_SERVICES.map((svc) => (
            svc.link ? (
              <a href={getRelativeHref(svc.link, language)} class="flex items-start gap-4 rounded-2xl border border-border/50 p-6 transition-all hover:bg-surface hover:shadow-md hover:border-primary/20 group">
                <div class="mt-1 shrink-0 rounded-full bg-primary/10 p-2 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                  <Icon name="Star" class="h-4 w-4" />
                </div>
                <div>
                  <h4 class="font-semibold flex items-center gap-2">
                    {svc.title}
                    <Icon name="ArrowRight" class="h-3 w-3 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" />
                  </h4>
                  <p class="text-sm font-medium text-cta">{svc.price}</p>
                  <p class="mt-1 text-sm text-muted-foreground">{svc.description}</p>
                </div>
              </a>
            ) : (
              <div class="flex items-start gap-4 rounded-2xl border border-border/50 p-6 transition-colors hover:bg-surface">
                <div class="mt-1 shrink-0 rounded-full bg-primary/10 p-2 text-primary">
                  <Icon name="Star" class="h-4 w-4" />
                </div>
                <div>
                  <h4 class="font-semibold">{svc.title}</h4>
                  <p class="text-sm font-medium text-cta">{svc.price}</p>
                  <p class="mt-1 text-sm text-muted-foreground">{svc.description}</p>
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>
