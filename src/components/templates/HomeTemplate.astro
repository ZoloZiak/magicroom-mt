---
import { Image } from 'astro:assets';
import BookingForm from '@/components/forms/BookingForm.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import Sparkles from '@/components/layout/Sparkles.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro'
import CardContent from '@/components/ui/CardContent.astro'
import CardDescription from '@/components/ui/CardDescription.astro'
import CardHeader from '@/components/ui/CardHeader.astro'
import CardTitle from '@/components/ui/CardTitle.astro';
import { ADDRESS_LABEL, MAP_URL, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import {
  getHomeOfferCards,
  getHomeStats,
  IMAGE_ASSETS,
  IMAGE_URLS,
  getProcessSteps,
  getTrustReasons,
} from '@/data/content';
import { getTranslations, type Language } from '@/lib/translations';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);
const isEn = language === 'en';

const stats = getHomeStats(language);
const offerCards = getHomeOfferCards(language);
const trustReasons = getTrustReasons(language);
const processSteps = getProcessSteps(language);

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: isEn ? 'How to book a wedding dress fitting' : 'Ako rezervovať skúšku svadobných šiat',
  step: processSteps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: `Krok ${i + 1}`,
    text: step,
  })),
};
---

<Layout
  title={isEn ? "MagicRoom — wedding dresses, decor and bridal concierge" : "MagicRoom — svadobné šaty, dekorácie a bridal concierge v Martine"}
  description={isEn ? "MagicRoom is a boutique wedding salon in Martin. Fittings from 15€, event styling and personal bridal assistance." : "MagicRoom je lokálny svadobný salón v Martine. Skúška svadobných šiat od 15 €, výzdoba svadieb a osláv, svadobné poradenstvo a pokojný osobný prístup."}
  keywords="svadobne saty, dekoracie, martin, bridal concierge, svadobne poradenstvo"
  image={IMAGE_URLS.hero}
  structuredData={howToSchema}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="relative overflow-hidden slovak-seasons bg-[linear-gradient(180deg,var(--color-gradient-start)_0%,var(--color-gradient-end)_100%)] pt-20">
      <Sparkles count={6} />
      <div class="container mx-auto px-4 pb-14 pt-8 md:pb-24 md:pt-10">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="hero-badge badge folk-pattern mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              {t.home.heroBadge}
            </Badge>
            <h1 class="hero-title font-display text-[2.9rem] leading-[0.95] text-foreground md:text-6xl lg:text-7xl">
              {t.home.heroTitle}
            </h1>
            <p class="hero-description mt-6 max-w-xl text-lg leading-8 text-muted-foreground md:text-xl">
              {t.home.heroDescription}
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg" className="hero-button interactive-ripple sm:min-w-[220px]">
                <a href="#booking">
                  {t.home.ctaBook}
                  <Icon name="ArrowRight" class="icon-morph slovak-heart h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg" className="hero-button sm:min-w-[220px]">
                <a href={isEn ? "/en/services" : "/sluzby"}>{t.home.ctaServices}</a>
              </Button>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {stats.map((stat, i) => (
                <div class={`rounded-2xl border border-border/70 bg-card/80 px-5 py-4 shadow-sm backdrop-blur animate-fade-in-up animate-stagger-${i + 1}`}>
                  <p class="font-display text-3xl text-cta">{stat.value}</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="relative">
            <div class="photo-card-lg">
              <Image
                src={IMAGE_ASSETS.hero}
                alt="MagicRoom interior"
                class="hero h-full max-h-[640px] w-full rounded-[24px] object-cover"
                width="1200"
                height="900"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20 -z-10 rounded-[24px]" aria-hidden="true"></div>
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <a href={PHONE_HREF} class="rounded-2xl border border-border/70 bg-card px-5 py-4 shadow-sm spring-hover">
                <div class="flex items-center gap-3 text-primary">
                  <Icon name="Phone" class="h-4 w-4" />
                  <span class="text-sm uppercase tracking-[0.2em]">{t.common.phone}</span>
                </div>
                <p class="mt-3 font-semibold text-foreground">{PHONE_DISPLAY}</p>
              </a>
              <a href={MAP_URL} target="_blank" rel="noopener noreferrer" data-ga-category="external" data-ga-action="map_click" data-ga-label="hero_map" class="rounded-2xl border border-border/70 bg-card px-5 py-4 shadow-sm spring-hover" aria-label={`${ADDRESS_LABEL} (${isEn ? 'opens in a new tab' : 'otvorí sa v novom okne'})`}>
                <div class="flex items-center gap-3 text-primary">
                  <Icon name="MapPin" class="h-4 w-4" />
                  <span class="text-sm uppercase tracking-[0.2em]">{t.common.address}</span>
                </div>
                <p class="mt-3 text-sm leading-6 text-foreground">{ADDRESS_LABEL}</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.nav.services}</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{t.home.servicesTitle}</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            {t.home.servicesSubtitle}
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {offerCards.map((item, index) => (
            <Card className={`service-card border-0 bg-card shadow-[var(--shadow-soft)] spring-hover`}>
              <CardHeader>
                <div class="mb-5 flex items-start justify-between gap-3">
                  {index === 0 && <Badge variant="cta">{isEn ? 'Most popular' : 'Najčastejší prvý krok'}</Badge>}
                </div>
                {item.title && (
                  <CardTitle className="font-display text-2xl">
                    {item.title}
                  </CardTitle>
                )}
                <p class="pt-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
                <CardDescription className="pt-3 text-base leading-7">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={item.href}>
                    {item.cta}
                    <Icon name="ArrowRight" class="icon-morph h-4 w-4" />
                  </a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20 bg-background">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="rounded-[30px] bg-primary-900 px-6 py-8 text-white shadow-[var(--shadow-dark)] md:px-10 md:py-12 border border-accent/10">
            <p class="text-sm uppercase tracking-[0.24em] text-white/70">{t.home.whySubtitle}</p>
            <h2 class="mt-4 font-display text-4xl leading-tight md:text-5xl">{t.home.whyTitle}</h2>
            <div class="mt-10 grid gap-5 md:grid-cols-2">
              {trustReasons.map((reason) => (
                <div class="rounded-2xl border border-accent/10 bg-accent/5 p-5">
                  <div class="flex items-start gap-3">
                    <div class="mt-1 rounded-full bg-accent/10 p-2 text-accent">
                      <Icon name="CheckCircle2" class="h-4 w-4" />
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-white">{reason.title}</h3>
                      <p class="mt-2 text-sm text-white/70">{reason.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-[30px] border border-border/70 bg-card p-6 shadow-[var(--shadow-soft)] md:p-10">
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.processSubtitle}</p>
            <h2 class="mt-4 font-display text-4xl text-foreground">{t.home.processTitle}</h2>
            <div class="mt-8 space-y-5">
              {processSteps.map((step, index) => (
                <div class="flex gap-4 rounded-2xl bg-surface px-5 py-5">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-semibold text-primary-foreground">
                    0{index + 1}
                  </div>
                  <p class="pt-1 text-base leading-7 text-muted-foreground">{step}</p>
                </div>
              ))}
            </div>

            <div class="mt-8 rounded-2xl border border-border/70 px-5 py-4">
              <div class="flex items-center gap-3 text-primary">
                <Icon name="Clock3" class="h-4 w-4" />
                <span class="text-sm uppercase tracking-[0.16em]">{t.contact.replyNote}</span>
              </div>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">{t.home.processNote}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-card py-12 md:py-16 border-t border-border/50">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{isEn ? 'Journal' : t.home.blogTitle}</p>
            <h2 class="mt-3 font-display text-3xl text-foreground md:text-4xl">{t.home.blogSubtitle}</h2>
            <p class="mt-4 text-base leading-7 text-muted-foreground">
              {t.common.footerDescription}
            </p>
            <div class="mt-8">
              <Button asChild variant="outline" size="lg">
                <a href={isEn ? "/en/blog" : "/blog"}>
                  {t.home.blogCta}
                  <Icon name="ArrowRight" class="h-4 w-4 ml-2" />
                </a>
              </Button>
            </div>
          </div>
          <div class="photo-card hidden lg:block">
            <Image
              src={IMAGE_ASSETS.decorMain}
              alt={isEn ? "Wedding inspiration" : "Svadobné inšpirácie"}
              class="w-full rounded-[24px] object-cover max-h-[400px]"
              width={600}
              height={400}
            />
          </div>
        </div>
      </div>
    </section>

    <section id="booking" class="py-16 md:py-20 bg-background">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-10 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.bookingTitle}</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{t.home.bookingTitle}</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            {t.home.bookingSubtitle} {t.home.bookingNote}
          </p>
        </div>

        <BookingForm language={language} />
      </div>
    </section>
  </main>

  <Footer language={language} />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>