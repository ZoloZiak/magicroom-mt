---
import { Image } from 'astro:assets';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import { getBookingPageHref, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { getConsignmentBenefits, getConsignmentConditions, getConsignmentSteps, IMAGE_ASSETS, IMAGE_URLS, DRESS_CATALOG } from '@/data/content';
import { getTranslations, getRelativeHref, type Language } from '@/lib/translations';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  language: Language;
  skSlug: string;
}

const { language, skSlug } = Astro.props;
const t = getTranslations(language);
const isEn = language === 'en';

const CONSIGNMENT_STEPS = getConsignmentSteps(language);
const CONSIGNMENT_BENEFITS = getConsignmentBenefits(language);
const CONSIGNMENT_CONDITIONS = getConsignmentConditions(language);

const consignmentSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: isEn ? 'How Consignment Works' : 'Ako funguje komisný predaj',
  steps: CONSIGNMENT_STEPS.map((step, i) => ({
    '@type': 'HowToStep',
    name: isEn ? `Step ${i + 1}` : `Krok ${i + 1}`,
    text: step,
  })),
};

const consignmentOgImage = DRESS_CATALOG[0]?.imageAsset ? String(DRESS_CATALOG[0].imageAsset) : IMAGE_URLS.hero;
---

<Layout
  title={t.consignment.pageTitle}
  description={t.consignment.pageDescription}
  image={consignmentOgImage}
  structuredData={consignmentSchema}
  breadcrumbs={[
    { name: t.nav.home, url: isEn ? '/en' : '/' },
    { name: t.nav.consignment, url: getRelativeHref(skSlug, language) },
  ]}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="relative overflow-hidden bg-primary-900 py-16 md:py-24 text-white">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-accent/10 blur-3xl rounded-full translate-x-1/2"></div>
      <div class="container relative mx-auto px-4">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 bg-card/10 text-accent border-accent/20">
              {t.consignment.heroBadge}
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight md:text-6xl">
              {t.consignment.heroTitle}
            </h1>
            
            <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-cta px-4 py-2 text-sm font-bold uppercase tracking-wider text-white shadow-lg animate-pulse">
              <Icon name="AlertCircle" class="h-4 w-4" />
              {isEn ? 'Capacity full — currently not accepting dresses' : 'Kapacita plná — šaty momentálne neprijímame'}
            </div>

            <p class="mt-6 text-lg leading-8 text-white/70 md:text-xl">
              {t.consignment.heroDescription}
            </p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row items-center">
              <Button variant="cta" size="lg" href={getBookingPageHref(language)}>
                {isEn ? 'Contact us' : 'Dohodnúť si termín'}
                <Icon name="ArrowRight" class="h-5 w-5 ml-2" />
              </Button>
            </div>
          </div>
          <div class="photo-card-lg animate-fade-in-right">
            <Image
              src={IMAGE_ASSETS.hero}
              alt="Dresses"
              class="w-full rounded-[32px] object-cover shadow-2xl"
              widths={[240, 480]}
              sizes="(max-width: 480px) 240px, 480px"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-background">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center mb-16">
          <h2 class="font-display text-4xl md:text-5xl">{isEn ? 'How it works' : 'Ako prebieha komis'}</h2>
          <p class="mt-4 text-muted-foreground">{isEn ? 'Simple 3-step process.' : 'Jednoduchý proces v troch krokoch.'}</p>
        </div>
        <div class="grid gap-12 md:grid-cols-3">
          {CONSIGNMENT_STEPS.map((step, i) => (
            <div class="text-center group">
              <div class="mb-6 inline-flex h-20 w-20 items-center justify-center rounded-full bg-surface text-3xl font-display text-primary transition-all group-hover:bg-primary group-hover:text-white">
                {i + 1}
              </div>
              <p class="text-lg text-muted-foreground leading-relaxed">
                {step}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-surface py-20 md:py-28">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-4xl">
          <h2 class="font-display text-4xl mb-12 text-center">{isEn ? 'Why sell with us' : 'Výhody pre vás'}</h2>
          <div class="grid gap-6 md:grid-cols-2">
            {CONSIGNMENT_BENEFITS.map((benefit) => (
              <div class="flex gap-4 p-6 rounded-2xl bg-card shadow-sm border border-border/50">
                <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <Icon name="CheckCircle2" class="h-4 w-4" />
                </div>
                <p class="text-lg leading-relaxed">{benefit}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-background">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-center mb-12">
          <Icon name="Heart" class="h-10 w-10 text-primary mx-auto mb-4" />
          <h2 class="font-display text-4xl">{isEn ? 'Conditions' : 'Podmienky prijatia'}</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {CONSIGNMENT_CONDITIONS.map((cond) => (
            <div class="p-6 rounded-2xl border border-border bg-surface">
              <p class="text-muted-foreground">{cond}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center p-8 rounded-3xl bg-cta/5 border border-cta/20">
          <p class="text-lg font-medium text-cta">
            {isEn ? 'Ready to give your dresses a second life?' : 'Máte šaty, ktoré si zaslúžia ďalšiu nevestu?'}
          </p>
          <Button variant="cta" size="lg" className="mt-6" href={getBookingPageHref(language)}>
            {isEn ? 'Contact us' : 'Dohodnúť si termín'}
          </Button>
        </div>
      </div>
    </section>

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>
