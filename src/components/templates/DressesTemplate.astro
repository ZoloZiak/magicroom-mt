---
import { Image } from 'astro:assets';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import { getBookingPageHref } from '@/data/site';
import { getWeddingDresses, IMAGE_URLS } from '@/data/content';
import { getTranslations, getRelativeHref, type Language } from '@/lib/translations';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  language: Language;
  skSlug: string;
}

const { language, skSlug } = Astro.props;
const t = getTranslations(language);
const isEn = language === 'en';

const dresses = await getWeddingDresses(language);
const firstDressImage = dresses[0]?.imageAsset?.src || IMAGE_URLS.hero;

const productSchema = dresses.map((dress) => ({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: dress.name,
  description: dress.description,
  offers: {
    '@type': 'Offer',
    price: dress.price,
    priceCurrency: 'EUR',
    availability: dress.status === 'available' 
      ? 'https://schema.org/InStock' 
      : 'https://schema.org/SoldOut',
  },
}));
---

<Layout
  title={t.dresses.pageTitle}
  description={t.dresses.pageDescription}
  image={firstDressImage}
  structuredData={productSchema}
  breadcrumbs={[
    { name: t.nav.home, url: isEn ? '/en' : '/' },
    { name: t.nav.dresses, url: getRelativeHref(skSlug, language) },
  ]}
  language={language}
>
  <Header language={language} />

  <main class="flex-1">
    <section class="bg-surface py-12 md:py-20">
      <div class="container mx-auto px-4 text-center">
        <Badge variant="secondary" class="mb-4">
          {t.dresses.heroBadge}
        </Badge>
        <h1 class="font-display text-4xl md:text-6xl mb-6">
          {t.dresses.heroTitle}
        </h1>
        <p class="max-w-2xl mx-auto text-lg text-muted-foreground">
          {t.dresses.heroDescription}
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-background">
      <div class="container mx-auto px-4">
        <div id="dresses-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {dresses.map((dress) => (
            <div class="group overflow-hidden rounded-[24px] border border-border/50 bg-card transition-all hover:shadow-xl">
              <div class="relative aspect-[2/3] overflow-hidden bg-surface">
                {/* 
                  Main click target: links to the first image.
                  Hidden links: link to the other images so PhotoSwipe can find them.
                */}
                <div class="gallery-item-group h-full w-full">
                  {dress.images.map((img, i) => (
                    <a 
                      href={img.src} 
                      data-pswp-width={img.width} 
                      data-pswp-height={img.height} 
                      target="_blank"
                      class={i === 0 ? "block h-full w-full cursor-zoom-in" : "hidden"}
                      aria-label={`${dress.name} - ${i + 1}/${dress.images.length}`}
                    >
                      {i === 0 && (
                        <Image
                          src={img}
                          alt={dress.name}
                          width={600}
                          height={900}
                          class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
                        />
                      )}
                    </a>
                  ))}
                </div>
                
                <div class="absolute right-4 top-4 pointer-events-none">
                  <Badge variant={dress.status === 'available' ? 'success' : 'outline'} class="backdrop-blur-md">
                    {dress.status === 'available' ? t.dresses.statusAvailable : t.dresses.statusReserved}
                  </Badge>
                </div>
              </div>
              <div class="flex flex-col p-6 h-full">
                <div class="flex items-start justify-between">
                  <div>
                    <h2 class="font-display text-2xl">{dress.name}</h2>
                    <p class="mt-1 text-sm text-muted-foreground">{dress.description}</p>
                  </div>
                  <p class="text-xl font-bold text-cta shrink-0 ml-2">{dress.price} €</p>
                </div>
                <div class="mt-auto flex items-center justify-between border-t border-border/50 pt-4">
                  <span class="text-sm font-medium uppercase tracking-widest text-muted-foreground">
                    {t.dresses.sizeLabel} {dress.size}
                  </span>
                  <Button variant="ghost" size="sm" class="group/btn text-muted-foreground hover:text-primary" href={isEn ? '/en/contact#booking' : '/kontakt#booking'}>
                    {t.dresses.bookFitting}
                    <Icon name="ArrowRight" class="ml-2 h-4 w-4 transition-transform group-hover/btn:translate-x-1" />
                  </Button>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-20 text-center p-12 rounded-[40px] bg-surface border border-dashed border-primary/30">
           <Icon name="Heart" class="h-10 w-10 text-primary mx-auto mb-6" aria-hidden="true" />
           <h3 class="font-display text-3xl mb-4">{t.dresses.consignmentTitle}</h3>
           <p class="mb-8 text-muted-foreground">{t.dresses.consignmentText}</p>
           <Button variant="outline" href={getRelativeHref('komisny-predaj', language)}>
              {t.nav.consignment}
           </Button>
        </div>
      </div>
    </section>

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  let lightbox: any;

  const initLightbox = () => {
    if (lightbox) {
      lightbox.destroy();
    }
    
    lightbox = new PhotoSwipeLightbox({
      gallery: '#dresses-grid',
      children: 'a[data-pswp-width]',
      pswpModule: () => import('photoswipe'),
      padding: { top: 20, bottom: 20, left: 10, right: 10 },
      showHideAnimationType: 'zoom'
    });
    lightbox.init();
  };

  // Inicializácia pri prvom načítaní
  initLightbox();

  // Reinicializácia po navigácii v Astro (View Transitions)
  document.addEventListener('astro:after-swap', initLightbox);
</script>

<style is:global>
  .pswp {
    --pswp-bg: rgba(42, 26, 36, 0.95);
  }
  .pswp__img {
    border-radius: 8px;
  }
</style>
