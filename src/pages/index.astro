---
import { Image } from 'astro:assets';
import BookingForm from '@/components/forms/BookingForm.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import Sparkles from '@/components/layout/Sparkles.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro'
import CardContent from '@/components/ui/CardContent.astro'
import CardDescription from '@/components/ui/CardDescription.astro'
import CardHeader from '@/components/ui/CardHeader.astro'
import CardTitle from '@/components/ui/CardTitle.astro';
import { ADDRESS_LABEL, MAP_URL, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import {
  FOUNDER_STORY,
  HOME_OFFER_CARDS,
  HOME_STATS,
  IMAGE_ASSETS,
  IMAGE_URLS,
  PROCESS_STEPS,
  TRUST_REASONS,
} from '@/data/content';
import { getTranslations } from '@/lib/translations';
import type { Language } from '@/lib/i18n';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/ui/Icon.astro';

const language: Language = 'sk';
const t = getTranslations(language);

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Ako rezervovať skúšku svadobných šiat v MagicRoom',
  step: PROCESS_STEPS.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: `Krok ${i + 1}`,
    text: step,
  })),
};
---

<Layout
  title="MagicRoom — svadobné šaty, dekorácie a bridal concierge v Martine"
  description="MagicRoom je lokálny svadobný salón v Martine. Skúška svadobných šiat od 15 €, výzdoba svadieb a osláv, svadobné poradenstvo a pokojný osobný prístup."
  keywords="svadobne saty, dekoracie, martin, bridal concierge, svadobne poradenstvo, komisny predaj"
  image={IMAGE_URLS.hero}
  structuredData={howToSchema}
  language="sk"
>
  <Header language={language} />

  <main class="flex-1">
    <section class="relative overflow-hidden slovak-seasons bg-[linear-gradient(180deg,var(--color-gradient-start)_0%,var(--color-gradient-end)_100%)] pt-20">
      <Sparkles count={6} />
      <div class="container mx-auto px-4 pb-14 pt-8 md:pb-24 md:pt-10">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="hero-badge badge folk-pattern mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              {t.home.heroBadge}
            </Badge>
            <h1 class="hero-title font-display text-[2.9rem] leading-[0.95] text-foreground md:text-6xl lg:text-7xl">
              {t.home.heroTitle}
            </h1>
            <p class="hero-description mt-6 max-w-xl text-lg leading-8 text-muted-foreground md:text-xl">
              {t.home.heroDescription}
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg" className="hero-button interactive-ripple sm:min-w-[220px]">
                <a href="#booking" data-ga-category="conversion" data-ga-action="book_appointment_click" data-ga-label="hero_cta">
                  {t.home.ctaBook}
                  <Icon name="ArrowRight" class="icon-morph slovak-heart h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg" className="hero-button sm:min-w-[220px]">
                <a href="/sluzby" data-ga-category="engagement" data-ga-action="navigation_click" data-ga-label="hero_services">{t.home.ctaServices}</a>
              </Button>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {HOME_STATS.map((stat, i) => (
                <div class={`rounded-2xl border border-border/70 bg-white/80 px-5 py-4 shadow-sm backdrop-blur animate-fade-in-up animate-stagger-${i + 1}`}>
                  <p class="font-display text-3xl text-cta">{stat.value}</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="relative">
            <div class="photo-card-lg">
              <Image
                src={IMAGE_ASSETS.hero}
                alt="Interiér svadobného salónu MagicRoom v Martine."
                class="hero parallax-float tatry-mountain h-full max-h-[640px] w-full rounded-[24px] object-cover"
                width="60"
                height="45"
                loading="eager"
              />
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <a href={PHONE_HREF} data-ga-category="contact" data-ga-action="phone_click" data-ga-label="hero_phone" class="rounded-2xl border border-border/70 bg-white px-5 py-4 shadow-sm spring-hover">
                <div class="flex items-center gap-3 text-primary">
                  <Icon name="Phone" class="h-4 w-4" />
                  <span class="text-sm uppercase tracking-[0.2em]">Telefón</span>
                </div>
                <p class="mt-3 font-semibold text-foreground">{PHONE_DISPLAY}</p>
              </a>
              <a href={MAP_URL} target="_blank" rel="noopener noreferrer" data-ga-category="external" data-ga-action="map_click" data-ga-label="hero_map" class="rounded-2xl border border-border/70 bg-white px-5 py-4 shadow-sm spring-hover">
                <div class="flex items-center gap-3 text-primary">
                  <Icon name="MapPin" class="h-4 w-4" />
                  <span class="text-sm uppercase tracking-[0.2em]">Adresa</span>
                </div>
                <p class="mt-3 text-sm leading-6 text-foreground">{ADDRESS_LABEL}</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.servicesSubtitle.split('—')[0]}</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{t.home.servicesTitle}</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            {t.home.servicesSubtitle}
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {HOME_OFFER_CARDS.map((item, index) => (
            <Card className={`service-card border-0 bg-white shadow-[var(--shadow-soft)] spring-hover`}>
              <CardHeader>
                <div class="mb-5 flex items-start justify-between gap-3">
                  {index === 0 && <Badge variant="cta">Najčastejší prvý krok</Badge>}
                </div>
                <CardTitle className="font-display text-2xl">
                  <h3 class="text-2xl">{item.title}</h3>
                </CardTitle>
                <p class="pt-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
                <CardDescription className="pt-3 text-base leading-7">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={item.href} data-ga-category="engagement" data-ga-action="navigation_click" data-ga-label={`homepage_services_${item.href.replace('/', '')}`}>
                    {item.cta}
                    <Icon name="ArrowRight" class="icon-morph h-4 w-4" />
                  </a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="rounded-[30px] bg-primary-900 px-6 py-8 text-white shadow-[var(--shadow-dark)] md:px-10 md:py-12">
            <p class="text-sm uppercase tracking-[0.24em] text-white/70">{t.home.whySubtitle}</p>
            <h2 class="mt-4 font-display text-4xl leading-tight md:text-5xl">{t.home.whyTitle}</h2>
            <div class="mt-10 grid gap-5 md:grid-cols-2">
              {TRUST_REASONS.map((reason) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <div class="flex items-start gap-3">
                    <div class="mt-1 rounded-full bg-white/10 p-2 text-accent">
                      <Icon name="CheckCircle2" class="h-4 w-4" aria-hidden="true" />
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-white">{reason.title}</h3>
                      <p class="mt-2 text-sm leading-6 text-white/70">{reason.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-[30px] border border-border/70 bg-white p-6 shadow-[var(--shadow-soft)] md:p-10">
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Jednoduchý proces</p>
            <h2 class="mt-4 font-display text-4xl text-foreground">{t.home.processTitle}</h2>
            <div class="mt-8 space-y-5">
              {PROCESS_STEPS.map((step, index) => (
                <div class="flex gap-4 rounded-2xl bg-surface px-5 py-5">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-semibold text-primary-foreground">
                    0{index + 1}
                  </div>
                  <p class="pt-1 text-base leading-7 text-muted-foreground">{step}</p>
                </div>
              ))}
            </div>

            <div class="mt-8 rounded-2xl border border-border/70 px-5 py-4">
              <div class="flex items-center gap-3 text-primary">
                <Icon name="Clock3" class="h-4 w-4" />
                <span class="text-sm uppercase tracking-[0.16em]">Rýchla odpoveď</span>
              </div>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">Na rezervácie a dopyty odpovedáme spravidla do 24 hodín. Ak je to súrne, zavolajte nám.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-surface py-12 md:py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
          <div class="photo-card max-w-md mx-auto lg:mx-0">
            <Image
              src={IMAGE_ASSETS.founder}
              alt="Natália Ondrejková, zakladateľka svadobného salónu MagicRoom v Martine."
              class="w-full rounded-[24px] bg-surface object-contain"
              loading="lazy"
            />
          </div>

          <div class="max-w-2xl">
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.founderLabel}</p>
            <blockquote class="mt-4 font-display text-3xl italic leading-tight text-foreground md:text-4xl">
              „{FOUNDER_STORY.quote}“
            </blockquote>
            <p class="mt-6 text-base leading-7 text-muted-foreground">
              {FOUNDER_STORY.paragraphs[0]}
              {FOUNDER_STORY.paragraphs[1]}
            </p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg">
                <a href="/o-nas">Spoznať náš príbeh</a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href="#booking">Prejsť k rezervácii</a>
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-12 md:py-16 border-t border-border/50">
      <div class="container mx-auto px-4">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{t.home.blogTitle}</p>
            <h2 class="mt-3 font-display text-3xl text-foreground md:text-4xl">{t.home.blogSubtitle}</h2>
            <p class="mt-4 text-base leading-7 text-muted-foreground">
              Svadba nie je len o šatách, ale o stovkách malých rozhodnutí. Na našom blogu nájdete praktické rady, ktoré vám ušetria čas pri plánovaní a pomôžu vybrať štýl, ktorý vám naozaj sedí.
            </p>
            <div class="mt-8">
              <Button asChild variant="outline" size="lg">
                <a href="/blog">
                  {t.home.blogCta}
                  <Icon name="ArrowRight" class="h-4 w-4 ml-2" />
                </a>
              </Button>
            </div>
          </div>
          <div class="photo-card hidden lg:block">
            <img
              src={IMAGE_URLS.decorMain}
              alt="Svadobné inšpirácie v MagicRoom"
              class="w-full rounded-[24px] object-cover max-h-[400px]"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-10 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Rezervácia termínu</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{t.home.bookingTitle}</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            {t.home.bookingSubtitle} Ak už riešite konkrétnu predstavu o výzdobe alebo svadobnej konzultácii, napíšte nám to rovno do správy.
          </p>
        </div>

        <BookingForm />
      </div>
    </section>
  </main>

  <Footer language={language} />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>