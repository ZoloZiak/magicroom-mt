---
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, Camera, ChefHat, Music, PartyPopper, Phone, Scissors } from 'lucide-react';

const PARTNERS = [
  {
    category: 'Fotograf',
    partners: [
      { name: ' wedding fotograf', description: 'Profesionálne svadobné fotenie v Martine a okolí', phone: '+421 950 123 456' },
    ],
    icon: Camera,
  },
  {
    category: 'Catering',
    partners: [
      { name: 'Svadobný catering', description: 'Kompletný catering pre svadby a oslavy', phone: '+421 944 567 890' },
    ],
    icon: ChefHat,
  },
  {
    category: 'DJ & Hudba',
    partners: [
      { name: 'DJ Miroslav', description: 'Svadobný DJ s hudbou pre každý vkus', phone: '+421 903 234 567' },
    ],
    icon: Music,
  },
  {
    category: 'Make-up',
    partners: [
      { name: 'Svadobný make-up', description: 'Profesionálny make-up pre nevesty', phone: '+421 915 678 901' },
    ],
    icon: Scissors,
  },
  {
    category: 'Výzdoba',
    partners: [
      { name: 'Kvetinárstvo', description: 'Čerstvé kvety a aranžmány', phone: '+421 940 345 678' },
    ],
    icon: PartyPopper,
  },
] as const;
---

<Layout
  title="Odporúčaní dodávatelia — MagicRoom Partneri"
  description="Odporúčaní dodávatelia pre vašu svadbu: fotograf, caterer, DJ, florista a ďalší v Martine. Overení partneri svadobného salónu MagicRoom."
  keywords="svadobní dodávatelia, fotograf, caterer, DJ, florista, Martin, svadobní vendori"
  image={IMAGE_ASSETS.hero}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Partneri', url: '/partneri' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Overení partneri
          </Badge>
          <h1 class="font-display text-4xl text-foreground md:text-5xl">
            Odporúčaní dodávatelia
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Overení partneri, s ktorými spolupracujeme. Všetky služby je možné koordinovať spolu so skúškou šiat v MagicRoom.
          </p>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {PARTNERS.map((category) => {
            const IconComponent = category.icon;
            return (
              <Card className="border-0 bg-white shadow-[var(--shadow-soft)]">
                <CardHeader>
                  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                    <IconComponent className="h-5 w-5" />
                  </div>
                  <CardTitle className="font-display text-2xl">{category.category}</CardTitle>
                </CardHeader>
                <CardContent>
                  {category.partners.map((partner) => (
                    <div class="mt-4 rounded-2xl bg-surface p-4">
                      <h3 class="font-semibold text-foreground">{partner.name}</h3>
                      <p class="mt-1 text-sm text-muted-foreground">{partner.description}</p>
                      <a
                        href={`tel:${partner.phone}`}
                        class="mt-3 inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-cta"
                      >
                        <Phone className="h-4 w-4" />
                        {partner.phone}
                      </a>
                    </div>
                  ))}
                </CardContent>
              </Card>
            );
          })}
        </div>
      </div>
    </section>

    <CTASection />

  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>