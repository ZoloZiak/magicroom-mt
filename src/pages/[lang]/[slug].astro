---
import { SLUG_MAP } from '@/lib/i18n';

export async function getStaticPaths() {
  const paths = [];
  const skSlugs = Object.keys(SLUG_MAP);

  for (const skSlug of skSlugs) {
    // SK route
    paths.push({
      params: { lang: 'sk', slug: skSlug },
      props: { skSlug },
    });

    // EN route
    const enSlug = SLUG_MAP[skSlug];
    paths.push({
      params: { lang: 'en', slug: enSlug },
      props: { skSlug },
    });
  }

  return paths;
}

import type { Language } from '@/lib/i18n';

// Import templates
import AboutTemplate from '@/components/templates/AboutTemplate.astro';
import ServicesTemplate from '@/components/templates/ServicesTemplate.astro';
import DressesTemplate from '@/components/templates/DressesTemplate.astro';
import GalleryTemplate from '@/components/templates/GalleryTemplate.astro';
import ConsignmentTemplate from '@/components/templates/ConsignmentTemplate.astro';
import DecorationsTemplate from '@/components/templates/DecorationsTemplate.astro';
import PartnersTemplate from '@/components/templates/PartnersTemplate.astro';
import ContactTemplate from '@/components/templates/ContactTemplate.astro';

const { lang, slug } = Astro.params;
const language = lang as Language;
const { skSlug } = Astro.props;

// Map skSlug to component
const templates: Record<string, any> = {
  'o-nas': AboutTemplate,
  'sluzby': ServicesTemplate,
  'svadobne-saty': DressesTemplate,
  'galeria': GalleryTemplate,
  'komisny-predaj': ConsignmentTemplate,
  'prenajom-dekoracii': DecorationsTemplate,
  'partneri': PartnersTemplate,
  'kontakt': ContactTemplate,
};

const Template = templates[skSlug];
---

{Template ? <Template language={language} skSlug={skSlug} /> : <div>Page not found</div>}
