---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import BookingForm from '@/components/forms/BookingForm.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import Header from '@/components/layout/Header.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { ADDRESS_LABEL, PHONE_DISPLAY, WHATSAPP_URL } from '@/data/site';
import { CONTACT_ACTIONS, CONTACT_ACTIONS_EN, CONTACT_FAQS, CONTACT_FAQS_EN, IMAGE_ASSETS } from '@/data/content';
import { getTranslations } from '@/lib/translations';
import type { Language } from '@/lib/i18n';
import Layout from '@/layouts/Layout.astro';
import { Mail, MapPin, MessageCircle, Phone } from 'lucide-react';

export function getStaticPaths() {
  return [
    { params: { lang: 'sk' }, props: { language: 'sk' as Language } },
    { params: { lang: 'en' }, props: { language: 'en' as Language } },
  ];
}

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);

const isEn = language === 'en';
const contactActions = isEn ? CONTACT_ACTIONS_EN : CONTACT_ACTIONS;
const contactFaqs = isEn ? CONTACT_FAQS_EN : CONTACT_FAQS;
const HeaderComponent = isEn ? HeaderEn : Header;
const FooterComponent = isEn ? FooterEn : Footer;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: contactFaqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const contactIcons = [Phone, MessageCircle, Mail, MapPin];

const pageData = isEn
  ? {
      title: 'Contact and booking — MagicRoom Martin',
      description: 'Book your wedding dress fitting from 12 € or wedding consultation at MagicRoom in Martin. Phone, WhatsApp, email, map and booking form. English spoken — Norwegian students welcome!',
      heroBadge: 'Contact • reservation • Martin',
      heroNotes: ['Martin • visit by appointment', 'Reply usually within 24 hours', 'Wedding dress fitting 12 € / 60 min'],
      bookingTitle: 'Book a fitting or send a query without waiting',
      bookingDesc: 'Fill in a few details and we will prepare a WhatsApp message for you to check before sending.',
      whatNextTitle: 'What happens next',
      whatNextDesc1: 'After submitting the form, a prepared WhatsApp message will open.',
      whatNextDesc2: 'When we receive your message, we will get back to you with a confirmation.',
    }
  : {
      title: 'Kontakt a rezervácia skúšky šiat — MagicRoom Martin',
      description: 'Rezervujte si skúšku svadobných šiat od 12 € alebo svadobnú konzultáciu v MagicRoom v Martine. Telefón, WhatsApp, email, mapa a rezervačný formulár.',
      heroBadge: 'Kontakt • rezervácia • Martin',
      heroNotes: ['Martin • návšteva na objednávku', 'Odpoveď zvyčajne do 24 hodín', 'Skúška svadobných šiat 12 € / 60 min'],
      bookingTitle: 'Zarezervujte si skúšku alebo pošlite dopyt bez zbytočného čakania',
      bookingDesc: 'Vyplňte pár detailov a pripravíme vám WhatsApp správu, ktorú si pred odoslaním ešte skontrolujete.',
      whatNextTitle: 'Čo sa stane potom',
      whatNextDesc1: 'Po odoslaní formulára sa otvorí pripravená WhatsApp správa.',
      whatNextDesc2: 'Keď nám správa príde, ozveme sa vám s potvrdením termínu.',
    };
---

<Layout
  title={pageData.title}
  description={pageData.description}
  keywords="contact, booking, martin, phone, email, whatsapp"
  image={IMAGE_ASSETS.map}
  structuredData={faqSchema}
  breadcrumbs={isEn ? [{ name: 'Home', url: '/en' }, { name: 'Contact', url: '/en/kontakt' }] : [{ name: 'Domov', url: '/' }, { name: 'Kontakt', url: '/kontakt' }]}
  language={isEn ? 'en' : undefined}
>
  <HeaderComponent />

  <main class="flex-1">
    <Breadcrumbs items={[{ name: isEn ? 'Contact' : 'Kontakt', url: `/${language}/kontakt` }]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            {t.contact.heroBadge}
          </Badge>
          <h1 class="font-display text-[2.85rem] leading-tight text-foreground md:text-6xl">{t.contact.heroTitle}</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">{t.contact.heroDescription}</p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground">
            {pageData.heroNotes.map((note) => (
              <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">{note}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="dots" />

    <section class="py-10 md:py-12">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
          {contactActions.map((action: any, index: number) => {
            const Icon = contactIcons[index];
            const isExternal = action.href.startsWith('http');
            return (
              <a href={action.href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined} class="rounded-[26px] border border-border/70 bg-white p-5 shadow-[var(--shadow-soft)] spring-hover md:p-6" data-ga-category="contact" data-ga-action={isExternal ? 'map_click' : action.href.startsWith('tel:') ? 'phone_click' : 'email_click'} data-ga-label={`contact_card_${index}`}>
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary"><Icon className="h-5 w-5" /></div>
                <h2 class="mt-5 text-xl font-semibold text-foreground">{action.title}</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{action.description}</p>
                <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-cta">{action.label}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="pb-16 pt-6 md:pb-20 md:pt-8">
      <div class="container mx-auto grid gap-8 px-4 xl:grid-cols-[1.15fr_0.85fr]">
        <BookingForm id="booking" title={pageData.bookingTitle} description={pageData.bookingDesc} />
        <div class="space-y-6">
          <Card className="border border-border/70 shadow-[var(--shadow-soft)]">
            <CardContent className="space-y-4 p-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">{pageData.whatNextTitle}</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">{isEn ? 'First a message, then a time confirmation.' : 'Najprv správa, potom potvrdenie termínu.'}</h2>
              </div>
              <div class="space-y-3 text-sm leading-6 text-muted-foreground">
                <p>{pageData.whatNextDesc1}</p>
                <p>{pageData.whatNextDesc2}</p>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>
    </section>

    <FooterComponent />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>