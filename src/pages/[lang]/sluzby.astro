---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import Header from '@/components/layout/Header.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF, BOOKING_PAGE_HREF_EN, PHONE_DISPLAY, PHONE_HREF, WHATSAPP_URL } from '@/data/site';
import { EXTRA_SERVICES, EXTRA_SERVICES_EN, IMAGE_ASSETS, SERVICE_PACKAGES, SERVICE_PACKAGES_EN } from '@/data/content';
import { getTranslations } from '@/lib/translations';
import type { Language } from '@/lib/i18n';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, ClipboardList, LayoutGrid, Phone, Shirt, Sparkles } from 'lucide-react';

export function getStaticPaths() {
  return [
    { params: { lang: 'sk' }, props: { language: 'sk' as Language } },
    { params: { lang: 'en' }, props: { language: 'en' as Language } },
  ];
}

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);

const isEn = language === 'en';
const servicePillars = isEn
  ? [
      { title: 'Wedding Dress Fitting', price: '12 € / 60 min', description: 'Calm fitting with drink included, space for two close people and time to compare multiple styles without stress.', cta: 'Book a fitting', href: BOOKING_PAGE_HREF_EN, icon: Shirt },
      { title: 'Dress Selection & Sale', price: 'from 100 €', description: 'New models, available pieces and consignment options.', cta: 'Ask about selection', href: BOOKING_PAGE_HREF_EN, icon: Sparkles },
      { title: 'Decoration Rental', price: 'from 0.50 € / item', description: 'Mirrors, vases, candlesticks, backdrops and candy bar accessories.', cta: 'View decorations', href: `/${language}/decorations`, icon: LayoutGrid },
      { title: 'Wedding Consulting', price: 'from 40 €', description: 'Consultations, moodboard, timeline and vendor recommendations.', cta: 'View packages', href: '#packages', icon: ClipboardList },
    ]
  : [
      { title: 'Skúška svadobných šiat', price: '12 € / 60 min', description: 'Pokojná skúška s nápojom v cene, priestorom pre dve blízke osoby.', cta: 'Rezervovať skúšku', href: BOOKING_PAGE_HREF, icon: Shirt },
      { title: 'Predaj a výber šiat', price: 'od 100 €', description: 'Nové modely, dostupné kúsky aj komisný výber.', cta: 'Napísať o výber', href: BOOKING_PAGE_HREF, icon: Sparkles },
      { title: 'Prenájom dekorácií', price: 'od 0,50 € / ks', description: 'Zrkadlá, vázy, svietniky, kulisy a candy bar doplnky.', cta: 'Pozrieť dekorácie', href: '/prenajom-dekoracii', icon: LayoutGrid },
      { title: 'Svadobné poradenstvo', price: 'od 40 €', description: 'Konzultácie, moodboard, harmonogram a odporúčania dodávateľov.', cta: 'Pozrieť balíky', href: '#baliky', icon: ClipboardList },
    ];

const servicePackages = isEn ? SERVICE_PACKAGES_EN : SERVICE_PACKAGES;
const extraServices = isEn ? EXTRA_SERVICES_EN : EXTRA_SERVICES;
const HeaderComponent = isEn ? HeaderEn : Header;
const FooterComponent = isEn ? FooterEn : Footer;

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: servicePackages.map((pkg, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'Offer', name: pkg.name, description: pkg.description, price: pkg.price, priceCurrency: 'EUR', availability: 'https://schema.org/InStock' },
  })),
};

const pageData = isEn
  ? {
      title: 'Services & Pricing — Wedding Dresses, Decorations, Consulting | MagicRoom Martin',
      description: 'Wedding dress fitting from 12 €, decoration rental, wedding consulting and wedding planning packages at MagicRoom in Martin with clear prices.',
      breadcrumbs: [{ name: 'Home', url: '/en' }, { name: 'Services', url: '/en/sluzby' }],
      heroTitle: 'Clear offer for the bride who wants everything sorted calmly.',
      heroDesc: 'At MagicRoom you do not start with a long list of obligations. You start with a service that makes sense now.',
      ctaBook: 'Book a fitting',
      ctaWhatsApp: 'Message on WhatsApp',
      norwegianBadge: 'Norwegian students: Special rates available',
      norwegianTitle: 'Studying in Slovakia? We offer tailored packages for international students.',
      norwegianDesc: 'Contact us via WhatsApp — we speak English and can arrange remote consultations.',
      sectionTitle: 'What we offer',
      sectionDesc: 'If you come for dresses, you can sort decorations and initial planning right away.',
      sectionTitle2: 'From the salon',
      sectionTitle3: 'Wedding planning packages',
      sectionDesc3: 'Each package can be adjusted according to wedding size, budget and whether you need more direction.',
      sectionTitle4: 'Extra services',
      sectionDesc4: 'Small items that make big peace in preparations.',
      recommendedLabel: 'Most popular',
      fromSalonLabel: 'From the salon',
      extraServicesLabel: 'Extra services',
      phoneLabel: 'Call',
    }
  : {
      title: 'Služby a cenník — Svadobné šaty, dekorácie, poradenstvo | MagicRoom Martin',
      description: 'Skúška svadobných šiat od 12 €, prenájom dekorácií, svadobné poradenstvo a balíky organizácie svadby v MagicRoom v Martine.',
      breadcrumbs: [{ name: 'Domov', url: '/' }, { name: 'Služby a cenník', url: '/sluzby' }],
      heroTitle: 'Jasná ponuka pre nevestu, ktorá chce všetko vyriešiť s pokojom.',
      heroDesc: 'V MagicRoom nezačínate dlhým zoznamom povinností. Začínate službou, ktorá vám dáva zmysel teraz.',
      ctaBook: 'Zarezervovať skúšku',
      ctaWhatsApp: 'Zavolať',
      norwegianBadge: '',
      norwegianTitle: '',
      norwegianDesc: '',
      sectionTitle: 'Čo u nás vybavíte',
      sectionDesc: 'Ak si prídete po šaty, viete rovno doriešiť dekorácie aj prvé plánovanie.',
      sectionTitle2: 'Zo salónu',
      sectionTitle3: 'Balíky organizácie svadby',
      sectionDesc3: 'Každý balík sa dá upraviť podľa veľkosti svadby, rozpočtu a toho, či potrebujete skôr smerovanie.',
      sectionTitle4: 'Doplnkové služby',
      sectionDesc4: 'Malé položky, ktoré robia veľký pokoj v prípravách.',
      recommendedLabel: 'Najčastejšia voľba',
      fromSalonLabel: 'Zo salónu',
      extraServicesLabel: 'Doplnkové služby',
      phoneLabel: 'Zavolať',
    };
---

<Layout
  title={pageData.title}
  description={pageData.description}
  keywords="wedding services, prices, packages, consultations, wedding planning"
  image={IMAGE_ASSETS.dresses}
  structuredData={[servicesSchema]}
  breadcrumbs={pageData.breadcrumbs}
  language={isEn ? 'en' : undefined}
>
  <HeaderComponent />

  <main class="flex-1">
    <Breadcrumbs items={[{ name: isEn ? 'Services' : 'Služby a cenník', url: `/${language}/sluzby` }]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              {t.services.heroBadge}
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl animate-fade-in-up animate-stagger-2">
              {pageData.heroTitle}
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground animate-fade-in-up animate-stagger-3">
              {pageData.heroDesc}
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row animate-fade-in-up animate-stagger-4">
              <Button asChild variant="cta" size="lg">
                <a href={isEn ? BOOKING_PAGE_HREF_EN : BOOKING_PAGE_HREF}>
                  {pageData.ctaBook}
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={isEn ? WHATSAPP_URL : PHONE_HREF}>{pageData.ctaWhatsApp}</a>
              </Button>
            </div>
            
            {isEn && (
              <div class="mt-6 flex items-center gap-3 text-sm text-muted-foreground">
                <Badge variant="success">English spoken</Badge>
                <span>•</span>
                <span>Norwegian brides welcome</span>
                <span>•</span>
                <span>Transparent prices</span>
              </div>
            )}
          </div>

          <div class="grid gap-5">
            <div class="photo-card">
              <img src={IMAGE_ASSETS.dresses} alt="Wedding dress ready for fitting" class="max-h-[520px] w-full rounded-[24px] bg-surface object-contain" />
            </div>
            {isEn ? (
              <div class="rounded-[28px] border border-primary/20 bg-primary/5 p-6">
                <Badge variant="secondary">🇳🇴 {pageData.norwegianBadge}</Badge>
                <h2 class="mt-4 text-2xl font-display text-foreground">{pageData.norwegianTitle}</h2>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">{pageData.norwegianDesc}</p>
                <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                  Message us on WhatsApp
                </a>
              </div>
            ) : (
              <div class="rounded-[28px] border border-destructive/20 bg-destructive/5 p-6">
                <Badge variant="destructive">Komisný predaj: plná kapacita</Badge>
                <h2 class="mt-4 text-2xl font-display text-foreground">Momentálne neprijímame ďalšie šaty do komisného predaja.</h2>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  Ak chcete byť medzi prvými, keď sa miesto uvoľní, pozrite si podmienky a ozvite sa nám cez stránku komisného predaja.
                </p>
                <a href="/komisny-predaj" class="mt-4 inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                  Pozrieť komisný predaj
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{pageData.sectionTitle}</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{isEn ? 'Four services that can naturally combine together.' : 'Štyri služby, ktoré sa dajú spolu prirodzene prepájať.'}</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">{pageData.sectionDesc}</p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {servicePillars.map((item: any, index: number) => (
            <Card className={`border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <item.icon className="h-5 w-5" />
                </div>
                <CardTitle className="font-display text-2xl">{item.title}</CardTitle>
                <p class="pt-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
                <CardDescription className="pt-3 text-base leading-7">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={item.href}>{item.cta}<ArrowRight className="h-4 w-4" /></a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{pageData.sectionTitle2}</p>
          <h2 class="mt-3 font-display text-3xl text-foreground md:text-4xl">{isEn ? 'This is what it looks like here.' : 'Takto to vyzerá u nás.'}</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.satyRuzove3} alt="Wedding dress" class="h-64 w-full object-cover" loading="lazy" /></div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.interier1} alt="Salon interior" class="h-64 w-full object-cover" loading="lazy" /></div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.sachovnica3} alt="Checkered pattern" class="h-64 w-full object-cover" loading="lazy" /></div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.satyRuzove1} alt="Wedding dress" class="h-64 w-full object-cover" loading="lazy" /></div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.interier3} alt="Interior detail" class="h-64 w-full object-cover" loading="lazy" /></div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]"><img src={IMAGE_ASSETS.detail1} alt="Decoration detail" class="h-64 w-full object-cover" loading="lazy" /></div>
        </div>
      </div>
    </section>

    <section id={isEn ? 'packages' : 'baliky'} class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{pageData.sectionTitle3}</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{isEn ? 'Choose the level of help you need right now.' : 'Vyberte si mieru pomoci, ktorú práve potrebujete.'}</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">{pageData.sectionDesc3}</p>
        </div>

        <div class="grid gap-8 lg:grid-cols-3">
          {servicePackages.map((pkg: any, index: number) => (
            <Card className={`relative border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1} ${pkg.recommended ? 'ring-2 ring-cta/60' : ''}`}>
              <CardHeader>
                <div class="mb-4 flex items-center justify-between gap-3">
                  <Badge variant={pkg.recommended ? 'cta' : 'secondary'}>{pkg.recommended ? pageData.recommendedLabel : (isEn ? 'Package' : 'Balík')}</Badge>
                  <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary/70">{pkg.price}</p>
                </div>
                <CardTitle className="font-display text-3xl">{pkg.name}</CardTitle>
                <CardDescription className="pt-3 text-base leading-7">{pkg.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul class="space-y-3">
                  {pkg.features.map((feature: string) => (
                    <li class="flex items-start gap-3 text-sm leading-6 text-muted-foreground">
                      <Badge variant="success" className="mt-0.5 px-2 py-0.5">{isEn ? 'included' : 'v cene'}</Badge>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <Button asChild variant={pkg.recommended ? 'cta' : 'outline'} className="mt-8 w-full">
                  <a href={isEn ? BOOKING_PAGE_HREF_EN : BOOKING_PAGE_HREF}>{isEn ? 'Explore options' : 'Chcem prejsť možnosti'}</a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="photo-card">
            <img src={IMAGE_ASSETS.graphics} alt="Graphic items from MagicRoom" class="w-full rounded-[24px] bg-surface object-contain" loading="lazy" />
          </div>
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">{pageData.sectionTitle4}</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{pageData.sectionDesc4}</h2>
            <div class="mt-8 grid gap-4">
              {extraServices.map((item: any) => (
                <div class="rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                      <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
                      <p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
                    </div>
                    <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">
                      <CheckCircle2 className="h-4 w-4" />{item.price}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <FooterComponent />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>