---
import FormalDressesTemplate from '@/components/templates/FormalDressesTemplate.astro';
import { DEFAULT_LANGUAGE } from '@/lib/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { skSlug: 'spolocenske-saty' } },
    { params: { lang: 'en' }, props: { skSlug: 'spolocenske-saty' } },
  ];
}

const { lang } = Astro.params;
const { skSlug } = Astro.props;
const language = lang === 'en' ? 'en' : DEFAULT_LANGUAGE;
---

<FormalDressesTemplate language={language} skSlug={skSlug} />
