---
import type { Language } from '@/lib/i18n';
import AboutTemplate from '@/components/templates/AboutTemplate.astro';
import ServicesTemplate from '@/components/templates/ServicesTemplate.astro';
import DressesTemplate from '@/components/templates/DressesTemplate.astro';
import GalleryTemplate from '@/components/templates/GalleryTemplate.astro';
import ConsignmentTemplate from '@/components/templates/ConsignmentTemplate.astro';
import DecorationsTemplate from '@/components/templates/DecorationsTemplate.astro';
import PartnersTemplate from '@/components/templates/PartnersTemplate.astro';
import ContactTemplate from '@/components/templates/ContactTemplate.astro';
import BlogIndexTemplate from '@/components/templates/BlogIndexTemplate.astro';
import BlogPostTemplate from '@/components/templates/BlogPostTemplate.astro';

const TEMPLATES = {
  about: AboutTemplate,
  services: ServicesTemplate,
  dresses: DressesTemplate,
  gallery: GalleryTemplate,
  consignment: ConsignmentTemplate,
  decorations: DecorationsTemplate,
  partners: PartnersTemplate,
  contact: ContactTemplate,
};

export async function getStaticPaths() {
  const pageSlugs = [
    { sk: 'o-nas', en: 'about', template: 'about' },
    { sk: 'sluzby', en: 'services', template: 'services' },
    { sk: 'svadobne-saty', en: 'dresses', template: 'dresses' },
    { sk: 'galeria', en: 'galeria', template: 'gallery' },
    { sk: 'komisny-predaj', en: 'consignment', template: 'consignment' },
    { sk: 'prenajom-dekoracii', en: 'decorations', template: 'decorations' },
    { sk: 'partneri', en: 'partners', template: 'partners' },
    { sk: 'kontakt', en: 'contact', template: 'contact' },
  ];
  
  const paths = [];
  
  // Main pages (both SK and EN)
  for (const page of pageSlugs) {
    paths.push({ params: { lang: 'sk', rest: page.sk }, props: { template: page.template, skSlug: page.sk } });
    paths.push({ params: { lang: 'en', rest: page.en }, props: { template: page.template, skSlug: page.sk } });
  }
  
  // Blog index
  paths.push({ params: { lang: 'sk', rest: 'blog' }, props: { type: 'index' } });
  paths.push({ params: { lang: 'en', rest: 'blog' }, props: { type: 'index' } });

  // Blog posts
  const posts = [
    { sk: 'svadobne-trendy-2026', en: 'wedding-trends-2026' },
    { sk: 'ako-zvolit-svadobne-saty', en: 'wedding-dresses-how-to-choose' },
    { sk: 'svadobne-dekoracie-na-male-oslavy', en: 'wedding-decorations-small-celebrations' },
  ];

  for (const post of posts) {
    paths.push({ params: { lang: 'sk', rest: `blog/${post.sk}` }, props: { type: 'post', skSlug: post.sk } });
    paths.push({ params: { lang: 'en', rest: `blog/${post.en}` }, props: { type: 'post', skSlug: post.sk } });
  }

  return paths;
}

const { lang, rest } = Astro.params;
const language = lang as Language;
const props = Astro.props;
const { template, type, skSlug: blogSkSlug } = props;
const skSlug = props.skSlug || rest;
---

{type === 'index' ? (
  <BlogIndexTemplate language={language} />
) : type === 'post' ? (
  <BlogPostTemplate language={language} skSlug={blogSkSlug} />
) : (
  (() => {
    const Component = TEMPLATES[template as keyof typeof TEMPLATES];
    return <Component language={language} skSlug={skSlug} />;
  })()
)}
