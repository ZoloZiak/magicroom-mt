---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { readFile } from 'fs/promises';
import { join } from 'path';

// Read partners data
const partnersPath = join(process.cwd(), 'content/json/partners.json');
let partners = { sk: { partners: [] }, en: { partners: [] }, categories: { sk: [], en: [] } };

try {
  const content = await readFile(partnersPath, 'utf-8');
  partners = JSON.parse(content);
} catch (e) {
  // File doesn't exist
}
---

<AdminLayout title="Partneri">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">🤝 Partneri</h1>
  </div>

  <form method="POST" action="/api/admin/save-partners" class="space-y-6">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Slovak (SK)</h2>
      
      <div class="space-y-4">
        {partners.sk.partners.map((partner: any, i: number) => (
          <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Názov</label>
                <input type="text" name={`sk_partners[${i}][name]`} value={partner.name || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Kategoria</label>
                <input type="text" name={`sk_partners[${i}][category]`} value={partner.category || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Popis</label>
                <textarea name={`sk_partners[${i}][description]`} rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg">{partner.description || ''}</textarea>
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Odkaz</label>
                <input type="url" name={`sk_partners[${i}][link]`} value={partner.link || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">English (EN)</h2>
      
      <div class="space-y-4">
        {partners.en.partners.map((partner: any, i: number) => (
          <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text" name={`en_partners[${i}][name]`} value={partner.name || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                <input type="text" name={`en_partners[${i}][category]`} value={partner.category || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea name={`en_partners[${i}][description]`} rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg">{partner.description || ''}</textarea>
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Link</label>
                <input type="url" name={`en_partners[${i}][link]`} value={partner.link || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button type="submit" class="w-full bg-pink-600 text-white py-3 px-6 rounded-lg font-medium hover:bg-pink-700 transition-colors">
      💾 Uložiť zmeny
    </button>
  </form>
</AdminLayout>
