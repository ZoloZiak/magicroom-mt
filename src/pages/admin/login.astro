export const prerender = false;
---
interface Props {
  error?: string;
}

const { error } = Astro.props;
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Login — MagicRoom</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen bg-gradient-to-br from-pink-50 via-white to-purple-50 flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-pink-400 to-purple-500 flex items-center justify-center text-white font-bold text-2xl mx-auto mb-4 shadow-xl">
          M
        </div>
        <h1 class="font-display text-3xl font-bold text-gray-900">MagicRoom</h1>
        <p class="text-pink-600 mt-1">Admin Panel</p>
      </div>

      <!-- Login Card -->
      <div class="bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/50 p-8">
        <h2 class="text-xl font-semibold text-gray-900 text-center mb-6">Prihlásenie</h2>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-2xl text-red-700 text-sm flex items-center gap-3">
            <span class="text-xl">⚠️</span>
            {error}
          </div>
        )}

        <form method="POST" action="/api/admin/login" class="space-y-6">
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              Heslo
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-pink-500 focus:border-pink-500 focus:bg-white transition-all"
              placeholder="Zadajte heslo"
            >
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-pink-500 to-purple-500 text-white py-3 px-6 rounded-2xl font-medium hover:from-pink-600 hover:to-purple-600 transition-all shadow-lg hover:shadow-xl transform hover:scale-[1.02]"
          >
            Prihlásiť →
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href="/" class="text-sm text-gray-500 hover:text-pink-600 transition-colors">
            ← Späť na stránku
          </a>
        </div>
      </div>

      <!-- Decorative elements -->
      <div class="absolute top-10 left-10 w-32 h-32 bg-pink-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
      <div class="absolute bottom-10 right-10 w-32 h-32 bg-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
    </div>
  </body>
</html>

<style is:global>
  @import '/src/styles/global.css';
</style>
