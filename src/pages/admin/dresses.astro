---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { readFile } from 'fs/promises';
import { join } from 'path';

// Read dresses data
const dressesPath = join(process.cwd(), 'content/json/dresses.json');
let dresses = { dresses: [] };

try {
  const content = await readFile(dressesPath, 'utf-8');
  dresses = JSON.parse(content);
} catch (e) {
  // File doesn't exist
}
---

<AdminLayout title="Šaty">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">👗 Svadobné šaty</h1>
  </div>

  <form method="POST" action="/api/admin/save-dresses" class="space-y-6">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Zoznam šiat</h2>
      
      <div class="space-y-4">
        {dresses.dresses.map((dress: any, i: number) => (
          <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
            <input type="hidden" name={`dresses[${i}][id]`} value={dress.id} />
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Názov</label>
                <input type="text" name={`dresses[${i}][name]`} value={dress.name || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Cena (€)</label>
                <input type="number" name={`dresses[${i}][price]`} value={dress.price || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Veľkosť</label>
                <input type="text" name={`dresses[${i}][size]`} value={dress.size || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Farba</label>
                <input type="text" name={`dresses[${i}][color]`} value={dress.color || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Štýl</label>
                <input type="text" name={`dresses[${i}][style]`} value={dress.style || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Stav</label>
                <select name={`dresses[${i}][status]`} class="w-full px-3 py-2 border border-gray-300 rounded-lg">
                  <option value="available" selected={dress.status === 'available'}>Dostupné</option>
                  <option value="reserved" selected={dress.status === 'reserved'}>Rezervované</option>
                </select>
              </div>
              <div class="md:col-span-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Popis</label>
                <textarea name={`dresses[${i}][description]`} rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg">{dress.description || ''}</textarea>
              </div>
              <div class="md:col-span-3">
                <label class="block text-sm font-medium text-gray-700 mb-1">Detaily</label>
                <input type="text" name={`dresses[${i}][details]`} value={dress.details || ''} class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
              </div>
            </div>
            <p class="text-xs text-gray-500 mt-2">ID: {dress.id}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h3 class="font-medium text-blue-900 mb-2">ℹ️ Nahrávanie obrázkov</h3>
      <p class="text-sm text-blue-700">Obrázky šiat nahrajte do <code class="bg-blue-100 px-2 py-1 rounded">public/images/dresses/</code></p>
    </div>

    <button type="submit" class="w-full bg-pink-600 text-white py-3 px-6 rounded-lg font-medium hover:bg-pink-700 transition-colors">
      💾 Uložiť zmeny
    </button>
  </form>
</AdminLayout>
