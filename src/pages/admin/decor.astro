export const prerender = false;
---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { readFile } from 'fs/promises';
import { join } from 'path';

const decorPath = join(process.cwd(), 'content/json/decor.json');
let decor = { sk: { categories: [], policies: [] }, en: { categories: [], policies: [] } };

try {
  const content = await readFile(decorPath, 'utf-8');
  decor = JSON.parse(content);
} catch (e) {
  // File doesn't exist
}

const allItems = decor.sk.categories?.flatMap((cat: any) => cat.items) || [];
const featuredCount = allItems.filter((item: any) => item.starred).length;
---

<AdminLayout title="Dekorácie">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">🎀 Dekorácie</h1>
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-500">{featuredCount} vybraných</span>
      <button type="button" onclick="saveChanges()" class="bg-pink-500 text-white px-6 py-3 rounded-2xl font-medium hover:shadow-lg transition-all">
        💾 Uložiť zmeny
      </button>
    </div>
  </div>

  <!-- Categories -->
  <div class="space-y-6">
    {decor.sk.categories?.map((category: any, catIdx: number) => (
      <div class="bg-white rounded-3xl shadow-xl border border-pink-100 overflow-hidden">
        <div class="bg-pink-500 px-6 py-4">
          <h2 class="text-lg font-semibold text-white">{category.category}</h2>
        </div>
        <div class="p-6">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-3 text-sm font-medium text-gray-500">⭐</th>
                <th class="text-left py-3 text-sm font-medium text-gray-500">Názov</th>
                <th class="text-right py-3 text-sm font-medium text-gray-500">Cena</th>
              </tr>
            </thead>
            <tbody>
              {category.items?.map((item: any, itemIdx: number) => (
                <tr class="border-b border-gray-100 hover:bg-pink-50/30 transition-colors">
                  <td class="py-3">
                    <button 
                      type="button" 
                      onclick={`toggleStar(${catIdx}, ${itemIdx})`}
                      class={`text-2xl transition-transform hover:scale-125 ${item.starred ? 'text-yellow-400' : 'text-gray-300'}`}
                      title={item.starred ? 'Odstrániť z vybraných' : 'Pridať medzi vybrané'}
                    >
                      {item.starred ? '⭐' : '☆'}
                    </button>
                  </td>
                  <td class="py-3 text-gray-900">{item.name}</td>
                  <td class="py-3 text-right font-medium text-pink-600">{item.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>

  <!-- Empty state -->
  {(!decor.sk.categories || decor.sk.categories.length === 0) && (
    <div class="text-center py-12">
      <div class="text-6xl mb-4">🎀</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">Žiadne dekorácie</h3>
      <p class="text-gray-500">Pridajte inventár do prenájmu</p>
    </div>
  )}
</AdminLayout>

<script define:vars={{ decorData: decor }}>
  const decor = decorData;

  window.toggleStar = function(catIdx, itemIdx) {
    const item = decor.sk.categories[catIdx].items[itemIdx];
    item.starred = !item.starred;
    window.showToast(item.starred ? 'Pridané medzi vybrané!' : 'Odstránené z vybraných');
  };

  window.saveChanges = async function() {
    try {
      const response = await fetch('/api/admin/save-decor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(decor)
      });
      
      const result = await response.json();
      if (result.success) {
        window.showToast('Zmeny uložené!');
      } else {
        window.showToast(result.error || 'Chyba pri ukladaní', 'error');
      }
    } catch (err) {
      window.showToast('Chyba pri ukladaní', 'error');
    }
  };
</script>
