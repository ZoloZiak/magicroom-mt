---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, Calendar, Clock } from 'lucide-react';

const BLOG_POSTS = [
  {
    slug: 'svadobne-trendy-2026',
    title: 'Svadobné trendy 2026: Čo bude v móde?',
    excerpt: 'Objavte najnovšie trendy v svadobnej móde pre rok 2026. Od farieb po štýly — všetko, čo potrebujete vedieť.',
    image: IMAGE_ASSETS.dresses,
    date: '2026-04-01',
    readTime: '5 min čítania',
    tags: ['trendy', 'šaty', '2026'],
  },
  {
    slug: 'ako-zvolit-svadobne-saty',
    title: 'Ako si vybrať svadobné šaty: Praktický sprievodca',
    excerpt: 'Krok za krokom vás prevedieme výberom ideálnych svadobných šiat. Od rozpočtu po štýl a pohodlie.',
    image: IMAGE_ASSETS.founder,
    date: '2026-03-15',
    readTime: '7 min čítania',
    tags: ['šaty', 'výber', 'poradenstvo'],
  },
  {
    slug: 'svadobne-dekoracie-na-male-oslavy',
    title: 'Svadobné dekorácie pre malé oslavy do 50 hostí',
    excerpt: 'Inšpirácie a tipy na dekorácie pre intimné svadby. Ako vytvoriť romantickú atmosféru bez zbytočných výdavkov.',
    image: IMAGE_ASSETS.decorMain,
    date: '2026-02-28',
    readTime: '6 min čítania',
    tags: ['dekorácie', 'malé svadby', 'inšpirácie'],
  },
] as const;
---

<Layout
  title="Svadobný blog MagicRoom — Tipy, inšpirácie a trendy"
  description="Čítajte naše články o svadobných šatách, dekoráciách, poradenstve a najnovších trendov. Praktické rady od Natálie z MagicRoom v Martine."
  keywords="svadobný blog, tipy, trendy, inšpirácie, svadobné šaty, dekorácie"
  image={IMAGE_ASSETS.hero}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Blog', url: '/blog' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-12 text-center">
          <Badge variant="secondary" className="mb-4 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Svadobný blog
          </Badge>
          <h1 class="font-display text-4xl text-foreground md:text-5xl">
            Tipy, inšpirácie a trendy pre vašu svadbu
          </h1>
          <p class="mt-4 max-w-2xl mx-auto text-base leading-7 text-muted-foreground">
            Praktické rady, najnovšie trendy a osobné skúsenosti z organizácie svadieb. Všetko, čo potrebujete vedieť o šatách, dekoráciách a svadobnom poradenstve.
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {BLOG_POSTS.map((post) => (
            <Card className="blog-card border-0 bg-white shadow-[0_20px_60px_rgba(74,46,58,0.08)] spring-hover">
              <div class="overflow-hidden rounded-t-xl">
                <img
                  src={post.image}
                  alt={post.title}
                  class="h-48 w-full object-cover transition-transform duration-300 hover:scale-105"
                />
              </div>
              <CardHeader>
                <div class="flex items-center gap-2 text-sm text-muted-foreground mb-2">
                  <Calendar className="h-4 w-4" />
                  <span>{new Date(post.date).toLocaleDateString('sk-SK')}</span>
                  <Clock className="h-4 w-4 ml-2" />
                  <span>{post.readTime}</span>
                </div>
                <CardTitle className="font-display text-xl line-clamp-2">{post.title}</CardTitle>
                <CardDescription className="line-clamp-3">{post.excerpt}</CardDescription>
              </CardHeader>
              <CardContent>
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.tags.map((tag) => (
                    <Badge variant="outline" className="text-xs">{tag}</Badge>
                  ))}
                </div>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={`/blog/${post.slug}`}>
                    Čítať článok
                    <ArrowRight className="h-4 w-4 ml-2" />
                  </a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>