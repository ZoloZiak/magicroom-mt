---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF, PHONE_HREF, PHONE_DISPLAY } from '@/data/site';
import { IMAGE_ASSETS, IMAGE_URLS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, Calendar, Clock, Phone } from 'lucide-react';

const RELATED_POSTS = [
  {
    slug: 'ako-zvolit-svadobne-saty',
    title: 'Ako si vybrať svadobné šaty',
    excerpt: 'Krok za krokom vás prevedieme výberom ideálnych svadobných šiat.',
    image: IMAGE_ASSETS.founder,
  },
  {
    slug: 'svadobne-dekoracie-na-male-oslavy',
    title: 'Dekorácie pre malé oslavy',
    excerpt: 'Inšpirácie na romantickú výzdobu bez zbytočných výdavkov.',
    image: IMAGE_ASSETS.decorMain,
  },
];
---

<Layout
  title="Svadobné trendy 2026: Čo bude v móde? | MagicRoom Blog"
  description="Objavte najnovšie trendy v svadobnej móde pre rok 2026. Od farieb po štýly — všetko, čo potrebujete vedieť pre svoju svadbu."
  keywords="svadobné trendy 2026, móda, šaty, farby, štýly, svadba"
  type="article"
  image={IMAGE_ASSETS.dresses}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'Svadobné trendy 2026: Čo bude v móde?',
    image: IMAGE_ASSETS.dresses,
    datePublished: '2026-04-01',
    author: {
      '@type': 'Person',
      name: 'Natália Ondrejková',
    },
  }}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: 'Svadobné trendy 2026', url: '/blog/svadobne-trendy-2026' },
  ]}
>
  <Header />

  <main class="flex-1">
    <article class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-8">
          <Badge variant="secondary" className="mb-4 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Blog • Trendy
          </Badge>
          <h1 class="font-display text-4xl text-foreground md:text-5xl">
            Svadobné trendy 2026: Čo bude v móde?
          </h1>
          <div class="mt-4 flex items-center gap-4 text-muted-foreground">
            <div class="flex items-center gap-2">
              <Calendar className="h-4 w-4" />
              <span>1. apríla 2026</span>
            </div>
            <div class="flex items-center gap-2">
              <Clock className="h-4 w-4" />
              <span>5 min čítania</span>
            </div>
          </div>
        </div>

        <div class="prose prose-lg max-w-none">
          <p class="article-element">
            Rok 2026 prináša nové trendy v svadobnej móde, ktoré kombinujú klasiku s modernými prvkami.
            Ak plánujete svadbu, je dobré vedieť, čo bude v kurze.
          </p>

          <h2 class="article-element">Kľúčové farby roka 2026</h2>
          <p class="article-element">
            Dominujú jemné, prírodné tóny: champagne, ivory a mäkké ružové odtiene.
            Odchádzajú čisto biele svadby — nahrádzajú ich teplé, živé farby.
          </p>

          <h2 class="article-element">Štýly a siluety</h2>
          <p class="article-element">
            Populárne sú šaty s asymetrickými detailmi, šifónovými vrstvami a minimalistickými aplikáciami.
            Dĺžky midi a tea-length sú stále v móde pre menej formálne svadby.
          </p>

          <img src={IMAGE_URLS.dresses} alt="Svadobné trendy 2026" class="article-element rounded-2xl my-8" />

          <h2 class="article-element">Doplnky a účesy</h2>
          <p class="article-element">
            Malé klobúčiky, živé kvety a prírodné vlny nahrádzajú tradičné závoja.
            Šperky sú minimalistické s prírodnými kamienkami.
          </p>
        </div>

        <div class="mt-12 rounded-2xl border border-border/70 bg-white p-6 md:p-8">
          <h3 class="font-display text-2xl mb-4">Máte otázky o šatách?</h3>
          <p class="text-muted-foreground mb-6">
            V MagicRoom vám pomôžeme nájsť šaty, ktoré vyjadrujú vašu osobnosť.
            Rezervujte si skúšku už dnes.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row">
            <Button asChild variant="cta" size="lg">
              <a href={BOOKING_PAGE_HREF}>
                Zarezervovať skúšku
                <ArrowRight className="h-4 w-4 ml-2" />
              </a>
            </Button>
            <Button asChild variant="outline" size="lg">
              <a href={PHONE_HREF}>
                <Phone className="h-4 w-4 mr-2" />
                {PHONE_DISPLAY}
              </a>
            </Button>
          </div>
        </div>

        <div class="mt-12">
          <h3 class="font-display text-2xl mb-6">Súvisiace články</h3>
          <div class="grid gap-6 md:grid-cols-2">
            {RELATED_POSTS.map((post) => (
              <Card className="border-0 bg-white shadow-[var(--shadow-soft)] spring-hover">
                <div class="overflow-hidden rounded-t-xl">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-32 w-full object-cover transition-transform duration-300 hover:scale-105"
                  />
                </div>
                <CardHeader>
                  <CardTitle className="font-display text-lg line-clamp-2">{post.title}</CardTitle>
                  <CardDescription className="line-clamp-2">{post.excerpt}</CardDescription>
                </CardHeader>
                <CardContent>
                  <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                    <a href={`/blog/${post.slug}`}>
                      Čítať článok
                      <ArrowRight className="h-4 w-4 ml-2" />
                    </a>
                  </Button>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>