---
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { EMAIL, EMAIL_HREF, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { CONSIGNMENT_BENEFITS, CONSIGNMENT_CONDITIONS, CONSIGNMENT_STEPS, IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, Mail, Phone } from 'lucide-react';
---

<Layout
  title="Komisný predaj svadobných šiat v Martine — MagicRoom"
  description="Podmienky komisného predaja svadobných šiat v MagicRoom v Martine. Férové pravidlá, osobná dohoda a vyplácanie do 7 dní. Aktuálne plná kapacita."
  keywords="komisný predaj šiat, predaj svadobných šiat, martin, podmienky"
  image={IMAGE_ASSETS.dresses}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Komisný predaj', url: '/komisny-predaj' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="destructive" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              Momentálne plná kapacita
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl">
              Máte šaty po svadbe a chcete im dať ďalší život?
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">
              Komisný predaj v MagicRoom je postavený na férových pravidlách a osobnej dohode. Aktuálne však nové šaty neprijímame, aby sme udržali kvalitu starostlivosti o tie, ktoré už v salóne máme.
            </p>

            <div class="mt-8 rounded-[28px] border border-destructive/20 bg-destructive/5 p-6">
              <h2 class="text-2xl font-display text-foreground">Chcete vedieť, kedy sa miesto uvoľní?</h2>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                Pošlite nám email alebo krátku správu s fotografiou šiat. Keď budeme opäť prijímať nové kúsky, ozveme sa vám medzi prvými.
              </p>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                <Button asChild variant="cta">
                  <a href={EMAIL_HREF}>
                    <Mail className="h-4 w-4" />
                    Napísať email
                  </a>
                </Button>
                <Button asChild variant="outline">
                  <a href={PHONE_HREF}>
                    <Phone className="h-4 w-4" />
                    {PHONE_DISPLAY}
                  </a>
                </Button>
              </div>
            </div>
          </div>

          <div class="overflow-hidden rounded-[32px] border border-white/60 bg-white p-3 shadow-[0_26px_80px_rgba(194,16,110,0.1)]">
            <img
              src={IMAGE_ASSETS.dresses}
              alt="Svadobné šaty pripravené v salóne MagicRoom."
              class="max-h-[560px] w-full rounded-[24px] bg-surface object-contain"
            />
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Ako komisný predaj funguje</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Keď kapacita nie je plná, proces je jednoduchý a transparentný.</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {CONSIGNMENT_STEPS.map((step, index) => (
            <Card className={`border-0 bg-white shadow-[0_20px_60px_rgba(194,16,110,0.08)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-sm font-semibold text-primary-foreground">
                  0{index + 1}
                </div>
                <CardTitle className="font-display text-2xl">Krok {index + 1}</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm leading-6 text-muted-foreground">{step}</p>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Podmienky zaradenia</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Pravidlá, vďaka ktorým ostáva predaj férový pre obe strany.</h2>
            <div class="mt-8 grid gap-4">
              {CONSIGNMENT_CONDITIONS.map((item) => (
                <div class="rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
                </div>
              ))}
            </div>
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Prečo to nevesty zvažujú</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Predaj bez inzercie, dohadovania a straty času.</h2>
            <div class="mt-8 grid gap-4">
              {CONSIGNMENT_BENEFITS.map((item) => (
                <div class="flex gap-4 rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="mt-1 rounded-full bg-success/15 p-2 text-success">
                    <CheckCircle2 className="h-4 w-4" />
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground">{item}</p>
                </div>
              ))}
            </div>

            <div class="mt-8 rounded-[28px] border border-primary/10 bg-primary-900 p-6 text-white shadow-[0_24px_70px_rgba(194,16,110,0.14)]">
              <p class="text-sm uppercase tracking-[0.2em] text-white/70">Aktuálny stav</p>
              <h3 class="mt-3 font-display text-3xl">Plná kapacita prijatých šiat</h3>
              <p class="mt-3 text-sm leading-6 text-white/75">
                Najlepší ďalší krok je napísať na {EMAIL}. Keď budeme mať priestor prijať ďalšie modely, ozveme sa vám a prejdeme spolu fotografie aj stav šiat.
              </p>
              <p class="mt-3 text-sm leading-6 text-white/75">
                Ak popri tom riešite aj šaty na skúšku alebo ďalšie služby v Martine, pozrite si
                <a href="/sluzby" class="font-semibold text-white underline underline-offset-4"> služby MagicRoom</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4 text-center">
        <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Kontakt pre čakačku</p>
        <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Pošlite nám základné info a ozveme sa, keď sa uvoľní miesto.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-muted-foreground">
          Stačí fotka šiat, veľkosť a vaša predstava o cene. Nemusíte si pamätať celý proces — keď sa otvorí kapacita, všetko si prejdeme spolu.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center">
          <Button asChild variant="cta" size="lg">
            <a href={EMAIL_HREF}>
              Napísať na {EMAIL}
              <ArrowRight className="h-5 w-5" />
            </a>
          </Button>
          <Button asChild variant="outline" size="lg">
            <a href={PHONE_HREF}>
              <Phone className="h-5 w-5" />
              {PHONE_DISPLAY}
            </a>
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>