---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { DECOR_CATEGORIES, DECOR_FEATURED, DECOR_POLICIES, IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, Frame, Gift, Lamp, Phone, Sparkles, UtensilsCrossed } from 'lucide-react';
---

<Layout
  title="Prenájom svadobných dekorácií — Zrkadlá, vázy, kulisy | MagicRoom Martin"
  description="Prenájom svadobných dekorácií v Martine od 0,50 €: zrkadlá, vázy, svietniky, kulisy, candy bar a textílie s jasnými cenami a podmienkami."
  keywords="prenájom dekorácií, svadobné dekorácie, vázy, zrkadlá, kulisy, martin"
  image={IMAGE_ASSETS.decorMain}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Dekorácie', url: '/prenajom-dekoracii' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              Prenájom dekorácií • Martin
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl">
              Dekorácie, ktoré doladia priestor bez potreby nakupovať všetko nanovo.
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">
              MagicRoom požičiava kúsky, ktoré hostine dodajú štýl a zároveň ostanú praktické na prevoz aj skladanie — od uvítacieho zrkadla po candy bar doplnky.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg">
                <a href={BOOKING_PAGE_HREF}>
                  Napísať o dostupnosť
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={PHONE_HREF}>Zavolať: {PHONE_DISPLAY}</a>
              </Button>
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-[0_24px_70px_rgba(74,46,58,0.1)] sm:col-span-2">
              <img
                src={IMAGE_ASSETS.decorMain}
                alt="Dekorácie pripravené na svadobnú hostinu od MagicRoom."
                class="max-h-[420px] w-full rounded-[22px] bg-surface object-contain"
              />
            </div>
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-sm">
              <img
                src={IMAGE_ASSETS.decorAlt}
                alt="Svadobný stôl s prenajatými dekoráciami MagicRoom."
                class="h-[280px] w-full rounded-[22px] bg-surface object-contain"
                loading="lazy"
              />
            </div>
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-sm">
              <img
                src={IMAGE_ASSETS.decorBackdrop}
                alt="Svadobná kulisa so závesmi a svetielkami z ponuky MagicRoom."
                class="h-[280px] w-full rounded-[22px] bg-surface object-contain"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Najžiadanejšie kúsky</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Štartovacia zostava, po ktorej sa nevesty pýtajú najčastejšie.</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            Ak si ešte len skladáte predstavu, začnite týmito kúskami. Dajú sa kombinovať s vlastnou floristkou aj s jednoduchou civilnou hostinou.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {DECOR_FEATURED.map((item, index) => {
            const IconComponent = item.icon === 'frame' ? Frame
              : item.icon === 'utensils' ? UtensilsCrossed
              : item.icon === 'lamp' ? Lamp
              : Gift;
            return (
            <Card className={`border-0 bg-white shadow-[0_20px_60px_rgba(74,46,58,0.08)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <IconComponent className="h-5 w-5" />
                </div>
                <CardTitle className="font-display text-2xl leading-tight">{item.title}</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
              </CardContent>
            </Card>
            );
          })}
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Katalóg dekorácií</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Cenník rozdelený podľa toho, čo sa rieši spolu.</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            Ceny sú orientačné za prenájom položky. Pri väčšej objednávke alebo kombinácii viacerých kategórií vám všetko prejdeme spolu a pripravíme dostupnosť.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {DECOR_CATEGORIES.map((group) => (
            <Card className="border-0 bg-white shadow-[0_24px_80px_rgba(74,46,58,0.08)]">
              <CardHeader>
                <CardTitle className="font-display text-3xl">{group.category}</CardTitle>
              </CardHeader>
              <CardContent>
                <div class="space-y-3">
                  {group.items.map((item) => (
                    <div class="flex items-start justify-between gap-4 rounded-2xl bg-surface px-4 py-4">
                      <p class="text-sm leading-6 text-foreground">{item.name}</p>
                      <span class="shrink-0 text-sm font-semibold uppercase tracking-[0.12em] text-cta">{item.price}</span>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
          <div class="overflow-hidden rounded-[32px] border border-white/60 bg-white p-3 shadow-[0_24px_70px_rgba(74,46,58,0.1)]">
            <img
              src={IMAGE_ASSETS.decorDetails}
              alt="Detail dekorácií a doplnkov na výzdobu z ponuky MagicRoom."
              class="w-full rounded-[24px] bg-surface object-contain"
              loading="lazy"
            />
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Dôležité informácie</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Prenájom má byť praktický, nie nejasný.</h2>
            <div class="mt-8 grid gap-4">
              {DECOR_POLICIES.map((item) => (
                <div class="flex gap-4 rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="mt-1 rounded-full bg-success/15 p-2 text-success">
                    <CheckCircle2 className="h-4 w-4" />
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground">{item}</p>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm leading-6 text-muted-foreground">
              Ak chcete dekorácie rovno spojiť so šatami alebo konzultáciou, pozrite si aj
              <a href="/sluzby" class="font-semibold text-primary underline-offset-4 hover:underline"> služby a cenník</a>
              alebo prejdite priamo na
              <a href="/kontakt" class="font-semibold text-primary underline-offset-4 hover:underline"> kontakt a dopyt</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-primary-900 py-16 text-white md:py-20">
      <div class="container mx-auto px-4 text-center">
        <p class="text-sm uppercase tracking-[0.24em] text-white/70">Ďalší krok</p>
        <h2 class="mt-3 font-display text-4xl md:text-5xl">Napíšte nám, čo chcete doladiť pri výzdobe.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/75">
          Stačí niekoľko položiek alebo typ hostiny. Podľa toho vám povieme, čo je aktuálne voľné a čo bude najlepšie fungovať spolu.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center">
          <Button asChild size="lg" className="bg-white text-primary-900 hover:bg-white/90">
            <a href={BOOKING_PAGE_HREF}>
              Poslať dopyt
              <ArrowRight className="h-5 w-5" />
            </a>
          </Button>
          <Button asChild variant="outline" size="lg" className="border-white text-white hover:bg-white/10">
            <a href={PHONE_HREF}>
              <Phone className="h-5 w-5" />
              {PHONE_DISPLAY}
            </a>
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>