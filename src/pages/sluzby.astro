---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { EXTRA_SERVICES, IMAGE_ASSETS, SERVICE_PACKAGES } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, ClipboardList, LayoutGrid, Phone, Shirt, Sparkles } from 'lucide-react';

const servicePillars = [
  {
    title: 'Skúška svadobných šiat',
    price: '12 € / 60 min',
    description: 'Pokojná skúška s nápojom v cene, priestorom pre dve blízke osoby a časom porovnať si viac modelov bez stresu.',
    cta: 'Rezervovať skúšku',
    href: BOOKING_PAGE_HREF,
    icon: Shirt,
  },
  {
    title: 'Predaj a výber šiat',
    price: 'od 100 €',
    description: 'Nové modely, dostupné kúsky aj komisný výber pre ženy, ktoré chcú dobrý pocit aj z rozpočtu.',
    cta: 'Napísať o výber',
    href: BOOKING_PAGE_HREF,
    icon: Sparkles,
  },
  {
    title: 'Prenájom dekorácií',
    price: 'od 0,50 € / ks',
    description: 'Zrkadlá, vázy, svietniky, kulisy aj candy bar doplnky tak, aby ste vedeli zladiť hostinu bez chaosu.',
    cta: 'Pozrieť dekorácie',
    href: '/prenajom-dekoracii',
    icon: LayoutGrid,
  },
  {
    title: 'Svadobné poradenstvo',
    price: 'od 40 €',
    description: 'Konzultácie, moodboard, harmonogram aj odporúčania dodávateľov podľa toho, koľko pomoci naozaj potrebujete.',
    cta: 'Pozrieť balíky',
    href: '#baliky',
    icon: ClipboardList,
  },
] as const;
---

<Layout
  title="Služby a cenník — Svadobné šaty, dekorácie, poradenstvo | MagicRoom Martin"
  description="Skúška svadobných šiat od 12 €, prenájom dekorácií, svadobné poradenstvo a balíky organizácie svadby v MagicRoom v Martine s jasnými cenami."
  keywords="svadobne sluzby, ceny, balíky, konzultácie, organizácia svadby"
  image={IMAGE_ASSETS.dresses}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Služby a cenník', url: '/sluzby' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              Služby • cenník • Martin
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl animate-fade-in-up animate-stagger-2">
              Jasná ponuka pre nevestu, ktorá chce všetko vyriešiť s pokojom.
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground animate-fade-in-up animate-stagger-3">
              V MagicRoom nezačínate dlhým zoznamom povinností. Začínate službou, ktorá vám dáva zmysel teraz — skúškou šiat, dekoráciami alebo plánovaním svadby krok po kroku.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row animate-fade-in-up animate-stagger-4">
              <Button asChild variant="cta" size="lg">
                <a href={BOOKING_PAGE_HREF}>
                  Zarezervovať skúšku
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={PHONE_HREF}>Zavolať: {PHONE_DISPLAY}</a>
              </Button>
            </div>
          </div>

          <div class="grid gap-5">
            <div class="overflow-hidden rounded-[32px] border border-white/60 bg-white p-3 shadow-[0_26px_80px_rgba(45,36,33,0.1)]">
              <img
                src={IMAGE_ASSETS.dresses}
                alt="Svadobné šaty pripravené na skúšku v salóne MagicRoom."
                class="max-h-[520px] w-full rounded-[24px] bg-surface object-contain"
              />
            </div>
            <div class="rounded-[28px] border border-destructive/20 bg-destructive/5 p-6">
              <Badge variant="destructive">Komisný predaj: plná kapacita</Badge>
              <h2 class="mt-4 text-2xl font-display text-foreground">Momentálne neprijímame ďalšie šaty do komisného predaja.</h2>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                Ak chcete byť medzi prvými, keď sa miesto uvoľní, pozrite si podmienky a ozvite sa nám cez stránku komisného predaja.
              </p>
              <a href="/komisny-predaj" class="mt-4 inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                Pozrieť komisný predaj
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Čo u nás vybavíte</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Štyri služby, ktoré sa dajú spolu prirodzene prepájať.</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            Ak si prídete po šaty, viete rovno doriešiť dekorácie aj prvé plánovanie. A ak riešite len jednu vec, nemusíte platiť za nič navyše.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {servicePillars.map((item, index) => (
            <Card className={`border-0 bg-white shadow-[0_20px_60px_rgba(59,44,38,0.08)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <item.icon className="h-5 w-5" />
                </div>
                <CardTitle className="font-display text-2xl">{item.title}</CardTitle>
                <p class="pt-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
                <CardDescription className="pt-3 text-base leading-7">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={item.href}>
                    {item.cta}
                    <ArrowRight className="h-4 w-4" />
                  </a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>

        <p class="mt-8 max-w-2xl text-sm leading-6 text-muted-foreground">
          Ak už viete, že riešite najmä výzdobu, pozrite si
          <a href="/prenajom-dekoracii" class="font-semibold text-primary underline-offset-4 hover:underline"> prenájom dekorácií</a>.
          Ak chcete najprv spoznať spôsob práce MagicRoom, prejdite na
          <a href="/o-nas" class="font-semibold text-primary underline-offset-4 hover:underline"> stránku o nás</a>
          alebo rovno na
          <a href="/kontakt" class="font-semibold text-primary underline-offset-4 hover:underline"> kontakt a rezerváciu</a>.
        </p>
      </div>
    </section>

    <section id="baliky" class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Balíky organizácie svadby</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Vyberte si mieru pomoci, ktorú práve potrebujete.</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            Každý balík sa dá upraviť podľa veľkosti svadby, rozpočtu a toho, či potrebujete skôr smerovanie alebo kompletnú oporu pri prípravách.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-3">
          {SERVICE_PACKAGES.map((pkg, index) => (
            <Card className={`relative border-0 bg-white shadow-[0_24px_80px_rgba(45,36,33,0.08)] spring-hover animate-fade-in-up animate-stagger-${index + 1} ${pkg.recommended ? 'ring-2 ring-cta/60' : ''}`}>
              <CardHeader>
                <div class="mb-4 flex items-center justify-between gap-3">
                  <Badge variant={pkg.recommended ? 'cta' : 'secondary'}>
                    {pkg.recommended ? 'Najčastejšia voľba' : 'Balík'}
                  </Badge>
                  <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary/70">{pkg.price}</p>
                </div>
                <CardTitle className="font-display text-3xl">{pkg.name}</CardTitle>
                <CardDescription className="pt-3 text-base leading-7">{pkg.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul class="space-y-3">
                  {pkg.features.map((feature) => (
                    <li class="flex items-start gap-3 text-sm leading-6 text-muted-foreground">
                      <Badge variant="success" className="mt-0.5 px-2 py-0.5">v cene</Badge>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                <Button asChild variant={pkg.recommended ? 'cta' : 'outline'} className="mt-8 w-full">
                  <a href={BOOKING_PAGE_HREF}>Chcem prejsť možnosti</a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="overflow-hidden rounded-[32px] border border-white/60 bg-white p-3 shadow-[0_24px_70px_rgba(45,36,33,0.1)]">
            <img
              src={IMAGE_ASSETS.graphics}
              alt="Personalizované svadobné oznámenie a grafické doplnky od MagicRoom."
              class="w-full rounded-[24px] bg-surface object-contain"
              loading="lazy"
            />
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Doplnkové služby</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Malé položky, ktoré robia veľký pokoj v prípravách.</h2>
            <div class="mt-8 grid gap-4">
              {EXTRA_SERVICES.map((item) => (
                <div class="rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                      <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
                      <p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
                    </div>
                    <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">
                      <CheckCircle2 className="h-4 w-4" />
                      {item.price}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-primary-900 py-16 text-white md:py-20">
      <div class="container mx-auto px-4 text-center">
        <p class="text-sm uppercase tracking-[0.24em] text-white/70">Ďalší krok</p>
        <h2 class="mt-3 font-display text-4xl md:text-5xl">Povedzte nám, čo riešite ako prvé.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/75">
          Či už potrebujete len skúšku, alebo chcete prejsť šaty, dekorácie aj harmonogram naraz, dohodneme si formu, ktorá bude pre vás prirodzená.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center">
          <Button asChild size="lg" className="bg-white text-primary-900 hover:bg-white/90">
            <a href={BOOKING_PAGE_HREF}>
              Prejsť na rezerváciu
              <ArrowRight className="h-5 w-5" />
            </a>
          </Button>
          <Button asChild variant="outline" size="lg" className="border-white text-white hover:bg-white/10">
            <a href={PHONE_HREF}>
              <Phone className="h-5 w-5" />
              {PHONE_DISPLAY}
            </a>
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>