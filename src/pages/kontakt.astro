---
import BookingForm from '@/components/forms/BookingForm.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { ADDRESS_LABEL, PHONE_DISPLAY } from '@/data/site';
import { CONTACT_ACTIONS, CONTACT_FAQS, IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { Mail, MapPin, MessageCircle, Phone } from 'lucide-react';

const contactIcons = [Phone, MessageCircle, Mail, MapPin];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: CONTACT_FAQS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Kontakt a rezervácia skúšky šiat — MagicRoom Martin"
  description="Rezervujte si skúšku svadobných šiat od 12 € alebo svadobnú konzultáciu v MagicRoom v Martine. Telefón, WhatsApp, email, mapa a rezervačný formulár."
  keywords="kontakt, rezervácia, martin, telefón, email, whatsapp"
  image={IMAGE_ASSETS.map}
  structuredData={faqSchema}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Kontakt', url: '/kontakt' },
  ]}
>
  <Header />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Kontakt • rezervácia • Martin
          </Badge>
          <h1 class="font-display text-[2.85rem] leading-tight text-foreground md:text-6xl">Ozvite sa tak, ako vám je to prirodzené.</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Ak chcete skúšku šiat, dekorácie alebo pokojne prejsť svadobné detaily, vyberte si telefonát, WhatsApp, email alebo rovno formulár nižšie.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground">
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">Martin • návšteva na objednávku</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">Odpoveď zvyčajne do 24 hodín</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">Skúška svadobných šiat 12 € / 60 min</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 md:py-12">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
          {CONTACT_ACTIONS.map((action, index) => {
            const Icon = contactIcons[index];
            const isExternal = action.href.startsWith('http');

            return (
              <a
                href={action.href}
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
                class="rounded-[26px] border border-border/70 bg-white p-5 shadow-[0_20px_60px_rgba(61,42,46,0.08)] spring-hover md:p-6"
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <Icon className="h-5 w-5" />
                </div>
                <h2 class="mt-5 text-xl font-semibold text-foreground">{action.title}</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{action.description}</p>
                <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-cta">{action.label}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="pb-16 pt-6 md:pb-20 md:pt-8">
      <div class="container mx-auto grid gap-8 px-4 xl:grid-cols-[1.15fr_0.85fr]">
        <BookingForm
          id="booking"
          title="Zarezervujte si skúšku alebo pošlite dopyt bez zbytočného čakania"
          description="Vyplňte pár detailov a pripravíme vám WhatsApp správu, ktorú si pred odoslaním ešte skontrolujete. Ak radšej voláte alebo píšete email, rovnaké kontakty nájdete aj vedľa formulára."
        />

        <div class="space-y-6">
          <Card className="border border-border/70 shadow-[0_20px_60px_rgba(61,42,46,0.08)]">
            <CardContent className="space-y-4 p-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">Čo sa stane potom</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">Najprv správa, potom potvrdenie termínu.</h2>
              </div>
              <div class="space-y-3 text-sm leading-6 text-muted-foreground">
                <p>Po odoslaní formulára sa otvorí pripravená WhatsApp správa. Môžete ju doplniť alebo upraviť podľa seba.</p>
                <p>Keď nám správa príde, ozveme sa vám s potvrdením termínu alebo s doplňujúcou otázkou, ak riešite šaty, dekorácie aj konzultáciu naraz.</p>
              </div>
            </CardContent>
          </Card>

          <Card className="border-0 bg-primary-900 text-white shadow-[0_26px_80px_rgba(42,28,31,0.18)]">
            <CardHeader>
              <CardTitle className="font-display text-3xl">Často sa pýtate</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              {CONTACT_FAQS.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <h2 class="text-base font-semibold text-white">{item.question}</h2>
                  <p class="mt-2 text-sm leading-6 text-white/75">{item.answer}</p>
                </div>
              ))}
            </CardContent>
          </Card>

          <Card className="overflow-hidden border border-border/70 shadow-[0_20px_60px_rgba(61,42,46,0.08)]">
            <a href={CONTACT_ACTIONS[3].href} target="_blank" rel="noopener noreferrer">
              <img
                src={IMAGE_ASSETS.map}
                alt="Mapa a orientačný screenshot polohy MagicRoom v Martine."
                class="h-[240px] w-full bg-surface object-contain"
                loading="lazy"
              />
            </a>
            <CardContent className="space-y-4 pt-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">Kde nás nájdete</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">{ADDRESS_LABEL}</h2>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  Keď si chcete trasu len rýchlo otvoriť v mobile, kliknite na mapu vyššie. Ak sa ponáhľate, najrýchlejšia cesta je zavolať na {PHONE_DISPLAY}.
                </p>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  Ak si chcete najprv pozrieť, čo všetko v MagicRoom vyriešite, prejdite na
                  <a href="/sluzby" class="font-semibold text-primary underline-offset-4 hover:underline"> služby a cenník</a>
                  alebo si prečítajte
                  <a href="/o-nas" class="font-semibold text-primary underline-offset-4 hover:underline"> príbeh MagicRoom</a>.
                </p>
              </div>
              <a href={CONTACT_ACTIONS[3].href} target="_blank" rel="noopener noreferrer" class="inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                Otvoriť navigáciu
              </a>
            </CardContent>
          </Card>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>