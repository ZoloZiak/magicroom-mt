---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import BookingForm from '@/components/forms/BookingForm.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { ADDRESS_LABEL, PHONE_DISPLAY } from '@/data/site';
import { CONTACT_ACTIONS, CONTACT_FAQS, IMAGE_ASSETS } from '@/data/content';
import { getTranslations } from '@/lib/translations';
import type { Language } from '@/lib/i18n';
import Layout from '@/layouts/Layout.astro';
import { Mail, MapPin, MessageCircle, Phone } from 'lucide-react';

const language: Language = 'sk';
const t = getTranslations(language);

const contactIcons = [Phone, MessageCircle, Mail, MapPin];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: CONTACT_FAQS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="{t.contact.pageTitle}"
  description="{t.contact.pageDescription}"
  keywords="kontakt, rezervácia, martin, telefón, email, whatsapp"
  image={IMAGE_ASSETS.map}
  structuredData={faqSchema}
  breadcrumbs={[
    { name: 'Domov', url: '/' },
    { name: 'Kontakt', url: '/kontakt' },
  ]}
>
  <Header />

  <main class="flex-1">
    <Breadcrumbs items={[
      { name: 'Kontakt', url: '/kontakt' }
    ]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            {t.contact.heroBadge}
          </Badge>
          <h1 class="font-display text-[2.85rem] leading-tight text-foreground md:text-6xl">{t.contact.heroTitle}</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            {t.contact.heroDescription}
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground">
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">{t.contact.visitNote}</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">{t.contact.replyNote}</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">{t.contact.fittingNote}</span>
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="dots" />

    <section class="py-10 md:py-12">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
          {CONTACT_ACTIONS.map((action, index) => {
            const Icon = contactIcons[index];
            const isExternal = action.href.startsWith('http');

            return (
              <a
                href={action.href}
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
                class="rounded-[26px] border border-border/70 bg-white p-5 shadow-[var(--shadow-soft)] spring-hover md:p-6"
                data-ga-category="contact"
                data-ga-action={action.href.startsWith('http') ? 'map_click' : action.href.startsWith('tel:') ? 'phone_click' : 'email_click'}
                data-ga-label={`contact_card_${index}`}
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <Icon className="h-5 w-5" />
                </div>
                <h2 class="mt-5 text-xl font-semibold text-foreground">{action.title}</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{action.description}</p>
                <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-cta">{action.label}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="pb-16 pt-6 md:pb-20 md:pt-8">
      <div class="container mx-auto grid gap-8 px-4 xl:grid-cols-[1.15fr_0.85fr]">
        <BookingForm
          id="booking"
          title="{t.contact.bookingTitle}"
          description="{t.contact.bookingDescription}"
        />

        <div class="space-y-6">
          <Card className="border border-border/70 shadow-[var(--shadow-soft)]">
            <CardContent className="space-y-4 p-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">{t.contact.nextStepsTitle}</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">{t.contact.nextStepsTitle}</h2>
              </div>
              <div class="space-y-3 text-sm leading-6 text-muted-foreground">
                <p>{t.contact.nextStepsDesc1}</p>
                <p>{t.contact.nextStepsDesc2}</p>
              </div>
            </CardContent>
          </Card>

          <Card className="border-0 bg-primary-900 text-white shadow-[var(--shadow-dark)]">
            <CardHeader>
              <CardTitle className="font-display text-3xl">Často sa pýtate</CardTitle>
              <input
                type="text"
                id="faq-search"
                placeholder="Hľadajte odpoveď..."
                class="mt-4 w-full rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-white/50 focus:border-white/40 focus:outline-none"
              />
            </CardHeader>
            <CardContent className="space-y-4" id="faq-list">
              {CONTACT_FAQS.map((item) => (
                <div class="faq-item rounded-2xl border border-white/10 bg-white/5 p-5" data-question={item.question.toLowerCase()} data-answer={item.answer.toLowerCase()}>
                  <h2 class="text-base font-semibold text-white">{item.question}</h2>
                  <p class="mt-2 text-sm leading-6 text-white/75">{item.answer}</p>
                </div>
              ))}
            </CardContent>
          </Card>

          <Card className="overflow-hidden border border-border/70 shadow-[var(--shadow-soft)]">
            <a href={CONTACT_ACTIONS[3].href} target="_blank" rel="noopener noreferrer">
              <img
                src={IMAGE_ASSETS.map}
                alt="Mapa a orientačný screenshot polohy MagicRoom v Martine."
                class="h-[240px] w-full bg-surface object-contain"
                loading="lazy"
              />
            </a>
            <CardContent className="space-y-4 pt-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">Kde nás nájdete</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">{ADDRESS_LABEL}</h2>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  Keď si chcete trasu len rýchlo otvoriť v mobile, kliknite na mapu vyššie. Ak sa ponáhľate, najrýchlejšia cesta je zavolať na {PHONE_DISPLAY}.
                </p>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  Ak si chcete najprv pozrieť, čo všetko v MagicRoom vyriešite, prejdite na
                  <a href="/sluzby" class="font-semibold text-primary underline-offset-4 hover:underline"> služby a cenník</a>
                  alebo si prečítajte
                  <a href="/o-nas" class="font-semibold text-primary underline-offset-4 hover:underline"> príbeh MagicRoom</a>.
                </p>
              </div>
              <a href={CONTACT_ACTIONS[3].href} target="_blank" rel="noopener noreferrer" class="inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                Otvoriť navigáciu
              </a>
            </CardContent>
          </Card>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
  <ScrollToTop />

  <script>
    const searchInput = document.getElementById('faq-search');
    const faqList = document.getElementById('faq-list');
    if (searchInput && faqList) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const items = faqList.querySelectorAll('.faq-item');
        items.forEach((item) => {
          const question = item.getAttribute('data-question') || '';
          const answer = item.getAttribute('data-answer') || '';
          if (query === '' || question.includes(query) || answer.includes(query)) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    }
  </script>
</Layout>