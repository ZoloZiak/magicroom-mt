---
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF_EN, PHONE_DISPLAY, PHONE_HREF } from '@/data/site';
import { DECOR_CATEGORIES_EN, DECOR_FEATURED_EN, DECOR_POLICIES_EN, IMAGE_ASSETS, IMAGE_URLS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, Frame, Gift, Lamp, Phone, Sparkles, UtensilsCrossed } from 'lucide-react';
---

<Layout
  title="Wedding Decoration Rental — Mirrors, Vases, Backdrops | MagicRoom Martin"
  description="Wedding decoration rental in Martin from 0.50 €: mirrors, vases, candelabras, backdrops, candy bar and textiles with clear prices and terms."
  keywords="decoration rental, wedding decorations, vases, mirrors, backdrops, martin"
  image={IMAGE_URLS.decorMain}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Decorations', url: '/en/prenajom-dekoracii' },
  ]}
  language="en"
>
  <Header language={language} />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              Decoration rental • Martin
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl">
              Decorations that finish the space without needing to buy everything new.
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">
              MagicRoom loans pieces that add style to the celebration while remaining practical for transport and setup — from the welcome mirror to candy bar accessories.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg">
                <a href={BOOKING_PAGE_HREF_EN}>
                  Ask about availability
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={PHONE_HREF}>Call: {PHONE_DISPLAY}</a>
              </Button>
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-[var(--shadow-xl)] sm:col-span-2">
              <img
                src={IMAGE_URLS.decorMain}
                alt="Decorations ready for wedding celebration at MagicRoom."
                class="max-h-[420px] w-full rounded-[22px] bg-surface object-contain"
              />
            </div>
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-sm">
              <img
                src={IMAGE_URLS.decorAlt}
                alt="Wedding table with rented MagicRoom decorations."
                class="h-[280px] w-full rounded-[22px] bg-surface object-contain"
                loading="lazy"
              />
            </div>
            <div class="overflow-hidden rounded-[28px] border border-white/60 bg-white p-3 shadow-sm">
              <img
                src={IMAGE_ASSETS.decorBackdrop}
                alt="Wedding backdrop with drapes and fairy lights from MagicRoom rental."
                class="h-[280px] w-full rounded-[22px] bg-surface object-contain"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="dots" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Most requested pieces</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Starting set that brides ask about most often.</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            If you're still putting together your vision, start with these pieces. They can be combined with your own florist or a simple civil ceremony.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {DECOR_FEATURED_EN.map((item, index) => {
            const IconComponent = item.icon === 'frame' ? Frame
              : item.icon === 'utensils' ? UtensilsCrossed
              : item.icon === 'lamp' ? Lamp
              : Gift;
            return (
            <Card className={`border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <IconComponent className="h-5 w-5" />
                </div>
                <CardTitle className="font-display text-2xl leading-tight">{item.title}</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
              </CardContent>
            </Card>
            );
          })}
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Decoration catalog</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Pricing divided by what gets handled together.</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            Prices are approximate for renting individual items. For larger orders or combining multiple categories, we'll go through everything together and check availability.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {DECOR_CATEGORIES_EN.map((group) => (
            <Card className="border-0 bg-white shadow-[var(--shadow-soft)]">
              <CardHeader>
                <CardTitle className="font-display text-3xl">{group.category}</CardTitle>
              </CardHeader>
              <CardContent>
                <div class="space-y-3">
                  {group.items.map((item) => (
                    <div class="flex items-start justify-between gap-4 rounded-2xl bg-surface px-4 py-4">
                      <p class="text-sm leading-6 text-foreground">{item.name}</p>
                      <span class="shrink-0 text-sm font-semibold uppercase tracking-[0.12em] text-cta">{item.price}</span>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
          <div class="photo-card">
            <img
              src={IMAGE_ASSETS.decorDetails}
              alt="Decoration details and accessories from MagicRoom rental."
              class="w-full rounded-[24px] bg-surface object-contain"
              loading="lazy"
            />
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Important information</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Rental should be practical, not unclear.</h2>
            <div class="mt-8 grid gap-4">
              {DECOR_POLICIES_EN.map((item) => (
                <div class="flex gap-4 rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="mt-1 rounded-full bg-success/15 p-2 text-success">
                    <CheckCircle2 className="h-4 w-4" />
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground">{item}</p>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm leading-6 text-muted-foreground">
              If you want to combine decorations with dresses or consultation, also check out our
              <a href="/en/sluzby" class="font-semibold text-primary underline-offset-4 hover:underline"> services and pricing</a>
              or go directly to
              <a href="/en/kontakt" class="font-semibold text-primary underline-offset-4 hover:underline"> contact and inquiry</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer language={language} />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>
