---
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF_EN, PHONE_HREF, PHONE_DISPLAY } from '@/data/site';
import { IMAGE_ASSETS, IMAGE_URLS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, Calendar, Clock, Phone } from 'lucide-react';

const RELATED_POSTS = [
  {
    slug: 'wedding-dresses-how-to-choose',
    title: 'How to Choose Wedding Dresses',
    excerpt: 'Step by step, we guide you through choosing the ideal wedding dress.',
    image: IMAGE_ASSETS.founder,
  },
  {
    slug: 'wedding-decorations-small-celebrations',
    title: 'Decorations for Small Celebrations',
    excerpt: 'Inspiration for romantic decorations without unnecessary expenses.',
    image: IMAGE_ASSETS.decorMain,
  },
];
---

<Layout
  title="Wedding Trends 2026: What Will Be in Fashion? | MagicRoom Blog"
  description="Discover the latest trends in wedding fashion for 2026. From colors to styles — everything you need to know for your wedding."
  keywords="wedding trends 2026, fashion, dresses, colors, styles, wedding"
  type="article"
  image={IMAGE_ASSETS.dresses}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'Wedding Trends 2026: What Will Be in Fashion?',
    image: IMAGE_ASSETS.dresses,
    datePublished: '2026-04-01',
    author: {
      '@type': 'Person',
      name: 'Natália Ondrejková',
    },
  }}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Blog', url: '/en/blog' },
    { name: 'Wedding Trends 2026', url: '/en/blog/wedding-trends-2026' },
  ]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <article class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-8">
          <Badge variant="secondary" className="mb-4 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Blog • Trends
          </Badge>
          <h1 class="font-display text-4xl text-foreground md:text-5xl">
            Wedding Trends 2026: What Will Be in Fashion?
          </h1>
          <div class="mt-4 flex items-center gap-4 text-muted-foreground">
            <div class="flex items-center gap-2">
              <Calendar className="h-4 w-4" />
              <span>April 1, 2026</span>
            </div>
            <div class="flex items-center gap-2">
              <Clock className="h-4 w-4" />
              <span>5 min read</span>
            </div>
          </div>
        </div>

        <div class="prose prose-lg max-w-none">
          <p class="article-element">
            The year 2026 brings new trends in wedding fashion that combine classic with modern elements.
            If you're planning a wedding, it's good to know what's in style.
          </p>

          <h2 class="article-element">Key Colors of 2026</h2>
          <p class="article-element">
            Subtle, natural tones dominate: champagne, ivory and soft pink shades.
            Pure white weddings are fading — being replaced by warm, vibrant colors.
          </p>

          <h2 class="article-element">Styles and Silhouettes</h2>
          <p class="article-element">
            Popular are dresses with asymmetric details, chiffon layers and minimalist appliques.
            Midi and tea-length lengths are still in fashion for less formal weddings.
          </p>

          <img src={IMAGE_URLS.dresses} alt="Wedding Trends 2026" class="article-element rounded-2xl my-8" />

          <h2 class="article-element">Accessories and Hairstyles</h2>
          <p class="article-element">
            Small hats, fresh flowers and natural waves are replacing traditional veils.
            Jewelry is minimalist with natural stones.
          </p>
        </div>

        <div class="mt-12 rounded-2xl border border-border/70 bg-white p-6 md:p-8">
          <h3 class="font-display text-2xl mb-4">Have Questions About Dresses?</h3>
          <p class="text-muted-foreground mb-6">
            At MagicRoom, we'll help you find a dress that expresses your personality.
            Book your fitting today.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row">
            <Button asChild variant="cta" size="lg">
              <a href={BOOKING_PAGE_HREF_EN}>
                Book a fitting
                <ArrowRight className="h-4 w-4 ml-2" />
              </a>
            </Button>
            <Button asChild variant="outline" size="lg">
              <a href={PHONE_HREF}>
                <Phone className="h-4 w-4 mr-2" />
                {PHONE_DISPLAY}
              </a>
            </Button>
          </div>
        </div>

        <div class="mt-12">
          <h3 class="font-display text-2xl mb-6">Related Articles</h3>
          <div class="grid gap-6 md:grid-cols-2">
            {RELATED_POSTS.map((post) => (
              <Card className="border-0 bg-white shadow-[var(--shadow-soft)] spring-hover">
                <div class="overflow-hidden rounded-t-xl">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-32 w-full object-cover transition-transform duration-300 hover:scale-105"
                  />
                </div>
                <CardHeader>
                  <CardTitle className="font-display text-lg line-clamp-2">{post.title}</CardTitle>
                  <CardDescription className="line-clamp-2">{post.excerpt}</CardDescription>
                </CardHeader>
                <CardContent>
                  <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                    <a href={`/en/blog/${post.slug}`}>
                      Read article
                      <ArrowRight className="h-4 w-4 ml-2" />
                    </a>
                  </Button>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
      </div>
    </article>
  </main>

  <FooterEn />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>
