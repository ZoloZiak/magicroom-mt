---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF_EN, WHATSAPP_URL } from '@/data/site';
import { EXTRA_SERVICES_EN, IMAGE_ASSETS, IMAGE_URLS, SERVICE_PACKAGES_EN } from '@/data/content';
import { getTranslations } from '@/lib/translations';
import type { Language } from '@/lib/i18n';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, ClipboardList, LayoutGrid, Shirt, Sparkles } from 'lucide-react';

const language: Language = 'en';
const t = getTranslations(language);

const servicePillars = [
  { title: 'Wedding Dress Fitting', price: '12 € / 60 min', description: 'Calm fitting with drink.', cta: 'Book a fitting', href: BOOKING_PAGE_HREF_EN, icon: Shirt },
  { title: 'Dress Selection', price: 'from 100 €', description: 'New models and consignment.', cta: 'Ask', href: BOOKING_PAGE_HREF_EN, icon: Sparkles },
  { title: 'Decorations', price: 'from 0.50 €', description: 'Mirrors, vases, candlesticks.', cta: 'View', href: '/en/decorations', icon: LayoutGrid },
  { title: 'Consulting', price: 'from 40 €', description: 'Consultations, moodboard.', cta: 'View', href: '#packages', icon: ClipboardList },
];

const servicePackages = SERVICE_PACKAGES_EN;
const extraServices = EXTRA_SERVICES_EN;
---

<Layout
  title="Services & Pricing — MagicRoom Martin"
  description="Wedding services and packages."
  image={IMAGE_URLS.dresses}
  breadcrumbs={[{ name: 'Home', url: '/en' }, { name: 'Services', url: '/en/services' }]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <Breadcrumbs items={[{ name: 'Services', url: '/en/services' }]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">{t.services.heroBadge}</Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl">Clear offer for the bride.</h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">Services that make sense.</p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <Button asChild variant="cta" size="lg"><a href={BOOKING_PAGE_HREF_EN}>Book fitting<ArrowRight className="h-5 w-5" /></a></Button>
              <Button asChild variant="outline" size="lg"><a href={WHATSAPP_URL}>WhatsApp</a></Button>
            </div>
          </div>
          <div class="photo-card"><img src={IMAGE_URLS.dresses} alt="Wedding dress" class="max-h-[520px] w-full rounded-[24px] object-contain" /></div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10"><p class="text-sm uppercase tracking-[0.24em] text-primary/70">What we offer</p><h2 class="mt-3 font-display text-4xl">Four services.</h2></div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {servicePillars.map((item, index) => (
            <Card className="border-0 bg-white shadow-[var(--shadow-soft)]">
              <CardHeader>
                <div className="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10"><item.icon className="h-5 w-5" /></div>
                <CardTitle className="font-display text-2xl">{item.title}</CardTitle>
                <p className="pt-2 text-sm font-semibold uppercase text-cta">{item.price}</p>
                <CardDescription>{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary"><a href={item.href}>{item.cta}<ArrowRight className="h-4 w-4" /></a></Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section id="packages" class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center"><p class="text-sm uppercase tracking-[0.24em] text-primary/70">Planning packages</p><h2 className="mt-3 font-display text-4xl">Choose level of help.</h2></div>
        <div class="grid gap-8 lg:grid-cols-3">
          {servicePackages.map((pkg, index) => (
            <Card className={`bg-white shadow ${pkg.recommended?'ring-2 ring-cta':''}`}>
              <CardHeader>
                <Badge variant={pkg.recommended?'cta':'secondary'}>{pkg.recommended?'Most popular':'Package'}</Badge>
                <CardTitle className="font-display text-3xl">{pkg.name}</CardTitle>
                <CardDescription>{pkg.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul className="space-y-3">
                  {pkg.features.map((f) => <li className="flex items-center gap-2 text-sm"><Badge variant="success">inc</Badge><span>{f}</span></li>)}
                </ul>
                <Button asChild className="mt-8 w-full"><a href={BOOKING_PAGE_HREF_EN}>Explore</a></Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

  <FooterEn />
  <WhatsAppFAB />
  <ScrollToTop />
  </main>
</Layout>