---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import BookingForm from '@/components/forms/BookingForm.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { ADDRESS_LABEL, PHONE_DISPLAY, WHATSAPP_URL } from '@/data/site';
import { CONTACT_ACTIONS_EN, CONTACT_FAQS_EN, IMAGE_ASSETS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { Mail, MapPin, MessageCircle, Phone } from 'lucide-react';

const contactIcons = [Phone, MessageCircle, Mail, MapPin];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: CONTACT_FAQS_EN.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Contact and booking — MagicRoom Martin"
  description="Book your wedding dress fitting from 12 € or wedding consultation at MagicRoom in Martin. Phone, WhatsApp, email, map and booking form. English spoken — Norwegian students welcome!"
  keywords="contact, booking, martin, phone, email, whatsapp"
  image={IMAGE_ASSETS.map}
  structuredData={faqSchema}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Contact', url: '/en/kontakt' },
  ]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <Breadcrumbs items={[
      { name: 'Contact', url: '/en/kontakt' }
    ]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Contact • booking • Martin
          </Badge>
          <h1 class="font-display text-[2.85rem] leading-tight text-foreground md:text-6xl">Reach out the way that's natural for you.</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            If you want a dress fitting, decorations or just to go through wedding details, choose a call, WhatsApp, email or the form below.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground">
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">Martin • by appointment</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">We reply within 24 hours</span>
            <span class="rounded-full border border-border/70 bg-white/80 px-4 py-2">Wedding dress fitting 12 € / 60 min</span>
          </div>
          
          <div class="mt-6 flex items-center gap-3 justify-center">
            <Badge variant="success">English spoken</Badge>
            <Badge variant="success">🇳🇴 Norwegian students welcome</Badge>
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="dots" />

    <section class="py-10 md:py-12">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
          {CONTACT_ACTIONS_EN.map((action, index) => {
            const Icon = contactIcons[index];
            const isExternal = action.href.startsWith('http');

            return (
              <a
                href={action.href}
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
                class="rounded-[26px] border border-border/70 bg-white p-5 shadow-[var(--shadow-soft)] spring-hover md:p-6"
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <Icon className="h-5 w-5" />
                </div>
                <h2 class="mt-5 text-xl font-semibold text-foreground">{action.title}</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">{action.description}</p>
                <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-cta">{action.label}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="pb-16 pt-6 md:pb-20 md:pt-8">
      <div class="container mx-auto grid gap-8 px-4 xl:grid-cols-[1.15fr_0.85fr]">
        <BookingForm
          id="booking"
          title="Book a fitting or send an inquiry without waiting"
          description="Fill in a few details and we'll prepare a WhatsApp message you can check before sending. If you prefer calling or emailing, those contacts are next to the form."
        />

        <div class="space-y-6">
          <Card className="border border-border/70 shadow-[var(--shadow-soft)]">
            <CardContent class="space-y-4 p-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">What happens next</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">First a message, then confirmation of the appointment.</h2>
              </div>
              <div class="space-y-3 text-sm leading-6 text-muted-foreground">
                <p>After submitting the form, a prepared WhatsApp message opens. You can add or edit it as you like.</p>
                <p>When we receive the message, we'll get back to you with appointment confirmation or a follow-up question if you're solving dresses, decorations and consultation all at once.</p>
              </div>
            </CardContent>
          </Card>

          <Card className="border-0 bg-primary-900 text-white shadow-[var(--shadow-dark)]">
            <CardHeader>
              <CardTitle className="font-display text-3xl">You often ask</CardTitle>
            </CardHeader>
            <CardContent class="space-y-4">
              {CONTACT_FAQS_EN.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <h2 class="text-base font-semibold text-white">{item.question}</h2>
                  <p class="mt-2 text-sm leading-6 text-white/75">{item.answer}</p>
                </div>
              ))}
            </CardContent>
          </Card>

          <Card className="overflow-hidden border border-border/70 shadow-[var(--shadow-soft)]">
            <a href={CONTACT_ACTIONS_EN[3].href} target="_blank" rel="noopener noreferrer">
              <img
                src={IMAGE_ASSETS.map}
                alt="Map and location screenshot of MagicRoom in Martin."
                class="h-[240px] w-full bg-surface object-contain"
                loading="lazy"
              />
            </a>
            <CardContent class="space-y-4 pt-6">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-primary/70">Where to find us</p>
                <h2 class="mt-2 text-2xl font-display text-foreground">{ADDRESS_LABEL}</h2>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  If you want to quickly open the route on mobile, click the map above. If you're in a hurry, the fastest way is to call {PHONE_DISPLAY}.
                </p>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  If you want to first see what all MagicRoom can solve, go to
                  <a href="/en/sluzby" class="font-semibold text-primary underline-offset-4 hover:underline"> services and pricing</a>
                  or read
                  <a href="/en/o-nas" class="font-semibold text-primary underline-offset-4 hover:underline"> MagicRoom's story</a>.
                </p>
              </div>
              <a href={CONTACT_ACTIONS_EN[3].href} target="_blank" rel="noopener noreferrer" class="inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                Open navigation
              </a>
            </CardContent>
          </Card>
        </div>
      </div>
    </section>
  </main>

  <FooterEn />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>