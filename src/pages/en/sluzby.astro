---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF_EN, PHONE_DISPLAY, PHONE_HREF, WHATSAPP_URL } from '@/data/site';
import { EXTRA_SERVICES_EN, IMAGE_ASSETS, SERVICE_PACKAGES_EN } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, ClipboardList, LayoutGrid, Phone, Shirt, Sparkles } from 'lucide-react';

const servicePillars = [
  {
    title: 'Wedding Dress Fitting',
    price: '12 € / 60 min',
    description: 'Calm fitting with drink included, space for two close people and time to compare multiple styles without stress.',
    cta: 'Book a fitting',
    href: BOOKING_PAGE_HREF_EN,
    icon: Shirt,
  },
  {
    title: 'Dress Selection & Sale',
    price: 'from 100 €',
    description: 'New models, available pieces and consignment options for women who want to feel good even on a budget.',
    cta: 'Ask about selection',
    href: BOOKING_PAGE_HREF_EN,
    icon: Sparkles,
  },
  {
    title: 'Decoration Rental',
    price: 'from 0.50 € / item',
    description: 'Mirrors, vases, candlesticks, backdrops and candy bar accessories so you can match your celebration without chaos.',
    cta: 'View decorations',
    href: '/en/prenajom-dekoracii',
    icon: LayoutGrid,
  },
  {
    title: 'Wedding Consulting',
    price: 'from 40 €',
    description: 'Consultations, moodboard, timeline and vendor recommendations depending on how much help you really need.',
    cta: 'View packages',
    href: '#packages',
    icon: ClipboardList,
  },
] as const;

const servicesSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: SERVICE_PACKAGES_EN.map((pkg, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Offer',
        name: pkg.name,
        description: pkg.description,
        price: pkg.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/InStock',
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList', 
    itemListElement: EXTRA_SERVICES_EN.map((svc, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        name: svc.title,
        description: svc.description,
        price: svc.price,
        priceCurrency: 'EUR',
      },
    })),
  },
];
---

<Layout
  title="Services & Pricing — Wedding Dresses, Decorations, Consulting | MagicRoom Martin"
  description="Wedding dress fitting from 12 €, decoration rental, wedding consulting and wedding planning packages at MagicRoom in Martin with clear prices. English spoken — Norwegian students welcome!"
  keywords="wedding services, prices, packages, consultations, wedding planning, dress rental"
  image={IMAGE_ASSETS.dresses}
  structuredData={[servicesSchema]}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Services', url: '/en/sluzby' },
  ]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <Breadcrumbs items={[
      { name: 'Services', url: '/en/sluzby' }
    ]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              Services • pricing • Martin
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl animate-fade-in-up animate-stagger-2">
              Clear offer for the bride who wants everything sorted calmly.
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground animate-fade-in-up animate-stagger-3">
              At MagicRoom you don't start with a long list of obligations. You start with a service that makes sense now — dress fitting, decorations or wedding planning step by step.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row animate-fade-in-up animate-stagger-4">
              <Button asChild variant="cta" size="lg">
                <a href={BOOKING_PAGE_HREF_EN}>
                  Book a fitting
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Message on WhatsApp</a>
              </Button>
            </div>
            
            <div class="mt-6 flex items-center gap-3 text-sm text-muted-foreground">
              <Badge variant="success">English spoken</Badge>
              <span>•</span>
              <span>Norwegian brides welcome</span>
              <span>•</span>
              <span>Transparent prices</span>
            </div>
          </div>

          <div class="grid gap-5">
            <div class="photo-card">
              <img
                src={IMAGE_ASSETS.dresses}
                alt="Wedding dress ready for fitting at MagicRoom salon."
                class="max-h-[520px] w-full rounded-[24px] bg-surface object-contain"
              />
            </div>
            <div class="rounded-[28px] border border-primary/20 bg-primary/5 p-6">
              <Badge variant="secondary">🇳🇴 Norwegian students: Special rates available</Badge>
              <h2 class="mt-4 text-2xl font-display text-foreground">Studying in Slovakia? We offer tailored packages for international students.</h2>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                Contact us via WhatsApp — we speak English and can arrange remote consultations for students planning a wedding back home.
              </p>
              <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex text-sm font-semibold text-primary underline-offset-4 hover:underline">
                Message us on WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">What we offer</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Four services that can naturally combine together.</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            If you come for dresses, you can sort decorations and initial planning right away. And if you're solving just one thing, you don't pay for anything extra.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {servicePillars.map((item, index) => (
            <Card className={`border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <item.icon className="h-5 w-5" />
                </div>
                <CardTitle className="font-display text-2xl">{item.title}</CardTitle>
                <p class="pt-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">{item.price}</p>
                <CardDescription className="pt-3 text-base leading-7">{item.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <Button asChild variant="ghost" className="px-0 text-primary hover:text-cta">
                  <a href={item.href}>
                    {item.cta}
                    <ArrowRight className="h-4 w-4" />
                  </a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>

        <p class="mt-8 max-w-2xl text-sm leading-6 text-muted-foreground">
          If you already know you're mainly solving decorations, check out
          <a href="/en/prenajom-dekoracii" class="font-semibold text-primary underline-offset-4 hover:underline"> decoration rental</a>.
          If you want to first get to know MagicRoom's way of working, go to
          <a href="/en/o-nas" class="font-semibold text-primary underline-offset-4 hover:underline"> about page</a>
          or directly to
          <a href="/en/kontakt" class="font-semibold text-primary underline-offset-4 hover:underline"> contact and booking</a>.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">From the salon</p>
          <h2 class="mt-3 font-display text-3xl text-foreground md:text-4xl">This is what it looks like here.</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.satyRuzove3} alt="Pink wedding dress in the salon." class="h-64 w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.interier1} alt="Wedding salon interior." class="h-64 w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.sachovnica3} alt="Checkered pattern in the salon." class="h-64 w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.satyRuzove1} alt="Wedding dress on hanger." class="h-64 w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.interier3} alt="Interior detail of the salon." class="h-64 w-full object-cover" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-2xl shadow-[var(--shadow-soft)]">
            <img src={IMAGE_ASSETS.detail1} alt="Wedding decoration detail." class="h-64 w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section id="packages" class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Wedding planning packages</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Choose the level of help you need right now.</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            Each package can be adjusted according to wedding size, budget and whether you need more direction or complete support during preparations.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-3">
          {SERVICE_PACKAGES_EN.map((pkg, index) => (
            <Card className={`relative border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1} ${pkg.recommended ? 'ring-2 ring-cta/60' : ''}`}>
              <CardHeader>
                <div class="mb-4 flex items-center justify-between gap-3">
                  <Badge variant={pkg.recommended ? 'cta' : 'secondary'}>
                    {pkg.recommended ? 'Most popular' : 'Package'}
                  </Badge>
                  <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary/70">{pkg.price}</p>
                </div>
                <CardTitle className="font-display text-3xl">{pkg.name}</CardTitle>
                <CardDescription className="pt-3 text-base leading-7">{pkg.description}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul class="space-y-3">
                  {pkg.features.map((feature) => (
                    <li class="flex items-start gap-3 text-sm leading-6 text-muted-foreground">
                      <Badge variant="success" className="mt-0.5 px-2 py-0.5">included</Badge>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                <Button asChild variant={pkg.recommended ? 'cta' : 'outline'} className="mt-8 w-full">
                  <a href={BOOKING_PAGE_HREF_EN}>Explore options</a>
                </Button>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="photo-card">
            <img
              src={IMAGE_ASSETS.graphics}
              alt="Personalized wedding announcement and graphic items from MagicRoom."
              class="w-full rounded-[24px] bg-surface object-contain"
              loading="lazy"
            />
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Extra services</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Small items that make big peace in preparations.</h2>
            <div class="mt-8 grid gap-4">
              {EXTRA_SERVICES_EN.map((item) => (
                <div class="rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                      <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
                      <p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
                    </div>
                    <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-cta">
                      <CheckCircle2 className="h-4 w-4" />
                      {item.price}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <FooterEn />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>