---
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { BOOKING_PAGE_HREF_EN, EMAIL, EMAIL_HREF, PHONE_DISPLAY, PHONE_HREF, WHATSAPP_URL } from '@/data/site';
import { CONSIGNMENT_BENEFITS_EN, CONSIGNMENT_CONDITIONS_EN, CONSIGNMENT_STEPS_EN, IMAGE_ASSETS, IMAGE_URLS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight, CheckCircle2, Mail, Phone } from 'lucide-react';
---

<Layout
  title="Consignment Sale of Wedding Dresses in Martin — MagicRoom"
  description="Consignment sale conditions for wedding dresses at MagicRoom in Martin. Fair rules, personal agreement and payment within 7 days. Currently at full capacity."
  keywords="consignment dress sale, sell wedding dress, martin, conditions"
  image={IMAGE_URLS.dresses}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Consignment', url: '/en/komisny-predaj' },
  ]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="destructive" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
              Currently at full capacity
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl">
              Have post-wedding dresses and want to give them another life?
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">
              Consignment at MagicRoom is built on fair rules and personal agreement. However, we currently don't accept new dresses to maintain the quality of care for those already in the salon.
            </p>

            <div class="mt-8 rounded-[28px] border border-destructive/20 bg-destructive/5 p-6">
              <h2 class="text-2xl font-display text-foreground">Want to know when space opens up?</h2>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                Send us an email or a short message with a photo of the dresses. When we start accepting new pieces again, we'll reach out to you among the first.
              </p>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                <Button asChild variant="cta">
                  <a href={EMAIL_HREF}>
                    <Mail className="h-4 w-4" />
                    Send email
                  </a>
                </Button>
                <Button asChild variant="outline">
                  <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
                    <Phone className="h-4 w-4" />
                    Message on WhatsApp
                  </a>
                </Button>
              </div>
            </div>
          </div>

          <div class="photo-card">
            <img
              src={IMAGE_URLS.dresses}
              alt="Wedding dresses ready at MagicRoom salon."
              class="max-h-[560px] w-full rounded-[24px] bg-surface object-contain"
            />
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <p class="text-sm uppercase tracking-[0.24em] text-primary/70">How consignment works</p>
          <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">When capacity isn't full, the process is simple and transparent.</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {CONSIGNMENT_STEPS_EN.map((step, index) => (
            <Card className={`border-0 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${index + 1}`}>
              <CardHeader>
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-sm font-semibold text-primary-foreground">
                  0{index + 1}
                </div>
                <CardTitle className="font-display text-2xl">Step {index + 1}</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm leading-6 text-muted-foreground">{step}</p>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-surface py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Conditions for listing</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Rules that keep the sale fair for both sides.</h2>
            <div class="mt-8 grid gap-4">
              {CONSIGNMENT_CONDITIONS_EN.map((item) => (
                <div class="rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <h3 class="text-xl font-semibold text-foreground">{item.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
                </div>
              ))}
            </div>
          </div>

          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Why brides consider this</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Sell without ads, negotiating and wasting time.</h2>
            <div class="mt-8 grid gap-4">
              {CONSIGNMENT_BENEFITS_EN.map((item) => (
                <div class="flex gap-4 rounded-2xl border border-border/70 bg-white px-5 py-5 shadow-sm">
                  <div class="mt-1 rounded-full bg-success/15 p-2 text-success">
                    <CheckCircle2 className="h-4 w-4" />
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground">{item}</p>
                </div>
              ))}
            </div>

            <div class="mt-8 rounded-[28px] border border-primary/10 bg-primary-900 p-6 text-white shadow-[var(--shadow-card-lg)]">
              <p class="text-sm uppercase tracking-[0.2em] text-white/70">Current status</p>
              <h3 class="mt-3 font-display text-3xl">Full capacity of accepted dresses</h3>
              <p class="mt-3 text-sm leading-6 text-white/75">
                Best next step is to write to {EMAIL}. When we have space to accept more models, we'll reach out and go through photos and dress condition together.
              </p>
              <p class="mt-3 text-sm leading-6 text-white/75">
                If you're also dealing with dress fitting or other services in Martin, check out
                <a href="/en/sluzby" class="font-semibold text-white underline underline-offset-4"> MagicRoom services</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4 text-center">
        <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Contact for waitlist</p>
        <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">Send us basic info and we'll reach out when space opens.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-muted-foreground">
          Just a photo of the dresses, size and your price expectation. You don't need to remember the whole process — when capacity opens, we'll go through everything together.
        </p>

        <Button asChild variant="cta" size="lg" className="mt-8">
          <a href="/en/kontakt">
            Go to contact
            <ArrowRight className="h-5 w-5" />
          </a>
        </Button>
      </div>
    </section>
  </main>

  <FooterEn />
  <WhatsAppFAB />
  <ScrollToTop />
</Layout>