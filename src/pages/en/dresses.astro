---
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { BOOKING_PAGE_HREF_EN, PHONE_DISPLAY, PHONE_HREF, WHATSAPP_URL } from '@/data/site';
import { IMAGE_ASSETS, IMAGE_URLS } from '@/data/content';
import Layout from '@/layouts/Layout.astro';
import type { Language } from '@/lib/i18n';
import { ArrowRight, Phone, Sparkles } from 'lucide-react';
import { getDresses } from '@/lib/dresses';

const language: Language = 'en';

const dresses = getDresses();
const availableDresses = dresses.filter(d => d.status === 'available');

const SIZES = ['34', '36', '38', '40', '42', '44'];
const PRICE_RANGES = [
  { label: 'up to 200 €', value: '0-200' },
  { label: '200–400 €', value: '200-400' },
  { label: 'over 400 €', value: '400+' },
];

const statusLabel = (status: string) => {
  if (status === 'available') return 'Available';
  if (status === 'reserved') return 'Reserved';
  if (status === 'sold') return 'Sold';
  return status;
};

const statusColor = (status: string) => {
  if (status === 'available') return 'bg-success/15 text-success border-success/30';
  if (status === 'reserved') return 'bg-accent/15 text-accent border-accent/30';
  return 'bg-muted text-muted-foreground border-border';
};

const typeLabel = (type: string) => type === 'new' ? 'New' : 'Consignment';
---

<Layout
  title="Wedding Dress Catalog — Rent & Buy | MagicRoom Martin"
  description="Browse our wedding dress collection. Rental from 200 €, new and consignment dresses available. See prices, sizes and availability — English spoken, Norwegian students welcome!"
  keywords="wedding dresses, dress rental, buy wedding dress, consignment, martin, slovakia"
  image={IMAGE_URLS.dresses}
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Dresses', url: '/en/svadobne-saty' },
  ]}
  language="en"
>
  <Header language={language} />

  <main class="flex-1">
    <Breadcrumbs items={[
      { name: 'Dresses', url: '/en/svadobne-saty' }
    ]} />

    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="max-w-2xl">
            <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em] animate-fade-in-up animate-stagger-1">
              Wedding dress catalog • Martin
            </Badge>
            <h1 class="font-display text-[2.9rem] leading-tight text-foreground md:text-6xl animate-fade-in-up animate-stagger-2">
              Find your dream dress — with clear prices you see upfront.
            </h1>
            <p class="mt-6 text-lg leading-8 text-muted-foreground animate-fade-in-up animate-stagger-3">
              Browse our collection from the comfort of home. All prices visible, all sizes listed. Book a fitting or ask about remote consultation.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row animate-fade-in-up animate-stagger-4">
              <Button asChild variant="cta" size="lg">
                <a href={BOOKING_PAGE_HREF_EN}>
                  Book a fitting
                  <ArrowRight className="h-5 w-5" />
                </a>
              </Button>
              <Button asChild variant="outline" size="lg">
                <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Message on WhatsApp</a>
              </Button>
            </div>

            <div class="mt-6 flex items-center gap-3 text-sm text-muted-foreground">
              <Badge variant="success">English spoken</Badge>
              <span>•</span>
              <span>🇳🇴 Norwegian students: Special rates</span>
              <span>•</span>
              <span>Rental from 200 €</span>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              <div class="rounded-2xl border border-border/70 bg-white/80 px-5 py-4 shadow-sm backdrop-blur">
                <p class="font-display text-3xl text-cta">{availableDresses.length}</p>
                <p class="mt-1 text-sm leading-6 text-muted-foreground">dresses available</p>
              </div>
              <div class="rounded-2xl border border-border/70 bg-white/80 px-5 py-4 shadow-sm backdrop-blur">
                <p class="font-display text-3xl text-cta">200–700 €</p>
                <p class="mt-1 text-sm leading-6 text-muted-foreground">rental price range</p>
              </div>
              <div class="rounded-2xl border border-border/70 bg-white/80 px-5 py-4 shadow-sm backdrop-blur">
                <p class="font-display text-3xl text-cta">34–44</p>
                <p class="mt-1 text-sm leading-6 text-muted-foreground">sizes available</p>
              </div>
            </div>
          </div>

          <div class="grid gap-5">
            <div class="photo-card">
              <img
                src={IMAGE_URLS.dresses}
                alt="Wedding dress collection at MagicRoom."
                class="max-h-[520px] w-full rounded-[24px] bg-surface object-contain"
              />
            </div>
            <div class="rounded-[28px] border border-primary/20 bg-primary/5 p-6">
              <div class="flex items-start gap-3">
                <Sparkles className="h-5 w-5 text-primary shrink-0 mt-1" />
                <div>
                  <h3 class="font-semibold text-foreground">Why rent in Slovakia?</h3>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">
                    Norwegian brides save <strong>50-70%</strong> compared to Norway. Same quality, transparent prices, personal fitting experience.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="floral" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-primary/70">Our collection</p>
            <h2 class="mt-3 font-display text-4xl text-foreground md:text-5xl">{availableDresses.length} dresses ready for fitting</h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted-foreground">
            All dresses can be rented or bought. Prices are for rental (2-week period). Want to buy? Contact us for purchase options.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {availableDresses.map((dress, index) => (
            <div class={`group relative overflow-hidden rounded-2xl border border-border/70 bg-white shadow-[var(--shadow-soft)] spring-hover animate-fade-in-up animate-stagger-${(index % 4) + 1}`}>
              <div class="aspect-[3/4] overflow-hidden bg-surface">
                <img 
                  src={dress.image} 
                  alt={dress.name}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-display text-lg text-foreground">{dress.name}</h3>
                  <Badge className={`text-xs ${statusColor(dress.status)}`}>
                    {statusLabel(dress.status)}
                  </Badge>
                </div>
                <p class="mt-2 text-sm text-muted-foreground line-clamp-2">{dress.description}</p>
                <div class="mt-3 flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-cta">{dress.price} €</p>
                    <p class="text-xs text-muted-foreground">Size {dress.size}</p>
                  </div>
                  <Badge variant="secondary" className="text-xs">{typeLabel(dress.type)}</Badge>
                </div>
                <Button asChild variant="ghost" size="sm" className="mt-3 w-full">
                  <a href={BOOKING_PAGE_HREF_EN}>
                    Book fitting
                    <ArrowRight className="h-4 w-4" />
                  </a>
                </Button>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 rounded-2xl border border-border/70 bg-surface p-8 text-center">
          <h3 class="text-xl font-semibold text-foreground">Can't find what you're looking for?</h3>
          <p class="mt-2 text-muted-foreground">We regularly update our collection. Contact us and we'll help you find the perfect dress.</p>
          <Button asChild variant="cta" size="lg" className="mt-6">
            <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Message on WhatsApp</a>
          </Button>
        </div>
      </div>
    </section>

    <CTASection />

    <Footer language={language} />
    <WhatsAppFAB />
    <ScrollToTop />
  </main>
</Layout>