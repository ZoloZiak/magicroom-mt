---
import CTASection from '@/components/layout/CTASection.astro';
import DecorativeDivider from '@/components/layout/DecorativeDivider.astro';
import FooterEn from '@/components/layout/FooterEn.astro';
import HeaderEn from '@/components/layout/HeaderEn.astro';
import ScrollToTop from '@/components/layout/ScrollToTop.astro';
import WhatsAppFAB from '@/components/layout/WhatsAppFAB.astro';
import { Badge } from '@/components/ui/badge';
import Layout from '@/layouts/Layout.astro';

const GALLERY_IMAGES = [
  { src: '/images/salon/interier-teple-1.jpeg', alt: 'MagicRoom Interior - warm lighting', category: 'interior' },
  { src: '/images/salon/interier-teple-2.jpeg', alt: 'MagicRoom Interior - detail', category: 'interior' },
  { src: '/images/salon/interier-teple-3.jpeg', alt: 'MagicRoom Interior - view', category: 'interior' },
  { src: '/images/salon/interier-chladne-1.jpeg', alt: 'MagicRoom Interior - cool light', category: 'interior' },
  { src: '/images/salon/saty-ruzove-1.jpeg', alt: 'Wedding dress - pink', category: 'dresses' },
  { src: '/images/salon/saty-ruzove-3.jpeg', alt: 'Wedding dress - detail', category: 'dresses' },
  { src: '/images/salon/saty-ruzove-5.jpeg', alt: 'Wedding dress - full view', category: 'dresses' },
  { src: '/images/salon/saty-fialove-1.jpeg', alt: 'Wedding dress - purple', category: 'dresses' },
  { src: '/images/salon/sachovnica-kontrast-1.jpeg', alt: 'Salon - contrast', category: 'interior' },
  { src: '/images/salon/detail-tmave-1.jpeg', alt: 'Dress detail', category: 'details' },
  { src: '/images/salon/detail-tmave-4.jpeg', alt: 'Dress detail - Pink', category: 'details' },
  { src: '/images/salon/detail-tmave-5.jpeg', alt: 'Dress detail - Embroidery', category: 'details' },
] as const;
---

<Layout
  title="Gallery — MagicRoom"
  description="Photo gallery from MagicRoom wedding salon in Martin. Interior, wedding dresses and details."
  keywords="gallery, photos, wedding dresses, interior, MagicRoom, Martin"
  image="https://www.magicroom.sk/wp-content/uploads/2026/02/magicroombackround-1024x683.png"
  breadcrumbs={[
    { name: 'Home', url: '/en' },
    { name: 'Gallery', url: '/en/galeria' },
  ]}
  language="en"
>
  <HeaderEn />

  <main class="flex-1">
    <section class="bg-[linear-gradient(180deg,#fbf5f1_0%,#fffdfb_100%)] py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <Badge variant="secondary" className="mb-5 px-4 py-1 text-[11px] uppercase tracking-[0.28em]">
            Gallery
          </Badge>
          <h1 class="font-display text-4xl text-foreground md:text-5xl">
            Photos from MagicRoom
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            See the interior of our salon, wedding dresses and details from our events.
          </p>
        </div>
      </div>
    </section>

    <DecorativeDivider variant="dots" />

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {GALLERY_IMAGES.map((img, index) => (
            <button
              class="gallery-item group relative overflow-hidden rounded-2xl bg-surface cursor-zoom-in"
              data-index={index}
              aria-label="Zoom photo"
            >
              <img
                src={img.src}
                alt={img.alt}
                class="h-64 w-full object-cover transition-transform duration-300 group-hover:scale-110"
                loading={index < 4 ? 'eager' : 'lazy'}
              />
              <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-colors group-hover:bg-black/30">
                <span class="text-white opacity-0 transition-opacity group-hover:opacity-100">
                  <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                  </svg>
                </span>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>

    <CTASection />

  </main>

  {/* Lightbox */}
  <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/95" role="dialog" aria-modal="true">
    <button id="lightbox-close" class="absolute top-4 right-4 z-10 text-white/70 hover:text-white" aria-label="Close">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 text-white/70 hover:text-white" aria-label="Previous">
      <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 text-white/70 hover:text-white" aria-label="Next">
      <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
    <div class="flex h-full items-center justify-center p-4">
      <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full rounded-lg object-contain" />
    </div>
    <p id="lightbox-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-center text-white/80"></p>
  </div>

  <FooterEn />
  <WhatsAppFAB />
  <ScrollToTop />

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const items = document.querySelectorAll('.gallery-item');
    
    let currentIndex = 0;
    const images = Array.from(items).map(item => ({
      src: item.querySelector('img').src,
      alt: item.querySelector('img').alt
    }));
    
    function showImage(index) {
      currentIndex = (index + images.length) % images.length;
      lightboxImg.src = images[currentIndex].src;
      lightboxImg.alt = images[currentIndex].alt;
      lightboxCaption.textContent = images[currentIndex].alt;
    }
    
    items.forEach((item, index) => {
      item.addEventListener('click', () => {
        showImage(index);
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });
    
    if (lightbox) {
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox || e.target === closeBtn) {
          lightbox.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    }
    
    if (prevBtn) prevBtn.addEventListener('click', () => showImage(currentIndex - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => showImage(currentIndex + 1));
    
    document.addEventListener('keydown', (e) => {
      if (!lightbox || !lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') { lightbox.classList.add('hidden'); document.body.style.overflow = ''; }
      if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
      if (e.key === 'ArrowRight') showImage(currentIndex + 1);
    });
  </script>
</Layout>