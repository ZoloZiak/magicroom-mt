{
  "rewrites": [
    { "source": "/o-nas", "destination": "/sk/o-nas" },
    { "source": "/sluzby", "destination": "/sk/sluzby" },
    { "source": "/svadobne-saty", "destination": "/sk/svadobne-saty" },
    { "source": "/spolocenske-saty", "destination": "/sk/spolocenske-saty" },
    { "source": "/galeria", "destination": "/sk/galeria" },
    { "source": "/blog", "destination": "/sk/blog" },
    { "source": "/blog/:slug", "destination": "/sk/blog/:slug" },
    { "source": "/komisny-predaj", "destination": "/sk/komisny-predaj" },
    { "source": "/prenajom-dekoracii", "destination": "/sk/prenajom-dekoracii" },
    { "source": "/partneri", "destination": "/sk/partneri" },
    { "source": "/kontakt", "destination": "/sk/kontakt" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
